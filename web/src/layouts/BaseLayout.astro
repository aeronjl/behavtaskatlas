---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import KeyboardNav from "../components/KeyboardNav.svelte";
import SearchPalette from "../components/SearchPalette.svelte";
import WhatsChangedBanner from "../components/WhatsChangedBanner.svelte";
import { catalog, manifest, papers } from "../lib/data";
import { findings } from "../lib/findings";
import { models } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  /** Inner container width — picks one of the --container-* tokens.
   * Defaults to "content" (64rem == previous max-w-5xl) for back-compat. */
  width?: "prose" | "content" | "wide" | "full";
}

const { title, description, width = "content" } = Astro.props;

const SITE_NAME = "behavtaskatlas";
const DEFAULT_DESCRIPTION =
  "A file-first atlas of sensory-guided decision-making tasks in behavioral neuroscience. Browse curated task families, protocols, datasets, and reproducible vertical slices.";
const resolvedDescription = description ?? DEFAULT_DESCRIPTION;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();

// Per-record OpenGraph cards. Detail pages (`/findings/<slug>`,
// `/papers/<slug>`, `/slices/<slug>`) get a generated SVG built by the
// `pages/og/<type>/[id].svg.ts` endpoints, so social previews show
// page-specific titles, citations, and (for findings) a sparkline of
// the observed curve. All other pages fall back to the generic
// `/og.svg` brand mark.
function deriveOgImage(pathname: string): string {
  const stripped = pathname.replace(/\/+$/, "");
  const detailMatch = stripped.match(/^\/(findings|papers|slices)\/([^/]+)$/);
  if (detailMatch) {
    return `/og/${detailMatch[1]}/${detailMatch[2]}.svg`;
  }
  return "/og.svg";
}
const ogImage = new URL(
  deriveOgImage(Astro.url.pathname),
  Astro.site ?? Astro.url,
).toString();

const widthClass = {
  prose: "max-w-prose",
  content: "max-w-content",
  wide: "max-w-wide",
  full: "max-w-full",
}[width];

// Counts surfaced to the what's-changed banner. The banner only renders
// when localStorage holds a previous snapshot whose commit differs from
// the build's commit — first-time visitors see nothing.
const whatsChangedCounts = {
  findings: findings.counts.findings ?? findings.findings.length,
  papers: papers.counts.papers ?? papers.papers.length,
  fits: models.counts?.fits ?? 0,
  slices: catalog.counts.vertical_slices ?? catalog.vertical_slices.length,
  protocols: catalog.counts.protocols ?? catalog.protocols.length,
  datasets: catalog.counts.datasets ?? catalog.datasets.length,
  families: catalog.counts.task_families ?? catalog.task_families.length,
};
const whatsChangedCommit = manifest.behavtaskatlas_commit ?? null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="min-h-screen overflow-x-hidden bg-surface text-fg">
    <Nav />
    <WhatsChangedBanner
      client:idle
      commit={whatsChangedCommit}
      counts={whatsChangedCounts}
    />
    <SearchPalette client:idle />
    <KeyboardNav client:idle />
    <main class:list={["mx-auto w-full min-w-0 px-4 py-8", widthClass]}>
      <slot />
    </main>
    <footer class="border-t border-rule bg-surface-raised">
      <div class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-x-4 gap-y-2 px-4 py-6 text-body-xs text-fg-muted">
        <span>
          behavtaskatlas — a file-first atlas of behavioral neuroscience tasks.
        </span>
        <ul class="flex flex-wrap items-center gap-x-4 gap-y-1">
          <li><a href="/about" class="no-underline hover:text-accent">About</a></li>
          <li>
            <a href="/project-health" class="no-underline hover:text-accent"
              >Atlas health</a
            >
          </li>
          <li>
            <a
              href="https://github.com/aeronjl/behavtaskatlas"
              class="no-underline hover:text-accent">GitHub</a>
          </li>
        </ul>
      </div>
    </footer>
  </body>
</html>
