---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SlicesBrowser from "../../components/SlicesBrowser.svelte";
import PageHeader from "../../components/ui/PageHeader.astro";
import { catalog, manifest } from "../../lib/data";

const familyById = new Map(
  catalog.task_families.map((family) => [family.family_id, family.name]),
);
const protocolById = new Map(
  catalog.protocols.map((protocol) => [protocol.protocol_id, protocol.name]),
);
const datasetById = new Map(
  catalog.datasets.map((dataset) => [dataset.dataset_id, dataset.name]),
);

const sliceRows = manifest.slices.map((slice) => ({
  ...slice,
  family_name: familyById.get(slice.family_id) ?? null,
  protocol_name: protocolById.get(slice.protocol_id) ?? null,
  dataset_name: datasetById.get(slice.dataset_id) ?? null,
}));
---

<BaseLayout
  title="Vertical slices · behavtaskatlas"
  description="Browse reproducible vertical slices linking behavioral neuroscience protocols, datasets, source data, and local analysis reports."
  width="wide"
>
  <PageHeader
    title="Vertical slices"
    lede={`Each slice binds one protocol and one dataset to a reproducible local analysis pipeline. ${manifest.slices.length} slices.`}
  />

  <SlicesBrowser rows={sliceRows} client:load />
</BaseLayout>
