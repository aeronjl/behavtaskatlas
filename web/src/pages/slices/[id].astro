---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import InPlacePyodide from "../../components/InPlacePyodide.svelte";
import MiniFindingsChart from "../../components/MiniFindingsChart.svelte";
import Card from "../../components/ui/Card.astro";
import DetailLayout from "../../components/ui/DetailLayout.astro";
import DetailToc from "../../components/ui/DetailToc.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Section from "../../components/ui/Section.astro";
import Stat from "../../components/ui/Stat.astro";
import StatGrid from "../../components/ui/StatGrid.astro";
import StatusPill from "../../components/ui/StatusPill.astro";
import {
  catalog,
  manifest,
  slugForId,
} from "../../lib/data";
import type { ManifestSlice } from "../../lib/data";
import { findings as findingsIndex } from "../../lib/findings";

export function getStaticPaths() {
  return manifest.slices.map((slice) => ({
    params: { id: slugForId(slice.id) },
    props: { slice },
  }));
}

interface Props {
  slice: ManifestSlice;
}

const { slice } = Astro.props as Props;
const protocol = catalog.protocol_details.find(
  (p) => p.protocol_id === slice.protocol_id,
);
const dataset = catalog.dataset_details.find(
  (d) => d.dataset_id === slice.dataset_id,
);

const comparisonRows: [string, string][] = [
  ["Species", slice.comparison.species],
  ["Modality", slice.comparison.modality],
  ["Stimulus metric", slice.comparison.stimulus_metric],
  ["Evidence type", slice.comparison.evidence_type],
  ["Choice type", slice.comparison.choice_type],
  ["Response modality", slice.comparison.response_modality],
  ["Source data level", slice.comparison.source_data_level],
  ["Analysis outputs", slice.comparison.analysis_outputs],
  ["Data scope", slice.comparison.data_scope],
  ["Canonical axis", slice.comparison.canonical_axis],
];

const reportAvailable = slice.report_status === "available";

type SliceMetric = { label: string; value: unknown };
type SliceLink = { href: string; label: string };

const metrics: SliceMetric[] = ((slice.metrics ?? []) as unknown as SliceMetric[]);
const links: SliceLink[] = ((slice.links ?? []) as unknown as SliceLink[]);

const sliceFindings = findingsIndex.findings.filter(
  (entry) => entry.slice_id === slice.id,
);

const REPO_SOURCE_BASE = "https://github.com/aeronjl/behavtaskatlas/blob/main";

type AnalysisConfig = {
  trialsUrl: string;
  title: string;
  description: string;
  snippet: string;
};

const ANALYSIS_CONFIGS: Record<string, AnalysisConfig> = {
  "slice.allen-visual-behavior": {
    trialsUrl: "/allen_visual_behavior/trials.csv",
    title: "Allen Visual Behavior · outcome breakdown",
    description:
      "Recompute hit, miss, false-alarm, correct-reject counts and the corresponding rates against the slice's canonical trials.csv. Output should match the Python adapter's analysis_result.json exactly.",
    snippet: `# Recompute the Allen Visual Behavior outcome breakdown in your browser.
# df is a pandas DataFrame loaded from the slice's canonical trials.csv.
# task_variables_json is parsed for you into df["task_variables"].

outcome_counts = (
    df["task_variables"]
    .apply(lambda v: v.get("outcome", "unknown"))
    .value_counts()
)
print("Outcome counts:")
print(outcome_counts.to_string())

hit = int(outcome_counts.get("hit", 0))
miss = int(outcome_counts.get("miss", 0))
fa = int(outcome_counts.get("false_alarm", 0))
cr = int(outcome_counts.get("correct_reject", 0))
hit_rate = hit / (hit + miss) if (hit + miss) else float("nan")
fa_rate = fa / (fa + cr) if (fa + cr) else float("nan")
print(f"\\nHit rate:        {hit_rate:.3f} ({hit}/{hit + miss})")
print(f"False-alarm rate: {fa_rate:.3f} ({fa}/{fa + cr})")
`,
  },
  "slice.ibl-visual-decision": {
    trialsUrl:
      "/ibl_visual_decision/ebce500b-c530-47de-8cb1-963c552703ea/trials.csv",
    title: "IBL Visual Decision · psychometric by prior block",
    description:
      "Group canonical trials by prior block (probabilityLeft) and signed contrast, then compute P(right) and trial counts per cell. Useful as a starting point for fitting prior-conditioned psychometrics.",
    snippet: `# Group IBL trials by prior block and signed contrast, compute P(right).
# df["choice"] is "left", "right", or "no-response".
# df["stimulus_value"] is signed contrast (right positive).
# df["prior_context"] is e.g. "p_left=0.5", "p_left=0.8", "p_left=0.2".

responded = df[df["choice"].isin(["left", "right"])].copy()
responded["signed_contrast"] = responded["stimulus_value"].astype(float)
grouped = responded.groupby(["prior_context", "signed_contrast"], dropna=False)
summary = grouped.apply(
    lambda g: pd.Series({
        "n": len(g),
        "p_right": (g["choice"] == "right").mean(),
    })
).reset_index()
print(f"Responded trials: {len(responded)} (of {len(df)})\\n")
print("P(right) by prior block × signed contrast:")
print(summary.pivot(index="signed_contrast", columns="prior_context", values="p_right").round(3).to_string())
`,
  },
  "slice.auditory-clicks": {
    trialsUrl: "/auditory_clicks/batch_summary.csv",
    title: "Auditory Clicks · per-rat batch summary",
    description:
      "Inspect the cross-rat aggregate batch summary. This slice is an aggregate across multiple Brody Lab rats, so the CSV is one row per rat (not per trial). Trial-level data lives in per-rat subdirectories that are not bundled into the public deploy.",
    snippet: `# The auditory_clicks slice aggregates over multiple Brody Lab rats.
# The CSV here is the per-rat batch summary; each row is one harmonized rat
# session, not one trial. Trial-level rows are kept under per-rat
# subdirectories and are not bundled into the public deploy.

print("Per-rat batch summary:")
print(
    df[
        [
            "subject_id",
            "task_type",
            "n_trials",
            "psychometric_summary_rows",
            "evidence_kernel_analyzed_trials",
        ]
    ].to_string(index=False)
)

n_rats = len(df)
total_trials = int(df["n_trials"].sum())
print(f"\\nRats: {n_rats}")
print(f"Total trials across all rats: {total_trials:,}")
print(f"Mean trials per rat: {df['n_trials'].mean():.0f}")
print(f"Task types: {sorted(df['task_type'].unique())}")
`,
  },
  "slice.human-auditory-clicks-dbs": {
    trialsUrl: "/human_auditory_clicks/london-dbs-poisson-clicks-mendeley/trials.csv",
    title: "Human DBS Poisson Clicks · psychometric by DBS state",
    description:
      "Group London Mendeley trials by DBS condition (on/off) and signed click-count difference, then compute P(right).",
    snippet: `# Group London DBS Poisson Clicks by DBS state and signed click difference.
# df["prior_context"] is "dbs=off" or "dbs=on".
# df["stimulus_value"] is the signed click-count difference (right positive).

responded = df[df["choice"].isin(["left", "right"])].copy()
responded["click_diff"] = responded["stimulus_value"].astype(float)

summary = (
    responded.groupby(["prior_context", "click_diff"])
    .apply(lambda g: pd.Series({
        "n": len(g),
        "p_right": (g["choice"] == "right").mean(),
    }))
    .reset_index()
)
print(f"Responded trials: {len(responded)} (of {len(df)})")
print("\\nP(right) by DBS state × signed click difference:")
print(
    summary.pivot(index="click_diff", columns="prior_context", values="p_right")
    .round(3)
    .to_string()
)
`,
  },
  "slice.human-random-dot-motion": {
    trialsUrl: "/human_random_dot_motion/palmer-huk-shadlen-cosmo2017/trials.csv",
    title: "Human RDM · psychometric across observers",
    description:
      "Compute P(right) by signed motion coherence pooled across observers in the Palmer-Huk-Shadlen CoSMo2017 dataset.",
    snippet: `# Palmer-Huk-Shadlen human RDM, signed coherence in df["stimulus_value"].

responded = df[df["choice"].isin(["left", "right"])].copy()
responded["coh"] = responded["stimulus_value"].astype(float)

summary = (
    responded.groupby("coh")
    .apply(lambda g: pd.Series({
        "n": len(g),
        "p_right": (g["choice"] == "right").mean(),
        "median_rt_s": g["response_time"].astype(float).median(),
    }))
    .reset_index()
)
print(f"Responded trials: {len(responded)} (of {len(df)})")
if "subject_id" in df.columns:
    print(f"Observers: {sorted(df['subject_id'].dropna().unique())}")
print("\\nPsychometric + chronometric pooled across observers:")
print(summary.round(3).to_string(index=False))
`,
  },
  "slice.human-visual-contrast-prior-cue": {
    trialsUrl: "/human_visual_contrast/walsh-prior-cue-human-contrast-osf/trials.csv",
    title: "Walsh Human Visual Contrast · psychometric by cue",
    description:
      "Group Walsh prior-cue trials by cue context and signed target-distractor contrast difference, then compute P(right). Note: the trials CSV for this slice is ~87 MB; the first fetch will be noticeably slow.",
    snippet: `# Walsh prior-cue trials, df["prior_context"] is e.g. "cue=valid".
# df["stimulus_value"] is signed target-distractor contrast difference.
#
# Heads up: this slice's trials.csv is ~87 MB. First run will be slow.

responded = df[df["choice"].isin(["left", "right"])].copy()
responded["contrast"] = responded["stimulus_value"].astype(float)

summary = (
    responded.groupby(["prior_context", "contrast"])
    .apply(lambda g: pd.Series({
        "n": len(g),
        "p_right": (g["choice"] == "right").mean(),
    }))
    .reset_index()
)
print(f"Responded trials: {len(responded)} (of {len(df)})")
print("\\nP(right) by cue × signed contrast difference:")
print(
    summary.pivot(index="contrast", columns="prior_context", values="p_right")
    .round(3)
    .to_string()
)
`,
  },
  "slice.macaque-rdm-confidence-wager": {
    trialsUrl:
      "/macaque_rdm_confidence/khalvati-kiani-rao-natcomm2021-source-data/accuracy_summary.csv",
    title: "Macaque RDM Confidence · accuracy by motion strength",
    description:
      "Per-monkey accuracy across motion strengths from the Khalvati-Kiani-Rao source-data summary. The full source-row CSV is ~242 MB so the cell uses the slice's pre-aggregated accuracy summary (a few dozen rows, one per measure × monkey × motion strength).",
    snippet: `# Per-monkey accuracy by motion strength.
# df is the slice's accuracy_summary.csv: one row per
# (source_measure, monkey, motion_strength_percent).
# source_measure is "accuracy_no_sure_target" (regular trials) or
# "accuracy_with_sure_target" (trials where the sure-target option was offered).

print("Rows:", len(df))
print("Monkeys:", sorted(df["monkey"].unique()))
print("Source measures:", sorted(df["source_measure"].unique()))

# Compare regular-trial accuracy by monkey × motion strength.
regular = df[df["source_measure"] == "accuracy_no_sure_target"]
pivot = regular.pivot(
    index="motion_strength_percent",
    columns="monkey",
    values="p_correct",
).round(3)
print("\\nP(correct) on no-sure-target trials by monkey × motion strength:")
print(pivot.to_string())
`,
  },
  "slice.mouse-visual-contrast-unbiased": {
    trialsUrl:
      "/mouse_visual_contrast_unbiased/6a6442d1-dd7d-4717-b7b1-5874aefbd6fc/trials.csv",
    title: "Mouse trainingChoiceWorld · psychometric + chronometric",
    description:
      "One unbiased trainingChoiceWorld session: compute P(right) and median response time per signed contrast level.",
    snippet: `# IBL trainingChoiceWorld session, df["stimulus_value"] is signed contrast %.

responded = df[df["choice"].isin(["left", "right"])].copy()
responded["contrast"] = responded["stimulus_value"].astype(float)

summary = (
    responded.groupby("contrast")
    .apply(lambda g: pd.Series({
        "n": len(g),
        "p_right": (g["choice"] == "right").mean(),
        "median_rt_s": g["response_time"].astype(float).median(),
    }))
    .reset_index()
)
print(f"Subject: {df['subject_id'].iloc[0]}")
print(f"Session: {df['session_id'].iloc[0]}")
print(f"Responded trials: {len(responded)} (of {len(df)})")
print("\\nPsychometric + chronometric:")
print(summary.round(3).to_string(index=False))
`,
  },
  "slice.random-dot-motion": {
    trialsUrl: "/random_dot_motion/roitman-shadlen-pyddm/trials.csv",
    title: "Random-Dot Motion · psychometric (with plot)",
    description:
      "Recompute P(right) by signed coherence and median RT by absolute coherence, then plot the psychometric curve. First run downloads matplotlib (~12 MB) on top of the base Pyodide runtime.",
    snippet: `# Plot the Roitman-Shadlen RDM psychometric curve in the browser.
# df["stimulus_value"] is signed motion coherence (right positive).
# df["response_time"] is in seconds.
# plt.show() is captured by the wrapper and rendered inline.

import matplotlib.pyplot as plt

responded = df[df["choice"].isin(["left", "right"])].copy()
responded["coh_signed"] = responded["stimulus_value"].astype(float)
responded["coh_abs"] = responded["coh_signed"].abs()

psychometric = (
    responded.groupby("coh_signed")
    .apply(lambda g: pd.Series({
        "n": len(g),
        "p_right": (g["choice"] == "right").mean(),
    }))
    .reset_index()
)
chronometric = (
    responded.groupby("coh_abs")
    .apply(lambda g: pd.Series({
        "n": len(g),
        "median_rt_s": g["response_time"].astype(float).median(),
    }))
    .reset_index()
)

print(f"Responded trials: {len(responded)} (of {len(df)})\\n")
print("Psychometric (P(right) by signed coherence):")
print(psychometric.round(3).to_string(index=False))
print("\\nChronometric (median RT by abs coherence):")
print(chronometric.round(3).to_string(index=False))

fig, ax = plt.subplots(figsize=(6.5, 4.2))
ax.scatter(
    psychometric["coh_signed"],
    psychometric["p_right"],
    s=psychometric["n"].clip(lower=4) * 1.2,
    color="#2b5ea0",
    alpha=0.85,
    edgecolor="white",
)
ax.plot(
    psychometric["coh_signed"],
    psychometric["p_right"],
    color="#2b5ea0",
    alpha=0.5,
    linewidth=1,
)
ax.axhline(0.5, color="#888", linestyle="--", linewidth=0.7)
ax.axvline(0, color="#888", linestyle="--", linewidth=0.7)
ax.set_xlabel("Signed motion coherence")
ax.set_ylabel("P(rightward choice)")
ax.set_title("Roitman-Shadlen RDM · psychometric")
ax.set_ylim(-0.02, 1.02)
ax.grid(True, alpha=0.25)
plt.show()
`,
  },
};

const analysisConfig = ANALYSIS_CONFIGS[slice.id];

function resolveArtifactHref(href: string): string {
  if (/^https?:\/\//.test(href) || href.startsWith("#")) {
    return href;
  }
  if (href.startsWith("../")) {
    // Repository-typed path emitted by the JSON manifest as a sibling-relative
    // link from derived/. Translate into a stable GitHub source URL.
    return `${REPO_SOURCE_BASE}/${href.replace(/^\.\.\//, "")}`;
  }
  // Derived-typed path: the slice-artifacts bundle extracts to web/public/,
  // so the deployed asset lives at the absolute root path.
  return `/${href.replace(/^\/+/, "")}`;
}

type TocItem = { id: string; label: string; count?: number };

const tocItems: TocItem[] = [
  analysisConfig
    ? { id: "analysis", label: "Run in your browser" }
    : null,
  sliceFindings.length > 0
    ? {
        id: "findings",
        label: "Findings extracted",
        count: sliceFindings.length,
      }
    : null,
  metrics.length > 0
    ? { id: "metrics", label: "Metrics", count: metrics.length }
    : null,
  { id: "profile", label: "Slice profile" } as TocItem,
  { id: "artifacts", label: "Artifacts" } as TocItem,
].filter((item): item is TocItem => item !== null);

const reportTone = reportAvailable ? "ok" : "warn";
const protocolHref = protocol
  ? `/protocols/${slugForId(protocol.protocol_id)}`
  : null;
const datasetHref = dataset
  ? `/datasets/${slugForId(dataset.dataset_id)}`
  : null;
---

<BaseLayout title={`${slice.title} · Slice`} width="wide">
  <Breadcrumbs
    crumbs={[
      { label: "Slices", href: "/slices" },
      { label: slice.title },
    ]}
  />

  <DetailLayout>
    <Fragment slot="rail">
      <DetailToc items={tocItems} />
      <Card padding="md" class="text-body-xs">
        <h3 class="mb-3 text-eyebrow uppercase text-fg-muted">Slice</h3>
        <dl class="space-y-3">
          <div>
            <dt class="text-fg-muted">Status</dt>
            <dd class="mt-1">
              <StatusPill tone={reportTone}>{slice.status_label}</StatusPill>
            </dd>
          </div>
          <div>
            <dt class="text-fg-muted">Protocol</dt>
            <dd class="mt-0.5">
              {protocol && protocolHref ? (
                <a class="text-fg" href={protocolHref}>{protocol.name}</a>
              ) : (
                <span class="font-mono text-mono-id text-fg-muted">{slice.protocol_id}</span>
              )}
            </dd>
          </div>
          <div>
            <dt class="text-fg-muted">Dataset</dt>
            <dd class="mt-0.5">
              {dataset && datasetHref ? (
                <a class="text-fg" href={datasetHref}>{dataset.name}</a>
              ) : (
                <span class="font-mono text-mono-id text-fg-muted">{slice.dataset_id}</span>
              )}
            </dd>
          </div>
          <div>
            <dt class="text-fg-muted">Slice id</dt>
            <dd class="mt-0.5 break-all font-mono text-mono-id text-fg-muted">{slice.id}</dd>
          </div>
        </dl>
      </Card>
    </Fragment>

    <PageHeader
      eyebrow="Vertical slice"
      title={slice.title}
      lede={slice.description}
    />

    {analysisConfig ? (
      <Section
        id="analysis"
        spacing="md"
        title={analysisConfig.title}
        eyebrow="Run in your browser"
        description={analysisConfig.description}
      >
        <Fragment slot="action">
          <p class="text-body-xs text-fg-muted">
            Pyodide + scipy run locally; first load downloads ~12 MB.
          </p>
        </Fragment>
        <InPlacePyodide
          client:visible
          title={analysisConfig.title}
          description={analysisConfig.description}
          trialsUrl={analysisConfig.trialsUrl}
          pythonSnippet={analysisConfig.snippet}
        />
      </Section>
    ) : (
      <Card padding="md" border="strong" class="mb-10 border-dashed text-body text-fg-secondary">
        No in-browser analysis cell is bundled for this slice yet. Run the
        pipeline locally with{" "}
        <code class="rounded bg-surface-sunken px-1 font-mono text-mono-id">
          uv run behavtaskatlas {slice.id.replace("slice.", "")}-report
        </code>
        to generate full artifacts.
      </Card>
    )}

    {sliceFindings.length > 0 ? (
      <Section
        id="findings"
        spacing="md"
        title="Findings extracted"
        description="Curves attached to this slice, on shared signed-evidence axes."
      >
        <MiniFindingsChart
          client:visible
          findings={sliceFindings}
          colorBy="condition"
          height={260}
        />
      </Section>
    ) : null}

    {metrics.length > 0 ? (
      <Section id="metrics" spacing="md" title="Metrics">
        <StatGrid cols={4}>
          {metrics.map((metric) => (
            <Stat label={metric.label} value={(metric.value ?? "—") as string | number} />
          ))}
        </StatGrid>
      </Section>
    ) : null}

    <Section
      id="profile"
      spacing="md"
      title="Slice profile"
      description="Operational variables for cross-slice comparison."
    >
      <Card padding="none" class="overflow-hidden">
        <table class="w-full text-body">
          <tbody class="divide-y divide-rule">
            {comparisonRows.map(([label, value]) => (
              <tr>
                <td class="w-48 px-3 py-2 text-eyebrow uppercase text-fg-muted">
                  {label}
                </td>
                <td class="px-3 py-2">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </Card>
    </Section>

    <Section id="artifacts" spacing="md" title="Artifacts">
      {reportAvailable ? (
        <Card padding="md" surface="ok" border="tinted" class="mb-3 text-body text-ok">
          Slice has a generated local report; the analysis pipeline ran cleanly
          and produced trial-level output, plots, and provenance.
        </Card>
      ) : (
        <Card padding="md" surface="warn" border="tinted" class="mb-3 text-body text-warn">
          Slice report has not been bundled into this deploy. Run the slice
          pipeline locally to regenerate artifacts.
        </Card>
      )}
      {links.length > 0 ? (
        <ul class="space-y-1 text-body">
          {links
            .map((link) => ({
              ...link,
              resolved: resolveArtifactHref(link.href),
            }))
            .map((link) => (
              <li>
                <a href={link.resolved} class="break-all">
                  {link.label}
                </a>
                <span class="ml-2 break-all font-mono text-mono-id text-fg-muted">
                  {link.href}
                </span>
              </li>
            ))}
        </ul>
      ) : null}
    </Section>
  </DetailLayout>
</BaseLayout>
