---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  catalog,
  manifest,
  slugForId,
} from "../../lib/data";
import type { ManifestSlice } from "../../lib/data";

export function getStaticPaths() {
  return manifest.slices.map((slice) => ({
    params: { id: slugForId(slice.id) },
    props: { slice },
  }));
}

interface Props {
  slice: ManifestSlice;
}

const { slice } = Astro.props;
const protocol = catalog.protocol_details.find(
  (p) => p.protocol_id === slice.protocol_id,
);
const dataset = catalog.dataset_details.find(
  (d) => d.dataset_id === slice.dataset_id,
);

const comparisonRows: [string, string][] = [
  ["Species", slice.comparison.species],
  ["Modality", slice.comparison.modality],
  ["Stimulus metric", slice.comparison.stimulus_metric],
  ["Evidence type", slice.comparison.evidence_type],
  ["Choice type", slice.comparison.choice_type],
  ["Response modality", slice.comparison.response_modality],
  ["Source data level", slice.comparison.source_data_level],
  ["Analysis outputs", slice.comparison.analysis_outputs],
  ["Data scope", slice.comparison.data_scope],
  ["Canonical axis", slice.comparison.canonical_axis],
];

const reportAvailable = slice.report_status === "available";

const REPO_SOURCE_BASE = "https://github.com/aeronjl/behavtaskatlas/blob/main";

function resolveArtifactHref(href: string): string {
  if (/^https?:\/\//.test(href) || href.startsWith("#")) {
    return href;
  }
  if (href.startsWith("../")) {
    // Repository-typed path emitted by the JSON manifest as a sibling-relative
    // link from derived/. Translate into a stable GitHub source URL.
    return `${REPO_SOURCE_BASE}/${href.replace(/^\.\.\//, "")}`;
  }
  // Derived-typed path: the slice-artifacts bundle extracts to web/public/,
  // so the deployed asset lives at the absolute root path.
  return `/${href.replace(/^\/+/, "")}`;
}
---

<BaseLayout title={`${slice.title} · Slice`}>
  <header class="mb-6">
    <p class="text-xs uppercase tracking-wide text-slate-500">Vertical slice</p>
    <h1 class="text-3xl font-semibold tracking-tight">{slice.title}</h1>
    <p class="mt-2 text-sm text-slate-700">{slice.description}</p>
    <div class="mt-3 flex items-center gap-2 text-xs">
      <span
        class:list={[
          "rounded px-2 py-0.5",
          reportAvailable ? "bg-ok-soft text-ok" : "bg-warn-soft text-warn",
        ]}
      >
        {slice.status_label}
      </span>
      <span class="text-slate-500 font-mono">{slice.id}</span>
    </div>
  </header>

  <section class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-2">
    <div class="rounded-md border border-slate-200 bg-white p-4">
      <h2 class="mb-2 text-sm font-semibold text-slate-700">Protocol</h2>
      {
        protocol ? (
          <a href={`/protocols/${slugForId(protocol.protocol_id)}`} class="text-sm">
            {protocol.name}
          </a>
        ) : (
          <p class="text-sm text-slate-500">{slice.protocol_id}</p>
        )
      }
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-4">
      <h2 class="mb-2 text-sm font-semibold text-slate-700">Dataset</h2>
      {
        dataset ? (
          <a href={`/datasets/${slugForId(dataset.dataset_id)}`} class="text-sm">
            {dataset.name}
          </a>
        ) : (
          <p class="text-sm text-slate-500">{slice.dataset_id}</p>
        )
      }
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-2 text-sm font-semibold text-slate-700">Comparison</h2>
    <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
      <table class="w-full text-sm">
        <tbody class="divide-y divide-slate-200">
          {
            comparisonRows.map(([label, value]) => (
              <tr>
                <td class="w-48 px-3 py-2 text-xs uppercase tracking-wide text-slate-500">
                  {label}
                </td>
                <td class="px-3 py-2">{value}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  {
    slice.metrics && slice.metrics.length > 0 ? (
      <section class="mb-8">
        <h2 class="mb-2 text-sm font-semibold text-slate-700">Metrics</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          {slice.metrics.map((metric) => (
            <div class="rounded-md border border-slate-200 bg-white p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">
                {metric.label}
              </div>
              <div class="mt-1 text-lg font-semibold">
                {metric.value ?? "—"}
              </div>
            </div>
          ))}
        </div>
      </section>
    ) : null
  }

  <section class="mb-8">
    <h2 class="mb-2 text-sm font-semibold text-slate-700">Artifacts</h2>
    {
      reportAvailable ? (
        <p class="mb-3 rounded-md border border-ok bg-ok-soft p-3 text-sm text-ok">
          Slice has a generated local report; the analysis pipeline ran cleanly
          and produced trial-level output, plots, and provenance.
        </p>
      ) : (
        <p class="mb-3 rounded-md border border-warn bg-warn-soft p-3 text-sm text-warn">
          Slice report has not been bundled into this deploy. Run the slice
          pipeline locally (see the protocol's source repository) to regenerate
          artifacts; once CI bundles slice outputs (Phase 4 of the migration),
          these links will resolve in production.
        </p>
      )
    }
    {
      slice.links && slice.links.length > 0 ? (
        <ul class="space-y-1 text-sm">
          {slice.links
            .map((link) => ({
              ...link,
              resolved: resolveArtifactHref(link.href),
            }))
            .map((link) => (
              <li>
                <a href={link.resolved} class="break-all">
                  {link.label}
                </a>
                <span class="ml-2 text-xs font-mono text-slate-500 break-all">
                  {link.href}
                </span>
              </li>
            ))}
        </ul>
      ) : null
    }
  </section>
</BaseLayout>
