---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DdmParamScatter from "../../components/DdmParamScatter.svelte";
import { models } from "../../lib/data";
import { findings as findingsIndex, type FindingsEntry } from "../../lib/findings";

type Variant = { id: string; family_id: string; name: string };
type Fit = {
  id: string;
  variant_id: string;
  finding_ids: string[];
  parameters: Record<string, number>;
  quality: Record<string, number>;
};
const variants = (models.variants ?? []) as unknown as Variant[];
const fits = (models.fits ?? []) as unknown as Fit[];

const ddmVariantIds = new Set(
  variants
    .filter((v) => v.family_id === "model_family.drift-diffusion")
    .map((v) => v.id),
);

const findingsById = new Map<string, FindingsEntry>();
for (const f of findingsIndex.findings as FindingsEntry[]) findingsById.set(f.finding_id, f);

const rows = fits
  .filter((f) => ddmVariantIds.has(f.variant_id))
  .map((f) => {
    const psyId = f.finding_ids.find((fid) => findingsById.get(fid)?.curve_type === "psychometric") ?? f.finding_ids[0];
    const entry = psyId ? findingsById.get(psyId) ?? null : null;
    const paperShort = entry?.paper_citation.split(".")[0] ?? entry?.paper_id ?? f.variant_id;
    return {
      fit_id: f.id,
      variant: f.variant_id.replace("model_variant.", ""),
      paper_id: entry?.paper_id ?? "",
      paper_label: paperShort,
      species: entry?.species ?? "unknown",
      subject_id: entry?.stratification?.subject_id ?? null,
      condition: entry?.stratification?.condition ?? null,
      drift_per_unit_evidence: f.parameters.drift_per_unit_evidence ?? NaN,
      boundary: f.parameters.boundary ?? NaN,
      non_decision_time: f.parameters.non_decision_time ?? NaN,
      starting_point: f.parameters.starting_point ?? null,
      drift_bias: f.parameters.drift_bias ?? null,
      aic: f.quality?.aic ?? null,
    };
  });

const speciesList = Array.from(new Set(rows.map((r) => r.species))).sort();
const variantList = Array.from(new Set(rows.map((r) => r.variant))).sort();

function fmt(value: number | null | undefined, digits = 3): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "—";
  return value.toFixed(digits);
}
---

<BaseLayout
  title="DDM parameters · behavtaskatlas"
  description="Cross-paper view of drift-diffusion model parameters: drift per unit evidence, boundary, and non-decision time across all DDM fits in the atlas."
>
  <header class="mb-6">
    <p class="text-xs uppercase tracking-wide text-slate-500">Models · drift-diffusion</p>
    <h1 class="text-3xl font-semibold tracking-tight">
      DDM parameters across the atlas
    </h1>
    <p class="mt-2 text-sm text-slate-600">
      {rows.length} DDM fits across {speciesList.length} species and{" "}
      {variantList.length} variant{variantList.length === 1 ? "" : "s"}. Each
      panel below is a strip plot of one parameter; points are coloured by
      paper and shaped by variant. Hover for fit ids and stratification.
    </p>
  </header>

  {
    rows.length === 0 ? (
      <p class="rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-600">
        No DDM fits committed yet.
      </p>
    ) : (
      <>
        <section class="mb-8 rounded-md border border-slate-200 bg-white p-4">
          <DdmParamScatter client:visible fits={rows} height={300} />
        </section>

        <section class="mb-8">
          <h2 class="mb-2 text-sm font-semibold text-slate-700">All DDM fits</h2>
          <div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-3 py-2">Variant</th>
                  <th class="px-3 py-2">Paper</th>
                  <th class="px-3 py-2">Species</th>
                  <th class="px-3 py-2">Subject / condition</th>
                  <th class="px-3 py-2 text-right">k</th>
                  <th class="px-3 py-2 text-right">a</th>
                  <th class="px-3 py-2 text-right">t0 (s)</th>
                  <th class="px-3 py-2 text-right">z</th>
                  <th class="px-3 py-2 text-right">v0</th>
                  <th class="px-3 py-2 text-right">AIC</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                {rows.map((r) => (
                  <tr>
                    <td class="px-3 py-2 font-mono text-[11px]">{r.variant}</td>
                    <td class="px-3 py-2 text-xs">{r.paper_label}</td>
                    <td class="px-3 py-2 text-xs">{r.species}</td>
                    <td class="px-3 py-2 text-[11px] text-slate-600">
                      {r.subject_id ?? r.condition ?? "—"}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {fmt(r.drift_per_unit_evidence, 4)}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">{fmt(r.boundary)}</td>
                    <td class="px-3 py-2 text-right font-mono">
                      {fmt(r.non_decision_time)}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {r.starting_point !== null ? fmt(r.starting_point) : "—"}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {r.drift_bias !== null ? fmt(r.drift_bias) : "—"}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {fmt(r.aic, 1)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <p class="text-xs text-slate-500">
          Caveats: vanilla, z-bias, and v-bias variants share the same family
          but free different parameters; columns z and v0 only have values
          when the variant frees that parameter (otherwise the family default
          z=0.5, v0=0 is in force). Walsh per-cue fits use closed-form
          marginal mean RT, which under-uses RT for distinguishing z vs v
          bias — see the
          <a class="text-accent" href="/compare#comparison.walsh-bias-locus">
            Walsh bias-locus comparison
          </a>{" "}
          for the AIC verdict per cue.
        </p>
      </>
    )
  }
</BaseLayout>
