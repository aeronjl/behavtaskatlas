---
import BaseLayout from "../layouts/BaseLayout.astro";
import { audit, slugForId } from "../lib/data";

type AuditReportRow = (typeof audit)["reports"][number];
type AuditPerPoint = NonNullable<AuditReportRow["per_point"]>[number];
const reports = audit.reports as AuditReportRow[];

function statusClass(status: string): string {
  if (status === "ok") return "bg-ok-soft text-ok";
  if (status === "drift") return "bg-bad-soft text-bad";
  if (status === "ambiguous") return "bg-warn-soft text-warn";
  return "bg-slate-100 text-slate-700";
}

function fmt(value: number | null | undefined, digits = 6): string {
  if (value === null || value === undefined) return "—";
  return value.toFixed(digits);
}
---

<BaseLayout
  title="Reproducibility audit · behavtaskatlas"
  description="Per-paper reconciliation between pooled findings and the n-weighted aggregate of their per-subject findings."
>
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Reproducibility audit</h1>
    <p class="mt-2 text-sm text-slate-600">
      For each (paper × curve type × condition) group with both a pooled
      finding and ≥2 per-subject findings, the audit recomputes the
      n-weighted aggregate of the subject curves and compares to the
      pooled curve at every matching x. CI runs this check after pytest;
      this page is the latest committed result.
    </p>
  </header>

  <section class="mb-6 rounded-md border border-slate-200 bg-white p-4">
    <div class="flex flex-wrap items-baseline gap-3">
      <span class={`rounded px-2 py-0.5 text-xs uppercase ${statusClass(audit.overall_status)}`}>
        {audit.overall_status}
      </span>
      <p class="text-sm text-slate-700">
        {audit.n_groups_audited} group{audit.n_groups_audited === 1 ? "" : "s"} audited.
      </p>
      <p class="text-xs text-slate-500">
        max |diff| = {fmt(audit.overall_max_abs_diff)} (tolerance {fmt(audit.tolerance, 4)})
      </p>
    </div>
  </section>

  {
    reports.length === 0 ? (
      <p class="rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-600">
        No groups currently meet the audit criteria (≥1 pooled + ≥2 per-subject).
      </p>
    ) : (
      <div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-3 py-2">Paper</th>
              <th class="px-3 py-2">Curve</th>
              <th class="px-3 py-2">Condition</th>
              <th class="px-3 py-2 text-right">Subjects</th>
              <th class="px-3 py-2 text-right">x overlap</th>
              <th class="px-3 py-2 text-right">max |diff|</th>
              <th class="px-3 py-2">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            {reports.map((r) => (
              <tr>
                <td class="px-3 py-2">
                  <a class="font-mono text-xs" href={`/papers/${slugForId(r.paper_id)}`}>
                    {r.paper_id}
                  </a>
                </td>
                <td class="px-3 py-2 text-xs">{r.curve_type}</td>
                <td class="px-3 py-2 text-xs text-slate-600">{r.condition || "—"}</td>
                <td class="px-3 py-2 text-right font-mono">
                  {r.n_subjects ?? "—"}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {r.n_x_overlap ?? "—"}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {fmt(r.max_abs_diff)}
                </td>
                <td class="px-3 py-2">
                  <span class={`rounded px-2 py-0.5 text-xs uppercase ${statusClass(r.status)}`}>
                    {r.status}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }

  <section class="mt-6 space-y-6">
    {reports
      .filter((r) => r.status !== "ok" && Array.isArray(r.per_point))
      .map((r) => (
        <details class="rounded-md border border-slate-200 bg-white p-4">
          <summary class="cursor-pointer text-sm font-semibold text-slate-700">
            {r.paper_id} · {r.curve_type}
            {r.condition ? ` · ${r.condition}` : ""} — per-point detail
          </summary>
          <div class="mt-3 overflow-x-auto">
            <table class="w-full text-xs">
              <thead class="text-left text-[11px] uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-2 py-1 text-right">x</th>
                  <th class="px-2 py-1 text-right">pooled y</th>
                  <th class="px-2 py-1 text-right">aggregated y</th>
                  <th class="px-2 py-1 text-right">|diff|</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {(r.per_point as AuditPerPoint[]).map((p) => (
                  <tr>
                    <td class="px-2 py-1 text-right font-mono">{p.x}</td>
                    <td class="px-2 py-1 text-right font-mono">{fmt(p.pooled_y, 4)}</td>
                    <td class="px-2 py-1 text-right font-mono">{fmt(p.agg_y, 4)}</td>
                    <td class="px-2 py-1 text-right font-mono">{fmt(p.abs_diff, 4)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      ))}
  </section>

  <p class="mt-6 text-xs text-slate-500">
    Local check: <code class="rounded bg-slate-100 px-1">uv run behavtaskatlas audit-findings</code>
  </p>
</BaseLayout>
