---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CurveGallery from "../../components/CurveGallery.svelte";
import MiniFindingsChart from "../../components/MiniFindingsChart.svelte";
import Card from "../../components/ui/Card.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Section from "../../components/ui/Section.astro";
import Stat from "../../components/ui/Stat.astro";
import StatGrid from "../../components/ui/StatGrid.astro";
import StatusPill from "../../components/ui/StatusPill.astro";
import {
  catalog,
  models,
  papers,
  slugForId,
  type PaperEntry,
} from "../../lib/data";
import { findings as findingsIndex, type FindingsEntry } from "../../lib/findings";

type Selection = {
  finding_id: string;
  best_variant_id: string;
  confidence_label?: string;
  delta_aic_to_next: number | null;
  n_candidate_fits: number;
  best_caveat_tags?: string[];
  candidate_caveat_tags?: string[];
};

type PaperCoverageRow = {
  paper: PaperEntry;
  findings: FindingsEntry[];
  selections: Selection[];
  protocolNames: string[];
  sourceLevels: string[];
  curveTypes: string[];
  species: string[];
  hasSlice: boolean;
  findingCount: number;
  modelCount: number;
};

const FAMILY_ID = "family.visual-2afc-contrast";
const familyProtocols = catalog.protocols
  .filter((protocol) => protocol.family_id === FAMILY_ID)
  .sort((a, b) => a.name.localeCompare(b.name));
const protocolIds = new Set(familyProtocols.map((protocol) => protocol.protocol_id));
const visualFindings = (findingsIndex.findings as FindingsEntry[])
  .filter((entry) => entry.family_id === FAMILY_ID)
  .sort((a, b) => {
    const paper = a.paper_year - b.paper_year;
    if (paper !== 0) return paper;
    return a.finding_id.localeCompare(b.finding_id);
  });

const selections =
  ((models as unknown as { model_selection_by_finding?: Selection[] })
    .model_selection_by_finding ?? []) as Selection[];
const selectionByFinding = new Map(
  selections.map((selection) => [selection.finding_id, selection]),
);

const paperRows: PaperCoverageRow[] = (papers.papers as PaperEntry[])
  .filter((paper) => (paper.protocol_ids ?? []).some((id) => protocolIds.has(id)))
  .sort((a, b) => a.year - b.year || a.citation.localeCompare(b.citation))
  .map((paper) => {
    const findingsForPaper = visualFindings.filter((finding) => finding.paper_id === paper.id);
    const selectionsForPaper = findingsForPaper
      .map((finding) => selectionByFinding.get(finding.finding_id))
      .filter((selection): selection is Selection => selection !== undefined);
    return {
      paper,
      findings: findingsForPaper,
      selections: selectionsForPaper,
      protocolNames: (paper.protocols ?? [])
        .map((protocol) => protocol.name ?? protocol.protocol_id ?? "")
        .filter(Boolean),
      sourceLevels: paper.source_data_levels ?? [],
      curveTypes: paper.curve_types ?? [],
      species: paper.species ?? [],
      hasSlice: (paper.vertical_slices ?? []).length > 0,
      findingCount: findingsForPaper.length,
      modelCount: selectionsForPaper.length,
    };
  });

const years = paperRows.map((row) => row.paper.year);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const yearSpan = Math.max(1, maxYear - minYear);
const protocolsWithReports = familyProtocols.filter((protocol) => protocol.report_status === "available");
const papersWithFindings = paperRows.filter((row) => row.findingCount > 0);
const papersWithModels = paperRows.filter((row) => row.modelCount > 0);
const totalTrials = visualFindings.reduce(
  (sum, entry) => sum + (typeof entry.n_trials === "number" ? entry.n_trials : 0),
  0,
);
const confidenceCounts = new Map<string, number>();
for (const row of paperRows) {
  for (const selection of row.selections) {
    const key = selection.confidence_label ?? "unlabelled";
    confidenceCounts.set(key, (confidenceCounts.get(key) ?? 0) + 1);
  }
}

function shortCitation(citation: string): string {
  return citation.trim().split(".")[0] ?? citation.trim();
}

function readable(value: string | null | undefined): string {
  if (!value) return "-";
  if (value === "non-human-primate") return "NHP";
  if (value === "processed-trial") return "processed trials";
  if (value === "raw-trial") return "raw trials";
  if (value === "figure-source-data") return "figure source data";
  return value.replace(/[_-]/g, " ");
}

function statusLabel(value: string): string {
  if (value === "findings") return "findings";
  if (value === "analysis-linked") return "analysis";
  if (value === "data-linked") return "data";
  if (value === "protocol-linked") return "protocol";
  return readable(value);
}

function sourceClass(level: string): string {
  if (level === "raw-trial") return "bg-encoding-source-raw text-white";
  if (level === "processed-trial") return "bg-encoding-source-processed text-white";
  if (level === "figure-source-data") return "bg-encoding-source-figure text-white";
  return "bg-surface-sunken text-fg-secondary";
}

function confidenceClass(label: string): string {
  if (label === "decisive") return "bg-confidence-decisive";
  if (label === "supported") return "bg-confidence-supported";
  if (label === "close") return "bg-confidence-close";
  return "bg-confidence-single";
}

function coverageWidth(value: number, max: number): string {
  if (max <= 0 || value <= 0) return "0%";
  return `${Math.max(8, Math.round((value / max) * 100))}%`;
}

const maxFindingCount = Math.max(1, ...paperRows.map((row) => row.findingCount));
const maxModelCount = Math.max(1, ...paperRows.map((row) => row.modelCount));
const timelineWidth = 860;
const timelineHeight = 170;
const timelineLeft = 48;
const timelineRight = timelineWidth - 36;
const timelineY = 78;

function xForYear(year: number): number {
  return timelineLeft + ((year - minYear) / yearSpan) * (timelineRight - timelineLeft);
}

const topModelVariants = Array.from(
  paperRows
    .flatMap((row) => row.selections)
    .reduce((counts, selection) => {
      const variant = selection.best_variant_id.replace("model_variant.", "");
      counts.set(variant, (counts.get(variant) ?? 0) + 1);
      return counts;
    }, new Map<string, number>()),
)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 5);
---

<BaseLayout
  title="Visual contrast family map · behavtaskatlas"
  description="A visual overview of the atlas's visual contrast discrimination family: notable papers, protocols, coverage, findings, source depth, and model-selection ambiguity."
  width="wide"
>
  <Breadcrumbs
    crumbs={[
      { label: "Stories", href: "/stories" },
      { label: "Visual contrast family map" },
    ]}
  />

  <PageHeader
    eyebrow="Story · task-family map"
    title="Visual contrast discrimination"
    lede="A visual scan of the atlas's deepest task family: which papers have source-backed findings, which protocols have reproducible slices, where model fits exist, and where the family is still only protocol-level coverage."
  />

  <StatGrid cols={4} class="mb-10">
    <Stat
      label="Protocols"
      value={familyProtocols.length}
      hint={`${protocolsWithReports.length} with reports`}
    />
    <Stat
      label="Notable papers"
      value={paperRows.length}
      hint={`${papersWithFindings.length} finding-backed`}
    />
    <Stat
      label="Findings"
      value={visualFindings.length}
      hint={`${totalTrials.toLocaleString()} trials`}
    />
    <Stat
      label="Modeled papers"
      value={papersWithModels.length}
      hint={`${confidenceCounts.get("close") ?? 0} close calls`}
    />
  </StatGrid>

  <Section
    spacing="lg"
    title="Paper Timeline"
    description="Filled markers have extracted findings; marker size follows finding count."
  >
    <Fragment slot="action">
      <a class="text-body text-accent" href="/papers?q=visual">Browse papers</a>
    </Fragment>

    <div class="-mx-4 overflow-x-auto px-4">
      <svg
        class="min-w-[760px] rounded-md border border-rule bg-surface-raised"
        viewBox={`0 0 ${timelineWidth} ${timelineHeight}`}
        role="img"
        aria-label="Timeline of visual contrast papers in the atlas"
      >
        <line
          x1={timelineLeft}
          x2={timelineRight}
          y1={timelineY}
          y2={timelineY}
          stroke="#cbd5e1"
          stroke-width="2"
        />
        {[minYear, maxYear].map((year) => (
          <g>
            <line
              x1={xForYear(year)}
              x2={xForYear(year)}
              y1={timelineY - 8}
              y2={timelineY + 8}
              stroke="#94a3b8"
            />
            <text
              x={xForYear(year)}
              y={timelineY + 28}
              text-anchor="middle"
              font-size="12"
              fill="#475569"
            >
              {year}
            </text>
          </g>
        ))}
        {paperRows.map((row, index) => {
          const x = xForYear(row.paper.year);
          const y = timelineY + (index % 2 === 0 ? -28 : 28);
          const radius = 5 + Math.min(12, row.findingCount * 0.45);
          const stroke = row.findingCount > 0 ? "#2b5ea0" : "#94a3b8";
          const fill = row.findingCount > 0 ? "#2b5ea0" : "#fff";
          return (
            <g>
              <line x1={x} x2={x} y1={timelineY} y2={y} stroke="#e2e8f0" />
              <circle
                cx={x}
                cy={y}
                r={radius}
                fill={fill}
                stroke={stroke}
                stroke-width="2"
              >
                <title>
                  {shortCitation(row.paper.citation)} · {row.findingCount} findings ·{" "}
                  {row.paper.coverage_status}
                </title>
              </circle>
              <text
                x={x}
                y={y + (index % 2 === 0 ? -16 : 24)}
                text-anchor="middle"
                font-size="11"
                fill="#334155"
              >
                {row.paper.year}
              </text>
            </g>
          );
        })}
      </svg>
    </div>
  </Section>

  <Section
    spacing="lg"
    title="Coverage Matrix"
    description="Each row is a paper linked to a visual-contrast protocol. Bars show how much finding/model coverage exists; chips show operational and source-data coverage."
  >
    <div class="-mx-4 overflow-x-auto px-4">
      <table class="min-w-[900px] w-full overflow-hidden rounded-md border border-rule bg-surface-raised text-body">
        <thead class="bg-surface text-left text-body-xs uppercase tracking-wide text-fg-muted">
          <tr>
            <th class="px-3 py-2">Paper</th>
            <th class="px-3 py-2">Protocol</th>
            <th class="px-3 py-2">Species</th>
            <th class="px-3 py-2">Source</th>
            <th class="px-3 py-2">Curves</th>
            <th class="px-3 py-2">Findings</th>
            <th class="px-3 py-2">Models</th>
            <th class="px-3 py-2">Slice</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-rule">
          {paperRows.map((row) => (
            <tr>
              <td class="px-3 py-2">
                <a class="font-medium text-fg no-underline hover:text-accent" href={`/papers/${row.paper.slug}`}>
                  {shortCitation(row.paper.citation)}
                </a>
                <p class="mt-0.5 text-mono-id text-fg-muted">
                  {row.paper.year} · {statusLabel(row.paper.coverage_status)}
                </p>
              </td>
              <td class="max-w-52 px-3 py-2 text-body-xs text-fg-secondary">
                {row.protocolNames.length > 0 ? row.protocolNames.join(" · ") : "-"}
              </td>
              <td class="px-3 py-2">
                <ul class="flex flex-wrap gap-1">
                  {row.species.map((value) => (
                    <li class="rounded bg-surface-sunken px-2 py-0.5 text-mono-id text-fg-secondary">
                      {readable(value)}
                    </li>
                  ))}
                </ul>
              </td>
              <td class="px-3 py-2">
                {row.sourceLevels.length === 0 ? (
                  <StatusPill tone="neutral">not linked</StatusPill>
                ) : (
                  <ul class="flex flex-wrap gap-1">
                    {row.sourceLevels.map((level) => (
                      <li class={`rounded px-2 py-0.5 text-mono-id ${sourceClass(level)}`}>
                        {readable(level)}
                      </li>
                    ))}
                  </ul>
                )}
              </td>
              <td class="px-3 py-2">
                {row.curveTypes.length === 0 ? (
                  <span class="text-body-xs text-fg-subtle">-</span>
                ) : (
                  <ul class="flex flex-wrap gap-1">
                    {row.curveTypes.map((curve) => (
                      <li class="rounded bg-accent-soft px-2 py-0.5 text-mono-id text-accent">
                        {readable(curve)}
                      </li>
                    ))}
                  </ul>
                )}
              </td>
              <td class="px-3 py-2">
                <div class="h-2 w-24 rounded bg-surface-sunken">
                  <div
                    class="h-2 rounded bg-accent"
                    style={`width: ${coverageWidth(row.findingCount, maxFindingCount)}`}
                  ></div>
                </div>
                <p class="mt-1 font-mono text-mono-id text-fg-secondary">{row.findingCount}</p>
              </td>
              <td class="px-3 py-2">
                <div class="h-2 w-24 rounded bg-surface-sunken">
                  <div
                    class="h-2 rounded bg-ok"
                    style={`width: ${coverageWidth(row.modelCount, maxModelCount)}`}
                  ></div>
                </div>
                <p class="mt-1 font-mono text-mono-id text-fg-secondary">{row.modelCount}</p>
              </td>
              <td class="px-3 py-2">
                <StatusPill tone={row.hasSlice ? "ok" : "neutral"}>
                  {row.hasSlice ? "report" : "none"}
                </StatusPill>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <Section
    spacing="lg"
    title="Curve Scan"
    description="Pooled or per-condition traces first; subject-level curves remain one click away."
  >
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-[minmax(0,1.25fr)_minmax(18rem,0.75fr)]">
      <MiniFindingsChart
        client:visible
        findings={visualFindings}
        colorBy="paper"
        height={300}
        showFits={true}
      />

      <aside class="space-y-4">
        <Card padding="md">
          <h3 class="text-h3 text-fg">Model Confidence</h3>
          <ul class="mt-3 space-y-2">
            {["decisive", "supported", "close", "unlabelled"].map((label) => {
              const count = confidenceCounts.get(label) ?? 0;
              return count > 0 ? (
                <li class="flex items-center gap-2">
                  <span class={`h-2.5 w-2.5 rounded-full ${confidenceClass(label)}`}></span>
                  <span class="text-body-xs text-fg-secondary">{readable(label)}</span>
                  <span class="ml-auto font-mono text-body-xs text-fg-muted">{count}</span>
                </li>
              ) : null;
            })}
          </ul>
        </Card>

        <Card padding="md">
          <h3 class="text-h3 text-fg">Top Winners</h3>
          <ul class="mt-3 space-y-2">
            {topModelVariants.map(([variant, count]) => (
              <li>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-body-xs text-fg-secondary">{readable(variant)}</span>
                  <span class="font-mono text-body-xs text-fg-muted">{count}</span>
                </div>
                <div class="mt-1 h-1.5 rounded bg-surface-sunken">
                  <div
                    class="h-1.5 rounded bg-accent"
                    style={`width: ${coverageWidth(count, topModelVariants[0]?.[1] ?? 1)}`}
                  ></div>
                </div>
              </li>
            ))}
          </ul>
          <a class="mt-3 inline-block text-body-xs font-semibold text-accent" href="/models?model_family=Visual+contrast+discrimination">
            Model answers
          </a>
        </Card>
      </aside>
    </div>
  </Section>

  <Section
    spacing="lg"
    title="Small-Multiple Gallery"
    description="Paper- and protocol-level panels expose condition shifts, subject variation, source depth, and fit overlays without collapsing the family into one dense plot."
  >
    <CurveGallery client:visible findings={visualFindings} defaultCurveType="psychometric" />
  </Section>

  <Section
    spacing="lg"
    title="Protocol Footprint"
    description="Protocol variants preserve response modality and context differences instead of treating all contrast tasks as interchangeable."
  >
    <ul class="grid grid-cols-1 gap-3 md:grid-cols-2">
      {familyProtocols.map((protocol) => (
        <li>
          <Card padding="md">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-h3 text-fg">
                  <a class="no-underline hover:text-accent" href={`/protocols/${slugForId(protocol.protocol_id)}`}>
                    {protocol.name}
                  </a>
                </h3>
                <p class="mt-1 text-body-xs text-fg-muted">
                  {protocol.species.map(readable).join(", ")} · {readable(protocol.choice_type)} ·{" "}
                  {(protocol.response_modalities ?? []).map(readable).join(", ")}
                </p>
              </div>
              <StatusPill tone={protocol.report_status === "available" ? "ok" : "neutral"}>
                {protocol.report_status === "available" ? "report" : "no report"}
              </StatusPill>
            </div>
            <div class="mt-3 grid grid-cols-3 gap-2 text-center text-body-xs">
              <div>
                <p class="font-mono text-fg">{(protocol.dataset_ids ?? []).length}</p>
                <p class="text-mono-id text-fg-muted">datasets</p>
              </div>
              <div>
                <p class="font-mono text-fg">{(protocol.slice_ids ?? []).length}</p>
                <p class="text-mono-id text-fg-muted">slices</p>
              </div>
              <div>
                <p class="font-mono text-fg">
                  {visualFindings.filter((finding) => finding.protocol_id === protocol.protocol_id).length}
                </p>
                <p class="text-mono-id text-fg-muted">findings</p>
              </div>
            </div>
          </Card>
        </li>
      ))}
    </ul>
  </Section>

  <Card padding="md">
    <h2 class="text-h3 text-fg">Reading The Map</h2>
    <p class="mt-2 text-body text-fg-secondary">
      Dense rows are not automatically better science: they mean the atlas has
      extracted more operational evidence. Sparse rows identify protocol-linked
      papers where source access or extraction is still the limiting factor.
      The page deliberately keeps source depth, curve type, and model confidence
      as separate visual channels.
    </p>
  </Card>
</BaseLayout>
