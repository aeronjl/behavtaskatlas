---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MiniFindingsChart from "../../components/MiniFindingsChart.svelte";
import DdmParamScatter from "../../components/DdmParamScatter.svelte";
import Card from "../../components/ui/Card.astro";
import DataTable from "../../components/ui/DataTable.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Section from "../../components/ui/Section.astro";
import Stat from "../../components/ui/Stat.astro";
import StatGrid from "../../components/ui/StatGrid.astro";
import { catalog, hrefForFinding, models, slugForId } from "../../lib/data";
import { findings as findingsIndex, type FindingsEntry } from "../../lib/findings";

type Variant = { id: string; family_id: string; name: string };
type Fit = {
  id: string;
  variant_id: string;
  finding_ids: string[];
  parameters: Record<string, number>;
  quality: Record<string, number>;
  caveat_tags?: string[];
};
type Selection = {
  finding_id: string;
  best_fit_id: string;
  best_variant_id: string;
  best_aic: number | null;
  delta_aic_to_next: number | null;
  n_candidate_fits: number;
  best_caveat_tags?: string[];
};

const RDM_PROTOCOL_IDS = new Set([
  "protocol.random-dot-motion-classic-macaque",
  "protocol.human-rdm-button-reaction-time",
  "protocol.macaque-rdm-confidence-wager",
]);

const allFindings = (findingsIndex.findings ?? []) as FindingsEntry[];
const rdmFindings = allFindings.filter((entry) =>
  RDM_PROTOCOL_IDS.has(entry.protocol_id),
);
const rdmPsychometric = rdmFindings.filter((entry) =>
  ["psychometric", "accuracy_by_strength"].includes(entry.curve_type),
);
const rdmChronometric = rdmFindings.filter(
  (entry) => entry.curve_type === "chronometric",
);

const variants = (models.variants ?? []) as unknown as Variant[];
const fits = (models.fits ?? []) as unknown as Fit[];
const ddmVariantIds = new Set(
  variants
    .filter((variant) => variant.family_id === "model_family.drift-diffusion")
    .map((variant) => variant.id),
);
const findingsById = new Map(rdmFindings.map((entry) => [entry.finding_id, entry]));

const ddmRows = fits
  .filter((fit) => ddmVariantIds.has(fit.variant_id))
  .map((fit) => {
    const psychometricId =
      fit.finding_ids.find((id) => findingsById.get(id)?.curve_type === "psychometric") ??
      fit.finding_ids.find((id) => findingsById.has(id));
    const entry = psychometricId ? findingsById.get(psychometricId) ?? null : null;
    if (!entry) return null;
    return {
      fit_id: fit.id,
      variant: fit.variant_id.replace("model_variant.", ""),
      paper_id: entry.paper_id,
      paper_label: entry.paper_citation.split(".")[0] ?? entry.paper_id,
      species: entry.species ?? "unknown",
      subject_id: entry.stratification?.subject_id ?? null,
      condition: entry.stratification?.condition ?? null,
      drift_per_unit_evidence: fit.parameters.drift_per_unit_evidence ?? NaN,
      boundary: fit.parameters.boundary ?? NaN,
      non_decision_time: fit.parameters.non_decision_time ?? NaN,
      starting_point: fit.parameters.starting_point ?? null,
      drift_bias: fit.parameters.drift_bias ?? null,
      aic: fit.quality?.aic ?? null,
    };
  })
  .filter((row): row is NonNullable<typeof row> => row !== null);

const selections =
  ((models as unknown as { model_selection_by_finding?: Selection[] })
    .model_selection_by_finding ?? []) as Selection[];
const selectionByFinding = new Map(
  selections.map((selection) => [selection.finding_id, selection]),
);
const rdmSelectionRows = rdmPsychometric
  .map((entry) => {
    const selection = selectionByFinding.get(entry.finding_id);
    if (!selection) return null;
    return { entry, selection };
  })
  .filter((row): row is NonNullable<typeof row> => row !== null)
  .sort((a, b) => {
    const paper = a.entry.paper_citation.localeCompare(b.entry.paper_citation);
    if (paper !== 0) return paper;
    return a.entry.finding_id.localeCompare(b.entry.finding_id);
  });

const rdmSlices = (catalog.vertical_slices ?? []).filter((slice) =>
  RDM_PROTOCOL_IDS.has(slice.protocol_id),
);

const species = Array.from(
  new Set(rdmFindings.map((entry) => entry.species ?? "unknown")),
).sort();

function fmt(value: number | null | undefined, digits = 1): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "-";
  return value.toFixed(digits);
}

function stratificationLabel(entry: FindingsEntry): string {
  return (
    entry.stratification?.subject_id ??
    entry.stratification?.condition ??
    "pooled"
  );
}

function tagLabel(tag: string): string {
  const defs =
    (models as unknown as {
      caveat_tag_definitions?: Record<string, { label: string }>;
    }).caveat_tag_definitions ?? {};
  return defs[tag]?.label ?? tag.replace(/_/g, " ");
}
---

<BaseLayout
  title="RDM cross-species story · behavtaskatlas"
  description="Cross-species random-dot motion synthesis with macaque and human psychometric findings, DDM fits, provenance caveats, and model-selection winners."
  width="wide"
>
  <PageHeader
    eyebrow="Story · random-dot motion"
    title="Cross-species RDM model story"
    lede="The atlas now links classic macaque RDM, human reaction-time RDM, and macaque confidence/wagering RDM in one model layer. The view below keeps operational variables separate from interpretation: choice curves, chronometric summaries, DDM parameters, and proxy caveats are shown as distinct evidence."
  />

  <StatGrid cols={5} class="mb-10">
    <Stat label="Species" value={species.length} />
    <Stat label="Slices" value={rdmSlices.length} />
    <Stat label="Choice findings" value={rdmPsychometric.length} />
    <Stat label="Chronometric" value={rdmChronometric.length} />
    <Stat label="DDM fits" value={ddmRows.length} />
  </StatGrid>

  <Section spacing="md" title="Curves and fitted overlays">
    <MiniFindingsChart
      client:visible
      findings={rdmFindings}
      colorBy="paper"
      height={320}
    />
  </Section>

  {ddmRows.length > 0 ? (
    <Section spacing="md" title="DDM parameter spread">
      <Card padding="md">
        <DdmParamScatter client:visible fits={ddmRows} height={300} />
      </Card>
    </Section>
  ) : null}

  <Section spacing="md" title="RDM model-selection winners">
    <DataTable
      columns={[
        { label: "Finding" },
        { label: "Paper" },
        { label: "Species" },
        { label: "Subject / condition" },
        { label: "Winner" },
        { label: "AIC", align: "right" },
        { label: "Delta", align: "right" },
        { label: "Caveats" },
      ]}
    >
      {rdmSelectionRows.map(({ entry, selection }) => (
            <tr>
              <td class="max-w-72 px-3 py-2 font-mono text-mono-id">
                <a href={hrefForFinding(entry.finding_id)}>
                  {entry.finding_id.replace("finding.", "")}
                </a>
              </td>
              <td class="px-3 py-2 text-body-xs">
                <a
                  class="text-fg hover:text-accent"
                  href={`/papers/${slugForId(entry.paper_id)}`}
                >
                  {entry.paper_citation.split(".")[0]}
                </a>
              </td>
              <td class="px-3 py-2 text-body-xs text-fg-secondary">
                {entry.species ?? "unknown"}
              </td>
              <td class="px-3 py-2 text-body-xs text-fg-secondary">
                {stratificationLabel(entry)}
              </td>
              <td class="px-3 py-2 font-mono text-mono-id">
                {selection.best_variant_id.replace("model_variant.", "")}
              </td>
              <td class="px-3 py-2 text-right font-mono">
                {fmt(selection.best_aic)}
              </td>
              <td class="px-3 py-2 text-right font-mono">
                {fmt(selection.delta_aic_to_next)}
              </td>
              <td class="px-3 py-2">
                {(selection.best_caveat_tags ?? []).length === 0 ? (
                  <span class="text-body-xs text-fg-muted">—</span>
                ) : (
                  <ul class="flex flex-wrap gap-1">
                    {(selection.best_caveat_tags ?? []).map((tag) => (
                      <li class="rounded bg-warn-soft px-2 py-0.5 text-mono-id text-warn">
                        {tagLabel(tag)}
                      </li>
                    ))}
                  </ul>
                )}
              </td>
            </tr>
      ))}
    </DataTable>
  </Section>

  <Section spacing="md" title="Source slices">
    <DataTable
      columns={[
        { label: "Slice" },
        { label: "Protocol" },
        { label: "Species" },
        { label: "Source level" },
        { label: "Report" },
      ]}
    >
      {rdmSlices.map((slice) => (
            <tr>
              <td class="px-3 py-2">
                <a
                  class="font-mono text-body-xs text-fg hover:text-accent"
                  href={`/slices/${slugForId(slice.slice_id)}`}
                >
                  {slice.slice_id}
                </a>
              </td>
              <td class="px-3 py-2 font-mono text-mono-id text-fg-secondary">
                {slice.protocol_id}
              </td>
              <td class="px-3 py-2 text-body-xs text-fg-secondary">{slice.species}</td>
              <td class="px-3 py-2 text-body-xs text-fg-secondary">
                {slice.source_data_level}
              </td>
              <td class="px-3 py-2 text-body-xs text-fg-secondary">
                {slice.report_status}
              </td>
            </tr>
      ))}
    </DataTable>
  </Section>
</BaseLayout>
