---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import MiniFindingsChart from "../../components/MiniFindingsChart.svelte";
import Term from "../../components/Term.astro";
import Card from "../../components/ui/Card.astro";
import DataTable from "../../components/ui/DataTable.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Section from "../../components/ui/Section.astro";
import {
  comparisons,
  findings as findingsIndex,
  type ComparisonEntry,
  type FindingsEntry,
} from "../../lib/findings";
import { hrefForFinding } from "../../lib/data";

type FitFields = {
  mu: number;
  sigma: number;
  gamma: number;
  lapse: number;
  threshold?: number;
  threshold_target_y: number;
};

const allFindings = findingsIndex.findings as FindingsEntry[];
const findingById = new Map(allFindings.map((f) => [f.finding_id, f]));

function findComparison(id: string): ComparisonEntry | undefined {
  return comparisons.comparisons.find((c) => c.id === id);
}

const mouse = findComparison("comparison.ibl-prior-blocks");
const human = findComparison("comparison.walsh-prior-cue");

function entriesFor(spec: ComparisonEntry | undefined): FindingsEntry[] {
  if (!spec) return [];
  return spec.finding_ids
    .map((id) => findingById.get(id))
    .filter((e): e is FindingsEntry => e !== undefined);
}

const mouseEntries = entriesFor(mouse);
const humanEntries = entriesFor(human);

function fitOf(entry: FindingsEntry): FitFields | null {
  return (entry as FindingsEntry & { fit?: FitFields | null }).fit ?? null;
}

type DeltaRow = {
  finding_id: string;
  paper_id: string;
  label: string;
  reference: boolean;
  n_trials: number | null;
  mu: number | null;
  sigma: number | null;
  delta_mu: number | null;
  delta_sigma: number | null;
};

function deltasFor(entries: FindingsEntry[], referenceLabel: string | null): DeltaRow[] {
  if (entries.length === 0) return [];
  const refIdx =
    referenceLabel !== null
      ? entries.findIndex(
          (e) =>
            (e.stratification?.condition ?? "")
              .toLowerCase()
              .includes(referenceLabel.toLowerCase()),
        )
      : 0;
  const reference = refIdx >= 0 ? entries[refIdx] : entries[0];
  const refFit = fitOf(reference);
  return entries.map((entry) => {
    const fit = fitOf(entry);
    const isRef = entry.finding_id === reference.finding_id;
    return {
      finding_id: entry.finding_id,
      paper_id: entry.paper_id,
      label:
        entry.stratification?.condition ??
        entry.stratification?.subject_id ??
        "pooled",
      reference: isRef,
      n_trials: typeof entry.n_trials === "number" ? entry.n_trials : null,
      mu: fit?.mu ?? null,
      sigma: fit?.sigma ?? null,
      delta_mu:
        !isRef && fit && refFit && Number.isFinite(fit.mu) && Number.isFinite(refFit.mu)
          ? fit.mu - refFit.mu
          : isRef
          ? 0
          : null,
      delta_sigma:
        !isRef && fit && refFit && Number.isFinite(fit.sigma) && Number.isFinite(refFit.sigma)
          ? fit.sigma - refFit.sigma
          : isRef
          ? 0
          : null,
    };
  });
}

const mouseDeltas = deltasFor(mouseEntries, "0.5");
const humanDeltas = deltasFor(humanEntries, "neutral");

function fmt(value: number | null | undefined, digits = 2): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "—";
  return value.toFixed(digits);
}

function absMax(values: (number | null | undefined)[]): number | null {
  let max: number | null = null;
  for (const v of values) {
    if (v === null || v === undefined || !Number.isFinite(v)) continue;
    const abs = Math.abs(v);
    if (max === null || abs > max) max = abs;
  }
  return max;
}

const mouseMaxDeltaMu = absMax(mouseDeltas.filter((r) => !r.reference).map((r) => r.delta_mu));
const mouseMaxDeltaSigma = absMax(mouseDeltas.filter((r) => !r.reference).map((r) => r.delta_sigma));
const humanMaxDeltaMu = absMax(humanDeltas.filter((r) => !r.reference).map((r) => r.delta_mu));
const humanMaxDeltaSigma = absMax(humanDeltas.filter((r) => !r.reference).map((r) => r.delta_sigma));

function ratio(a: number | null, b: number | null): string {
  if (a === null || b === null) return "—";
  if (b === 0) return "∞";
  return (a / b).toFixed(2);
}

const cases = [
  {
    id: "mouse",
    species: "Mouse",
    paper: "IBL 2021",
    paperId: "paper.ibl-2021-standardized",
    description:
      "trainingChoiceWorld biased blocks, p(left) ∈ {0.2, 0.5, 0.8}, the prior is set per block (~90 trials each).",
    referenceLabel: "the unbiased 0.5 block",
    entries: mouseEntries,
    deltas: mouseDeltas,
    maxDeltaMu: mouseMaxDeltaMu,
    maxDeltaSigma: mouseMaxDeltaSigma,
    comparisonId: mouse?.id,
  },
  {
    id: "human",
    species: "Human",
    paper: "Walsh 2024",
    paperId: "paper.walsh-2024-prior-cue",
    description:
      "Trial-by-trial cue (valid / neutral / invalid) of the upcoming target side. Cue is delivered at trial onset, ~75% predictive when valid.",
    referenceLabel: "the neutral cue",
    entries: humanEntries,
    deltas: humanDeltas,
    maxDeltaMu: humanMaxDeltaMu,
    maxDeltaSigma: humanMaxDeltaSigma,
    comparisonId: human?.id,
  },
];

const haveData = mouseEntries.length > 0 && humanEntries.length > 0;
---

<BaseLayout
  title="Prior conditioning shifts the psychometric · behavtaskatlas"
  description="Cross-species story: do prior probabilities shift only the bias (μ) of the psychometric, or do they also change the slope (σ)? Mouse blocks (IBL) and human trial-cues (Walsh) tested side by side."
  width="content"
>
  <Breadcrumbs
    crumbs={[
      { label: "Stories", href: "/stories" },
      { label: "Prior conditioning" },
    ]}
  />

  <PageHeader
    eyebrow="Story"
    title="Prior conditioning shifts the psychometric, not the slope"
  >
    <Fragment slot="lede">
      A textbook prediction in perceptual decision-making: telling a subject
      that one option is more likely should bias them toward it (
      <Term define="psychometric bias — the x-value where P(right) = 50%, in stimulus units">μ</Term>
      moves) without changing their underlying sensitivity to the stimulus
      (
      <Term define="psychometric slope width — larger σ means a shallower curve, i.e. lower discriminability">σ</Term>
      stays put). Two papers in the atlas test exactly this — once in mice
      via block-level prior schedules, once in humans via trial-by-trial
      cues. They use different mechanics, but they make the same
      prediction. The atlas's canonical psychometric axis lets us read
      both off side by side.
    </Fragment>
  </PageHeader>

  {!haveData ? (
    <Card padding="md" surface="warn" border="tinted" class="text-body text-warn">
      One or both source comparisons (<code>comparison.ibl-prior-blocks</code>,
      {" "}<code>comparison.walsh-prior-cue</code>) are not present in the
      current build. Re-run <code>behavtaskatlas site-index</code> after
      adding the IBL and Walsh slices.
    </Card>
  ) : null}

  {cases.map((c) => (
    <Section
      id={c.id}
      spacing="lg"
      eyebrow={c.species}
      title={c.paper}
      description={`${c.description} The reference here is ${c.referenceLabel}; deltas report the bias and slope change relative to it.`}
    >
      {c.entries.length > 0 ? (
        <Card padding="md">
          <MiniFindingsChart
            client:visible
            findings={c.entries}
            colorBy="condition"
            height={260}
          />
        </Card>
      ) : null}

      {c.deltas.length > 0 ? (
        <div class="mt-4 grid grid-cols-1 gap-3 lg:grid-cols-[1.4fr_1fr]">
          <DataTable
            density="compact"
            columns={[
              { label: "Condition" },
              { label: "n", align: "right", title: "Trial count for this condition" },
              { label: "μ (bias)", align: "right" },
              { label: "σ (slope)", align: "right" },
              { label: "Δμ", align: "right" },
              { label: "Δσ", align: "right" },
            ]}
          >
            {c.deltas.map((row) => (
              <tr class={row.reference ? "bg-surface" : ""}>
                <td class="px-3 py-2">
                  <a
                    class="font-mono text-mono-id"
                    href={hrefForFinding(row.finding_id)}
                  >
                    {row.label}
                  </a>
                  {row.reference ? (
                    <span class="ml-2 text-mono-id text-fg-muted">(reference)</span>
                  ) : null}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {row.n_trials !== null ? row.n_trials.toLocaleString() : "—"}
                </td>
                <td class="px-3 py-2 text-right font-mono">{fmt(row.mu)}</td>
                <td class="px-3 py-2 text-right font-mono">{fmt(row.sigma)}</td>
                <td class="px-3 py-2 text-right font-mono">
                  {row.reference ? "—" : fmt(row.delta_mu)}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {row.reference ? "—" : fmt(row.delta_sigma)}
                </td>
              </tr>
            ))}
          </DataTable>
          <Card as="aside" padding="md" class="text-body">
            <h3 class="text-eyebrow uppercase text-fg-muted">Effect size</h3>
            <dl class="mt-2 space-y-2">
              <div>
                <dt class="text-body-xs text-fg-muted">max |Δμ|</dt>
                <dd class="mt-0.5 font-mono text-body-lg">{fmt(c.maxDeltaMu)}</dd>
              </div>
              <div>
                <dt class="text-body-xs text-fg-muted">max |Δσ|</dt>
                <dd class="mt-0.5 font-mono text-body-lg">{fmt(c.maxDeltaSigma)}</dd>
              </div>
              <div>
                <dt class="text-body-xs text-fg-muted">|Δμ| / |Δσ|</dt>
                <dd class="mt-0.5 font-mono text-body-lg">
                  {ratio(c.maxDeltaMu, c.maxDeltaSigma)}
                </dd>
              </div>
            </dl>
            <p class="mt-3 text-body-xs text-fg-muted">
              The textbook bias-only prediction is large |Δμ|, ≈0 |Δσ|. The
              ratio quantifies it: ratios &gt; 1 mean μ moves more than σ.
            </p>
            {c.comparisonId ? (
              <p class="mt-3 text-body-xs">
                <a class="text-accent" href={`/compare#${c.comparisonId}`}>
                  See on /compare →
                </a>
              </p>
            ) : null}
          </Card>
        </div>
      ) : null}
    </Section>
  ))}

  {haveData ? (
    <Section spacing="lg" title="The takeaway">
      <p class="text-body-lg text-fg-secondary">
        Both species behave like the classical model predicts:
        <Term define="psychometric bias">μ</Term>
        moves substantially with the prior, and
        <Term define="psychometric slope">σ</Term>
        moves much less. The mouse biased-block effect is operationalised
        at the block timescale (priors persist for ~90 trials) and the
        human cue effect is operationalised at the trial timescale (cue
        resets every trial), but the canonical parameters land in the
        same place — <Term define="psychometric bias">μ</Term> shifts in
        the cued/biased direction,
        <Term define="psychometric slope">σ</Term>
        stays roughly fixed at each species' baseline.
      </p>
      <p class="mt-3 text-body-lg text-fg-secondary">
        The atlas's job here is to make this readable in one glance. The
        underlying findings are 4-parameter logistic fits run at build
        time on the harmonized canonical-trial CSVs from the IBL and
        Walsh slices; if you want to refit interactively, every curve is
        also available on{" "}
        <a class="text-accent" href="/findings?curve=psychometric&fit=1">
          /findings
        </a>
        {" "}with the in-browser scipy fitter enabled.
      </p>
    </Section>
  ) : null}

  <Section spacing="lg" title="Caveats">
    <ul class="list-disc space-y-2 pl-5 text-body text-fg-secondary">
      <li>
        IBL biased blocks and Walsh trial-cues operate at very different
        timescales. The atlas does not claim the underlying neural
        mechanism is the same — only that the behavioural read-out
        (psychometric μ vs σ) matches.
      </li>
      <li>
        Walsh's invalid-cue trials are rarer than valid; per-condition
        sample sizes differ. The slope estimate uncertainty is therefore
        not symmetric across conditions.
      </li>
      <li>
        Both fits use the
        <Term define="ψ(x) = γ + (1 − γ − λ) · sigmoid((x − μ) / σ); μ is bias, σ is slope, γ is lower asymptote, λ is upper lapse rate">
          4-parameter logistic
        </Term>
        with
        <Term define="lower asymptote — chance-rate or guessing baseline at very negative x">γ</Term>
        and
        <Term define="upper lapse rate — error rate at very positive x">λ</Term>
        free. Bias-only is the textbook expectation but not the only
        possibility; a slope change would show up as a non-zero
        <Term define="change in σ relative to the reference condition">Δσ</Term>.
      </li>
    </ul>
  </Section>
</BaseLayout>
