---
import BaseLayout from "../../layouts/BaseLayout.astro";

type Story = {
  href: string;
  title: string;
  lead: string;
  surface: string;
  speciesCount?: number;
  tags: string[];
};

const stories: Story[] = [
  {
    href: "/stories/rdm",
    title: "Cross-species random-dot motion",
    lead:
      "Classic macaque RDM, human reaction-time RDM, and macaque confidence-wagering RDM live on one canonical signed-coherence axis. DDM fits give a single drift parameter to read off across species — and the spread is bigger than you'd expect.",
    surface: "Psychometric + chronometric + DDM cross-species fits",
    speciesCount: 2,
    tags: ["random-dot motion", "DDM", "cross-species"],
  },
  {
    href: "/stories/prior-shifts",
    title: "Prior conditioning shifts the psychometric, not the slope",
    lead:
      "IBL biases mouse choice via three-block left-prior schedules; Walsh 2024 biases human choice with trial-by-trial valid/neutral/invalid cues. Both predict μ moves and σ stays put. The atlas measures both directly.",
    surface: "Psychometric μ vs σ across mouse blocks and human cues",
    speciesCount: 2,
    tags: ["prior conditioning", "psychometric", "cross-species"],
  },
];
---

<BaseLayout
  title="Stories · behavtaskatlas"
  description="Long-form synthesis pieces drawing across the atlas's findings, fits, and slices."
>
  <header class="mb-10">
    <h1 class="text-3xl">Stories</h1>
    <p class="mt-3 max-w-3xl text-base text-slate-700">
      Curated long-form views that follow a question across the atlas — same
      canonical axes, multiple papers, both choice and process-level evidence
      where available. Each story embeds the relevant findings and fits so
      you can read the punchline without opening a paper.
    </p>
  </header>

  <ul class="grid grid-cols-1 gap-4">
    {stories.map((story) => (
      <li>
        <a
          href={story.href}
          class="group flex flex-col rounded-md border border-slate-200 bg-white p-5 no-underline transition-colors hover:border-accent"
        >
          <header class="mb-2 flex items-baseline justify-between gap-3">
            <h2 class="text-xl text-slate-900">{story.title}</h2>
            <span
              class="text-base text-slate-400 transition-colors group-hover:text-accent"
              aria-hidden="true"
            >→</span>
          </header>
          <p class="mb-3 text-sm text-slate-700">{story.lead}</p>
          <p class="text-xs text-slate-500">{story.surface}</p>
          <ul class="mt-3 flex flex-wrap gap-1">
            {story.tags.map((tag) => (
              <li class="rounded bg-slate-100 px-2 py-0.5 text-[11px] text-slate-600">
                {tag}
              </li>
            ))}
          </ul>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
