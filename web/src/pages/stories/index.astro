---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/ui/Card.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import { stories } from "../../lib/stories";

// Sort newest-first so the freshest piece anchors the grid.
const ordered = [...stories].sort((a, b) =>
  b.publishedAt.localeCompare(a.publishedAt),
);
---

<BaseLayout
  title="Stories · behavtaskatlas"
  description="Long-form synthesis pieces drawing across the atlas's findings, fits, and slices."
  width="content"
>
  <PageHeader
    title="Stories"
    lede="Curated long-form views that follow a question across the atlas — same canonical axes, multiple papers, both choice and process-level evidence where available. Each story embeds the relevant findings and fits so you can read the punchline without opening a paper."
  />

  <ul class="grid grid-cols-1 gap-5 md:grid-cols-2">
    {ordered.map((story) => (
      <li>
        <Card href={story.href} padding="none" class="overflow-hidden">
          <div class="aspect-[1200/630] w-full bg-surface-sunken">
            <img
              src={`/og/stories/${story.slug}.svg`}
              alt=""
              loading="lazy"
              decoding="async"
              class="block h-full w-full object-cover"
            />
          </div>
          <div class="p-5">
            <header class="mb-2 flex flex-wrap items-baseline justify-between gap-3">
              <p class="text-eyebrow uppercase text-fg-muted">
                {story.publishedAt} · {story.readMinutes} min read
              </p>
              <span
                class="text-body-lg text-fg-subtle transition-colors group-hover:text-accent"
                aria-hidden="true"
              >→</span>
            </header>
            <h2 class="text-h3 text-fg">{story.title}</h2>
            <p class="mt-2 text-body text-fg-secondary">{story.lead}</p>
            <p class="mt-3 text-body-xs text-fg-muted">{story.surface}</p>
            <ul class="mt-3 flex flex-wrap gap-1">
              {story.tags.map((tag) => (
                <li class="rounded bg-surface-sunken px-2 py-0.5 text-mono-id text-fg-secondary">
                  {tag}
                </li>
              ))}
            </ul>
          </div>
        </Card>
      </li>
    ))}
  </ul>
</BaseLayout>
