---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import MiniFindingsChart from "../../components/MiniFindingsChart.svelte";
import CitationDownloads from "../../components/CitationDownloads.astro";
import RecordChip from "../../components/RecordChip.astro";
import Card from "../../components/ui/Card.astro";
import DataTable from "../../components/ui/DataTable.astro";
import DetailLayout from "../../components/ui/DetailLayout.astro";
import DetailToc from "../../components/ui/DetailToc.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Section from "../../components/ui/Section.astro";
import StatusPill from "../../components/ui/StatusPill.astro";
import { findings } from "../../lib/findings";
import {
  hrefForFinding,
  slugForId,
  getPaper,
  papers,
  type PaperEntry,
} from "../../lib/data";

type Entry = (typeof findings.findings)[number];

const findingsByPaper = new Map<string, Entry[]>();
for (const entry of findings.findings as Entry[]) {
  if (!findingsByPaper.has(entry.paper_id)) findingsByPaper.set(entry.paper_id, []);
  findingsByPaper.get(entry.paper_id)!.push(entry);
}

export function getStaticPaths() {
  return (papers.papers as PaperEntry[]).map((paper) => ({
    params: { id: paper.slug },
    props: { paperId: paper.id },
  }));
}

interface Props {
  paperId: string;
}

const { paperId } = Astro.props as Props;
const paperEntries = findingsByPaper.get(paperId) ?? [];
const first = paperEntries[0];
const paperRecord = getPaper(paperId);
const paperTitle = paperRecord?.citation ?? first?.paper_citation ?? paperId;
const paperDoi = paperRecord?.doi ?? first?.paper_doi ?? null;
const paperFindingCount = paperRecord?.finding_count ?? paperEntries.length;
const paperDescription =
  paperFindingCount > 0
    ? `${paperFindingCount} standardized findings from ${paperTitle}`
    : `Curated paper record for ${paperTitle}`;

type FitSummary = {
  variant_id: string;
  parameters: Record<string, number>;
  quality: Record<string, number>;
};
function fitsOf(entry: Entry): FitSummary[] {
  return ((entry as unknown as { model_fits?: FitSummary[] }).model_fits ?? []) as FitSummary[];
}
function paramRow(params: Record<string, number>): string {
  return Object.entries(params)
    .map(([k, v]) => {
      const abs = Math.abs(v);
      const fmt = abs !== 0 && (abs < 0.01 || abs > 1000) ? v.toExponential(2) : v.toFixed(3);
      return `${k}=${fmt}`;
    })
    .join(" · ");
}
const protocolEntries = paperRecord
  ? paperRecord.protocols.map((protocol) => ({
      protocol_id: protocol.protocol_id,
      protocol_name: protocol.name,
    }))
  : Array.from(new Set(paperEntries.map((e) => e.protocol_id))).map((id) => ({
      protocol_id: id,
      protocol_name:
        paperEntries.find((e) => e.protocol_id === id)?.protocol_name ?? id,
    }));

const datasetEntries = paperRecord?.datasets ?? [];
const sliceEntries = paperRecord?.vertical_slices ?? [];
const coverageLabels: Record<string, string> = {
  findings: "Findings extracted",
  "analysis-linked": "Analysis linked",
  "data-linked": "Dataset linked",
  "protocol-linked": "Protocol curated",
  "bibliography-only": "Bibliography only",
};

function listText(values: readonly string[] | undefined): string {
  return values && values.length > 0 ? values.join(", ") : "—";
}

function coverageLabel(status: string | undefined): string {
  return status ? coverageLabels[status] ?? status : "—";
}

type TocItem = { id: string; label: string; count?: number };
const hasNotes = Boolean(paperRecord?.notes);
const hasFits = paperEntries.some((e) => fitsOf(e).length > 0);

const tocItems: TocItem[] = [
  hasNotes ? { id: "notes", label: "Notes" } : null,
  paperEntries.length > 0
    ? { id: "curves", label: "Curves on shared axes" }
    : null,
  { id: "findings", label: "Findings", count: paperEntries.length } as TocItem,
  hasFits ? { id: "fits", label: "Fit parameters" } : null,
].filter((item): item is TocItem => item !== null);

const coverageTone =
  paperRecord?.coverage_status === "findings"
    ? "ok"
    : paperRecord?.coverage_status === "analysis-linked" ||
      paperRecord?.coverage_status === "data-linked"
    ? "accent"
    : "neutral";
---

<BaseLayout
  title={`${paperTitle} · Paper`}
  description={paperDescription}
  width="wide"
>
  <Breadcrumbs
    crumbs={[
      { label: "Papers", href: "/papers" },
      { label: paperTitle },
    ]}
  />

  <DetailLayout>
    <Fragment slot="rail">
      <DetailToc items={tocItems} />
      <Card padding="md" class="text-body-xs">
        <h3 class="mb-3 text-eyebrow uppercase text-fg-muted">Paper</h3>
        {paperRecord ? (
          <dl class="space-y-3">
            <div>
              <dt class="text-fg-muted">Year</dt>
              <dd class="mt-0.5 font-mono text-fg">{paperRecord.year}</dd>
            </div>
            <div>
              <dt class="text-fg-muted">Coverage</dt>
              <dd class="mt-1">
                <StatusPill tone={coverageTone}>
                  {coverageLabel(paperRecord.coverage_status)}
                </StatusPill>
              </dd>
            </div>
            <div>
              <dt class="text-fg-muted">Findings</dt>
              <dd class="mt-0.5 font-mono text-fg">{paperRecord.finding_count}</dd>
            </div>
            <div>
              <dt class="text-fg-muted">Trials</dt>
              <dd class="mt-0.5 font-mono text-fg">
                {paperRecord.total_n_trials > 0
                  ? paperRecord.total_n_trials.toLocaleString()
                  : "—"}
              </dd>
            </div>
            <div>
              <dt class="text-fg-muted">Species</dt>
              <dd class="mt-0.5 text-fg">{listText(paperRecord.species)}</dd>
            </div>
            <div>
              <dt class="text-fg-muted">Lab</dt>
              <dd class="mt-0.5 text-fg">{paperRecord.lab ?? "—"}</dd>
            </div>
            <div>
              <dt class="text-fg-muted">Venue</dt>
              <dd class="mt-0.5 text-fg">{paperRecord.venue ?? "—"}</dd>
            </div>
            <div>
              <dt class="text-fg-muted">Source levels</dt>
              <dd class="mt-0.5 text-fg-secondary">
                {listText(paperRecord.source_data_levels)}
              </dd>
            </div>
            {paperDoi ? (
              <div>
                <dt class="text-fg-muted">DOI</dt>
                <dd class="mt-0.5">
                  <a class="break-all text-accent" href={`https://doi.org/${paperDoi}`}>
                    {paperDoi}
                  </a>
                </dd>
              </div>
            ) : null}
            <div>
              <dt class="text-fg-muted">Paper id</dt>
              <dd class="mt-0.5 break-all font-mono text-mono-id text-fg-muted">{paperId}</dd>
            </div>
          </dl>
        ) : null}
        {paperRecord ? (
          <div class="mt-4">
            <CitationDownloads
              bibtex={paperRecord.bibtex}
              ris={paperRecord.ris}
              filenameStem={paperRecord.slug}
              label="Cite"
            />
          </div>
        ) : null}
      </Card>
      {(protocolEntries.length > 0 ||
        datasetEntries.length > 0 ||
        sliceEntries.length > 0) ? (
        <Card padding="md" class="mt-3 text-body-xs">
          <h3 class="mb-2 text-eyebrow uppercase text-fg-muted">Linked records</h3>
          <ul class="flex flex-wrap gap-1.5">
            {protocolEntries.map((p) => (
              <li>
                <RecordChip
                  type="protocol"
                  label={p.protocol_name}
                  href={`/protocols/${slugForId(p.protocol_id)}`}
                />
              </li>
            ))}
            {datasetEntries.map((dataset) => (
              <li>
                <RecordChip
                  type="dataset"
                  label={dataset.name}
                  href={`/datasets/${slugForId(dataset.dataset_id)}`}
                />
              </li>
            ))}
            {sliceEntries.map((slice) => (
              <li>
                <RecordChip
                  type="slice"
                  label={slice.title}
                  href={`/slices/${slugForId(slice.slice_id)}`}
                />
              </li>
            ))}
          </ul>
        </Card>
      ) : null}
    </Fragment>

    <PageHeader
      eyebrow="Paper"
      title={paperTitle}
    />

    {hasNotes && paperRecord ? (
      <Section id="notes" spacing="md" title="Notes">
        <Card padding="md">
          <p class="text-body text-fg-secondary">{paperRecord.notes}</p>
        </Card>
      </Section>
    ) : null}

    {paperEntries.length > 0 ? (
      <Section
        id="curves"
        spacing="md"
        title="Curves on shared axes"
        description="Findings extracted from this paper, plotted alongside one another."
      >
        <MiniFindingsChart
          client:visible
          findings={paperEntries}
          colorBy="condition"
          height={280}
        />
        <p class="mt-2 text-body-xs text-fg-muted">
          Compare to the rest of the literature on{" "}
          <a class="text-accent" href="/findings">/findings</a>.
        </p>
      </Section>
    ) : null}

    <Section id="findings" spacing="md" title="Findings">
      {paperEntries.length > 0 ? (
        <DataTable
          columns={[
            { label: "Finding" },
            { label: "Curve" },
            { label: "Species" },
            { label: "Source level" },
            { label: "Stratification" },
            { label: "Points", align: "right" },
            { label: "Fits" },
          ]}
        >
          {paperEntries.map((e) => {
            const fits = fitsOf(e);
            return (
              <tr>
                <td class="px-3 py-2 font-mono text-mono-id">
                  <a href={hrefForFinding(e.finding_id)}>{e.finding_id}</a>
                </td>
                <td class="px-3 py-2">{e.curve_type}</td>
                <td class="px-3 py-2">{e.species ?? "—"}</td>
                <td class="px-3 py-2">{e.source_data_level}</td>
                <td class="px-3 py-2 text-body-xs text-fg-secondary">
                  {e.stratification.condition ?? "—"}
                </td>
                <td class="px-3 py-2 text-right font-mono">{e.points.length}</td>
                <td class="px-3 py-2">
                  {fits.length === 0 ? (
                    <span class="text-body-xs text-fg-muted">—</span>
                  ) : (
                    <ul class="space-y-0.5 text-mono-id">
                      {fits.map((f) => (
                        <li class="font-mono">
                          <span class="text-fg-secondary">
                            {f.variant_id.replace("model_variant.", "")}
                          </span>
                          {f.quality?.aic !== undefined ? (
                            <span class="ml-1 text-fg-muted">
                              AIC={f.quality.aic.toFixed(1)}
                            </span>
                          ) : null}
                        </li>
                      ))}
                    </ul>
                  )}
                </td>
              </tr>
            );
          })}
        </DataTable>
      ) : (
        <Card padding="md" class="text-body text-fg-secondary">
          No standardized finding curves have been extracted for this paper yet.
          The paper remains part of the curated bibliography and linked task
          coverage, so it will appear here as soon as extraction adds finding
          records.
        </Card>
      )}
    </Section>

    {hasFits ? (
      <Section
        id="fits"
        spacing="md"
        title="Fit parameters"
        description="Per-finding fits committed alongside this paper. Parameters, log-likelihood, AIC, and BIC for each variant. Click the finding id for residuals, model-selection winner, and provenance."
      >
        <div class="space-y-4">
          {paperEntries
            .filter((e) => fitsOf(e).length > 0)
            .map((e) => (
              <Card padding="sm">
                <header class="mb-2 flex flex-wrap items-baseline justify-between gap-2">
                  <a class="font-mono text-mono-id" href={hrefForFinding(e.finding_id)}>
                    {e.finding_id}
                  </a>
                  <span class="text-body-xs text-fg-muted">
                    {e.stratification.condition
                      ? `${e.stratification.condition}`
                      : ""}
                    {e.stratification.condition && e.stratification.subject_id
                      ? " · "
                      : ""}
                    {e.stratification.subject_id
                      ? `${e.stratification.subject_id}`
                      : ""}
                  </span>
                </header>
                <DataTable
                  density="compact"
                  class="border-0"
                  columns={[
                    { label: "Variant" },
                    { label: "Parameters" },
                    { label: "logL", align: "right", title: "log-likelihood" },
                    { label: "AIC", align: "right", title: "Akaike information criterion" },
                    { label: "BIC", align: "right", title: "Bayesian information criterion" },
                  ]}
                >
                  {fitsOf(e).map((f) => (
                    <tr>
                      <td class="px-2 py-1 font-mono">
                        {f.variant_id.replace("model_variant.", "")}
                      </td>
                      <td class="px-2 py-1 font-mono">
                        {paramRow(f.parameters)}
                      </td>
                      <td class="px-2 py-1 text-right font-mono">
                        {f.quality?.log_likelihood?.toFixed(1) ?? "—"}
                      </td>
                      <td class="px-2 py-1 text-right font-mono">
                        {f.quality?.aic?.toFixed(1) ?? "—"}
                      </td>
                      <td class="px-2 py-1 text-right font-mono">
                        {f.quality?.bic?.toFixed(1) ?? "—"}
                      </td>
                    </tr>
                  ))}
                </DataTable>
              </Card>
            ))}
        </div>
      </Section>
    ) : null}
  </DetailLayout>
</BaseLayout>
