---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { findings } from "../../lib/findings";
import { models, papers, type PaperEntry } from "../../lib/data";
import CitationDownloads from "../../components/CitationDownloads.astro";
import PapersBrowser from "../../components/PapersBrowser.svelte";
import Card from "../../components/ui/Card.astro";
import PageHeader from "../../components/ui/PageHeader.astro";

const findingPaperById = new Map(
  findings.findings.map((finding) => [finding.finding_id, finding.paper_id]),
);
const modelFitIdsByPaper = new Map<string, Set<string>>();
for (const fit of models.fits) {
  for (const findingId of fit.finding_ids ?? []) {
    const paperId = findingPaperById.get(findingId);
    if (!paperId) continue;
    const fitIds = modelFitIdsByPaper.get(paperId) ?? new Set<string>();
    fitIds.add(fit.id);
    modelFitIdsByPaper.set(paperId, fitIds);
  }
}

const cardList = (papers.papers as PaperEntry[])
  .map((paper) => ({
    ...paper,
    model_fit_count: modelFitIdsByPaper.get(paper.id)?.size ?? 0,
  }))
  .sort((a, b) => b.year - a.year || a.citation.localeCompare(b.citation));
---

<BaseLayout
  title="Papers · behavtaskatlas"
  description="Generated bibliography for behavtaskatlas papers, summarised by species, protocol, source-data level, coverage status, and extracted finding counts."
  width="wide"
>
  <PageHeader title="Papers">
    <Fragment slot="lede">
      {papers.counts.papers} curated papers in the generated bibliography;
      {findings.counts.findings} standardized findings are extracted from the
      subset with curve-level coverage. Click into a card for provenance,
      linked records, and any per-paper finding table, or compare on shared
      axes via{" "}
      <a class="text-accent" href="/findings">/findings</a>.
    </Fragment>
    <Fragment slot="meta">
      <CitationDownloads
        bibtex={papers.atlas_bibtex}
        ris={papers.atlas_ris}
        filenameStem="behavtaskatlas"
        label="Export all"
      />
    </Fragment>
  </PageHeader>

  {
    cardList.length === 0 ? (
      <Card padding="lg" class="text-body text-fg-secondary">
        No papers curated yet. Add one under{" "}
        <code class="rounded bg-surface-sunken px-1">papers/</code>.
      </Card>
    ) : (
      <PapersBrowser rows={cardList} client:load />
    )
  }
</BaseLayout>
