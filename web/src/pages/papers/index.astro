---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { findings, type FindingsEntry } from "../../lib/findings";
import { slugForId, getPaper, papers } from "../../lib/data";
import CitationDownloads from "../../components/CitationDownloads.astro";

type PaperCard = {
  paper_id: string;
  paper_citation: string;
  paper_year: number;
  paper_lab: string | null;
  paper_doi: string | null;
  species: Set<string>;
  protocols: Set<string>;
  findings: number;
  curve_types: Set<string>;
  source_levels: Set<string>;
  total_n_trials: number;
  total_n_subjects: number;
};

const cards = new Map<string, PaperCard>();
for (const entry of findings.findings as FindingsEntry[]) {
  let card = cards.get(entry.paper_id);
  if (!card) {
    card = {
      paper_id: entry.paper_id,
      paper_citation: entry.paper_citation,
      paper_year: entry.paper_year,
      paper_lab: entry.paper_lab ?? null,
      paper_doi: entry.paper_doi ?? null,
      species: new Set(),
      protocols: new Set(),
      findings: 0,
      curve_types: new Set(),
      source_levels: new Set(),
      total_n_trials: 0,
      total_n_subjects: 0,
    };
    cards.set(entry.paper_id, card);
  }
  card.findings += 1;
  if (entry.species) card.species.add(entry.species);
  card.protocols.add(entry.protocol_name);
  card.curve_types.add(entry.curve_type);
  card.source_levels.add(entry.source_data_level);
  if (typeof entry.n_trials === "number") card.total_n_trials += entry.n_trials;
  if (typeof entry.n_subjects === "number" && entry.n_subjects > card.total_n_subjects) {
    card.total_n_subjects = entry.n_subjects;
  }
}

const cardList = Array.from(cards.values()).sort(
  (a, b) => b.paper_year - a.paper_year || a.paper_citation.localeCompare(b.paper_citation),
);
---

<BaseLayout
  title="Papers · behavtaskatlas"
  description="Curated papers backing the atlas's findings, summarised by species, protocol, source-data level, and curve-type coverage."
>
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Papers</h1>
    <p class="mt-2 text-sm text-slate-600">
      {cardList.length} curated papers contributing
      {findings.counts.findings} findings across the atlas. Click into a card
      for the per-paper finding list, or compare on shared axes via{" "}
      <a class="text-accent" href="/findings">/findings</a>.
    </p>
    <div class="mt-3">
      <CitationDownloads
        bibtex={papers.atlas_bibtex}
        ris={papers.atlas_ris}
        filenameStem="behavtaskatlas"
        label="Export all"
      />
    </div>
  </header>

  {
    cardList.length === 0 ? (
      <section class="rounded-md border border-slate-200 bg-white p-6 text-sm text-slate-600">
        No papers curated yet. Add one under{" "}
        <code class="rounded bg-slate-100 px-1">papers/</code>.
      </section>
    ) : (
      <ul class="grid grid-cols-1 gap-3 md:grid-cols-2">
        {cardList.map((card) => (
          <li class="flex flex-col rounded-md border border-slate-200 bg-white p-4">
            <header class="mb-2 flex items-baseline justify-between gap-2">
              <h2 class="text-base font-semibold">
                <a href={`/papers/${slugForId(card.paper_id)}`}>
                  {card.paper_citation}
                </a>
              </h2>
              <span class="rounded bg-slate-100 px-2 py-0.5 text-xs">
                {card.paper_year}
              </span>
            </header>
            <p class="mb-3 text-xs font-mono text-slate-500">{card.paper_id}</p>
            <dl class="mb-3 grid grid-cols-2 gap-x-3 gap-y-1 text-xs text-slate-700">
              <dt class="text-slate-500">Lab</dt>
              <dd>{card.paper_lab ?? "—"}</dd>
              <dt class="text-slate-500">Species</dt>
              <dd>{Array.from(card.species).sort().join(", ") || "—"}</dd>
              <dt class="text-slate-500">Protocols</dt>
              <dd>{Array.from(card.protocols).sort().join(", ") || "—"}</dd>
              <dt class="text-slate-500">Source levels</dt>
              <dd>{Array.from(card.source_levels).sort().join(", ")}</dd>
            </dl>
            <ul class="mb-3 flex flex-wrap gap-x-3 gap-y-1 text-xs">
              <li class="rounded bg-slate-100 px-2 py-0.5">
                <span class="text-slate-500">Findings</span>
                <span class="ml-1 font-mono font-semibold text-slate-900">
                  {card.findings}
                </span>
              </li>
              <li class="rounded bg-slate-100 px-2 py-0.5">
                <span class="text-slate-500">Curves</span>
                <span class="ml-1 text-slate-900">
                  {Array.from(card.curve_types).sort().join(", ")}
                </span>
              </li>
              {card.total_n_trials > 0 ? (
                <li class="rounded bg-slate-100 px-2 py-0.5">
                  <span class="text-slate-500">Σ trials</span>
                  <span class="ml-1 font-mono font-semibold text-slate-900">
                    {card.total_n_trials.toLocaleString()}
                  </span>
                </li>
              ) : null}
              {card.total_n_subjects > 0 ? (
                <li class="rounded bg-slate-100 px-2 py-0.5">
                  <span class="text-slate-500">Subjects</span>
                  <span class="ml-1 font-mono font-semibold text-slate-900">
                    {card.total_n_subjects}
                  </span>
                </li>
              ) : null}
            </ul>
            {card.paper_doi ? (
              <p class="text-xs">
                <a class="text-accent" href={`https://doi.org/${card.paper_doi}`}>
                  doi:{card.paper_doi}
                </a>
              </p>
            ) : null}
            {(() => {
              const paper = getPaper(card.paper_id);
              return paper ? (
                <div class="mt-auto pt-3">
                  <CitationDownloads
                    bibtex={paper.bibtex}
                    ris={paper.ris}
                    filenameStem={paper.slug}
                  />
                </div>
              ) : null;
            })()}
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
