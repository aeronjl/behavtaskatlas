---
import BaseLayout from "../layouts/BaseLayout.astro";
import FindingsOverlay from "../components/FindingsOverlay.svelte";
import { findings } from "../lib/findings";

const counts = findings.counts as Record<string, number>;
const findingsList = findings.findings as Array<{
  finding_id: string;
  paper_citation: string;
  paper_year: number;
  species: string | null;
  protocol_name: string;
  source_data_level: string;
  curve_type: string;
  n_trials: number | null;
}>;
---

<BaseLayout
  title="Findings · behavtaskatlas"
  description="Cross-paper psychometric findings, plotted on shared signed-evidence axes and filterable by species, modality, evidence type, response modality, and source-data level."
>
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Cross-paper findings</h1>
    <p class="mt-2 text-sm text-slate-600">
      {counts.findings ?? 0} findings across {counts.papers ?? 0} papers, plotted on
      shared signed-evidence axes. Source-data level is encoded as point shape
      so curves at different levels stay distinguishable.
    </p>
  </header>

  {
    counts.findings && counts.findings > 0 ? (
      <FindingsOverlay client:visible data={findings} />
    ) : (
      <section class="rounded-md border border-slate-200 bg-white p-6 text-sm text-slate-600">
        No findings have been curated yet. Add a paper YAML under{" "}
        <code class="rounded bg-slate-100 px-1">papers/</code> and a finding
        YAML under <code class="rounded bg-slate-100 px-1">findings/</code>{" "}
        (or run <code class="rounded bg-slate-100 px-1">behavtaskatlas
        extract-finding</code>).
      </section>
    )
  }

  {
    findingsList.length > 0 ? (
      <section class="mt-10">
        <h2 class="mb-3 text-lg font-semibold">All findings</h2>
        <div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
              <tr>
                <th class="px-3 py-2">Paper</th>
                <th class="px-3 py-2">Year</th>
                <th class="px-3 py-2">Species</th>
                <th class="px-3 py-2">Protocol</th>
                <th class="px-3 py-2">Curve</th>
                <th class="px-3 py-2">Source level</th>
                <th class="px-3 py-2 text-right">Trials</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {findingsList.map((entry) => (
                <tr>
                  <td class="px-3 py-2">{entry.paper_citation}</td>
                  <td class="px-3 py-2 text-slate-600">{entry.paper_year}</td>
                  <td class="px-3 py-2 text-slate-600">
                    {entry.species ?? "—"}
                  </td>
                  <td class="px-3 py-2 text-slate-600">
                    {entry.protocol_name}
                  </td>
                  <td class="px-3 py-2 text-slate-600">{entry.curve_type}</td>
                  <td class="px-3 py-2 text-slate-600">
                    {entry.source_data_level}
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-slate-600">
                    {entry.n_trials ?? "—"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ) : null
  }
</BaseLayout>
