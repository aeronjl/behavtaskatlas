---
import BaseLayout from "../layouts/BaseLayout.astro";
import FindingsOverlay from "../components/FindingsOverlay.svelte";
import Card from "../components/ui/Card.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import { findings } from "../lib/findings";

const counts = findings.counts as Record<string, number>;
const findingPaperCount = counts.finding_papers ?? counts.papers ?? 0;
---

<BaseLayout
  title="Findings · behavtaskatlas"
  description="Cross-paper psychometric findings, plotted on shared signed-evidence axes and filterable by species, modality, evidence type, response modality, and source-data level."
  width="wide"
>
  <PageHeader
    title="Cross-paper findings"
    lede={`Behavioural curves from ${findingPaperCount} papers with extracted findings, plotted on shared signed-evidence axes. The generated bibliography tracks ${counts.papers ?? findingPaperCount} curated papers overall. Pick a curve type to switch view; use a preset to compare a slice of the literature; toggle Fit + aggregate to refit every curve interactively in your browser.`}
  />

  {
    counts.findings && counts.findings > 0 ? (
      <FindingsOverlay client:visible data={findings} />
    ) : (
      <Card padding="lg" class="text-body text-fg-secondary">
        No findings have been curated yet. Add a paper YAML under{" "}
        <code class="rounded bg-surface-sunken px-1">papers/</code> and a finding
        YAML under <code class="rounded bg-surface-sunken px-1">findings/</code>{" "}
        (or run <code class="rounded bg-surface-sunken px-1">behavtaskatlas
        extract-finding</code>).
      </Card>
    )
  }

  <p class="mt-6 max-w-prose text-body-xs text-fg-muted">
    For a flat-table view of every finding alongside protocols, datasets,
    and slices, use the search and type filters on
    <a class="text-accent" href="/catalog?type=family">/catalog</a>.
    Each finding's permalink lives at
    <code class="rounded bg-surface-sunken px-1 text-mono-id">/findings/&lt;id&gt;</code>.
  </p>
</BaseLayout>
