---
import BaseLayout from "../layouts/BaseLayout.astro";
import CatalogBrowser from "../components/CatalogBrowser.svelte";
import RecordChip from "../components/RecordChip.astro";
import Card from "../components/ui/Card.astro";
import DataTable from "../components/ui/DataTable.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import Section from "../components/ui/Section.astro";
import SectionAnchorNav from "../components/ui/SectionAnchorNav.astro";
import StatusPill from "../components/ui/StatusPill.astro";
import { catalog, manifest, slugForId } from "../lib/data";

const counts = (catalog.counts ?? {}) as Record<string, number>;

type Protocol = (typeof catalog.protocols)[number];
type Dataset = (typeof catalog.datasets)[number];

const datasetById = new Map(
  catalog.datasets.map((d) => [d.dataset_id, d]),
);
const slicesByProtocol = new Map<string, typeof manifest.slices>();
for (const slice of manifest.slices) {
  const list = slicesByProtocol.get(slice.protocol_id) ?? [];
  list.push(slice);
  slicesByProtocol.set(slice.protocol_id, list);
}
const protocolsByFamily = new Map<string, Protocol[]>();
for (const protocol of catalog.protocols) {
  const list = protocolsByFamily.get(protocol.family_id) ?? [];
  list.push(protocol);
  protocolsByFamily.set(protocol.family_id, list);
}

const familyCards = catalog.task_families.map((family) => {
  const protocols = protocolsByFamily.get(family.family_id) ?? [];
  const datasetIds = new Set<string>();
  for (const p of protocols) {
    for (const did of p.dataset_ids ?? []) datasetIds.add(did);
  }
  const datasets = Array.from(datasetIds)
    .map((id) => datasetById.get(id))
    .filter((d): d is Dataset => d !== undefined);
  return {
    family,
    protocols,
    datasets,
  };
});

const orphanProtocols = catalog.protocols.filter(
  (p) => !catalog.task_families.some((f) => f.family_id === p.family_id),
);

const familyNameById = new Map(
  catalog.task_families.map((family) => [family.family_id, family.name]),
);

function familyAnchor(familyId: string): string {
  return slugForId(familyId);
}

const catalogRows = [
  ...catalog.task_families.map((family) => ({
    record_type: "family" as const,
    id: family.family_id,
    title: family.name,
    href: `#${familyAnchor(family.family_id)}`,
    modalities: family.modalities,
    species: [],
    family_id: family.family_id,
    family_name: family.name,
    choice_type: family.choice_types.join(", "),
    status: family.curation_status,
    protocol_count: family.protocol_count,
    dataset_count: family.dataset_count,
    slice_count: family.slice_count,
    body: `${family.protocol_count} protocols, ${family.dataset_count} datasets, ${family.slice_count} slices`,
  })),
  ...catalog.protocols.map((protocol) => ({
    record_type: "protocol" as const,
    id: protocol.protocol_id,
    title: protocol.name,
    href: `/protocols/${slugForId(protocol.protocol_id)}`,
    family_id: protocol.family_id,
    family_name:
      protocol.family_name ??
      familyNameById.get(protocol.family_id) ??
      protocol.family_id,
    species: protocol.species,
    modalities: protocol.modalities,
    evidence_type: protocol.evidence_type,
    choice_type: protocol.choice_type,
    status: protocol.curation_status,
    dataset_count: (protocol.dataset_ids ?? []).length,
    slice_count: (protocol.slice_ids ?? []).length,
    body: `${protocol.protocol_scope} protocol`,
  })),
  ...catalog.datasets.map((dataset) => ({
    record_type: "dataset" as const,
    id: dataset.dataset_id,
    title: dataset.name,
    href: `/datasets/${slugForId(dataset.dataset_id)}`,
    species: dataset.species,
    modalities: [],
    source_data_level: dataset.source_data_level,
    status: dataset.curation_status,
    protocol_count: (dataset.protocol_ids ?? []).length,
    slice_count: (dataset.slice_ids ?? []).length,
    body: dataset.license ?? dataset.source_url ?? "",
  })),
  ...catalog.vertical_slices.map((slice) => ({
    record_type: "slice" as const,
    id: slice.slice_id,
    title: slice.title,
    href: `/slices/${slugForId(slice.slice_id)}`,
    family_id: slice.family_id,
    family_name: familyNameById.get(slice.family_id) ?? slice.family_id,
    species: slice.species ? [slice.species] : [],
    modalities: slice.modality ? [slice.modality] : [],
    evidence_type: slice.evidence_type,
    source_data_level: slice.source_data_level,
    status: slice.report_status,
    protocol_count: 1,
    dataset_count: 1,
    slice_count: 1,
    body: slice.stimulus_metric ?? "",
  })),
];
---

<BaseLayout
  title={`Catalog · ${catalog.title}`}
  description="Browsable atlas directory for task families, protocols, datasets, and reproducible vertical slices."
  width="wide"
>
  <PageHeader title="Catalog">
    <Fragment slot="lede">
      Every record in the atlas, grouped under its task family. Each family
      bundles one or more protocols (concrete task variants), each protocol
      points at the datasets that ran it and any reproducible slices the
      atlas has built. For cross-paper comparison see{" "}
      <a class="text-accent" href="/findings">/findings</a>;
      for the relationships between records visit{" "}
      <a class="text-accent" href="/graph">/graph</a>.
    </Fragment>
    <Fragment slot="meta">
      <p class="text-body-xs text-fg-muted">
        {counts.task_families ?? "?"} task families ·
        {counts.protocols ?? "?"} protocols ·
        {counts.datasets ?? "?"} datasets ·
        {counts.vertical_slices ?? "?"} vertical slices ·
        {counts.report_available ?? 0} reports available
      </p>
    </Fragment>
  </PageHeader>

  <section class="mb-8">
    <CatalogBrowser rows={catalogRows} client:load />
  </section>

  <SectionAnchorNav
    items={familyCards.map(({ family }) => ({
      id: familyAnchor(family.family_id),
      label: family.name,
      count: family.protocol_count,
    }))}
  />

  <section class="space-y-8">
    {familyCards.map(({ family, protocols, datasets }) => (
      <Card
        as="article"
        padding="none"
        id={familyAnchor(family.family_id)}
        class="scroll-mt-20"
      >
        <header class="border-b border-rule p-5">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <div>
              <p class="text-eyebrow uppercase text-fg-muted">Task family</p>
              <h2 class="mt-1 text-h2 text-fg">{family.name}</h2>
              <p class="mt-1 text-mono-id text-fg-muted">{family.family_id}</p>
            </div>
            <StatusPill
              tone={
                family.curation_status === "data-linked" ||
                family.curation_status === "literature-curated"
                  ? "ok"
                  : "neutral"
              }
            >
              {family.curation_status}
            </StatusPill>
          </div>
          <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1 text-body-xs sm:grid-cols-4">
            <div>
              <dt class="text-fg-muted">Modalities</dt>
              <dd class="mt-0.5 text-fg-secondary">
                {family.modalities.join(", ")}
              </dd>
            </div>
            <div>
              <dt class="text-fg-muted">Choice types</dt>
              <dd class="mt-0.5 text-fg-secondary">
                {family.choice_types.join(", ")}
              </dd>
            </div>
            <div>
              <dt class="text-fg-muted">Counts</dt>
              <dd class="mt-0.5 font-mono text-fg-secondary">
                {family.protocol_count}p · {family.dataset_count}d ·{" "}
                {family.slice_count}s
              </dd>
            </div>
            <div>
              <dt class="text-fg-muted">Datasets</dt>
              <dd class="mt-0.5">
                <ul class="flex flex-wrap gap-1">
                  {datasets.map((d) => (
                    <li>
                      <a
                        class="text-mono-id text-fg-secondary hover:text-accent"
                        href={`/datasets/${slugForId(d.dataset_id)}`}
                      >
                        {d.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </dd>
            </div>
          </dl>
        </header>

        <div class="p-5">
          <h3 class="mb-3 text-eyebrow uppercase text-fg-muted">
            Protocols ({protocols.length})
          </h3>
          {protocols.length === 0 ? (
            <p class="text-body text-fg-muted">
              No protocols are linked to this family yet.
            </p>
          ) : (
            <ul class="space-y-3">
              {protocols.map((protocol) => {
                const slices = slicesByProtocol.get(protocol.protocol_id) ?? [];
                const datasets = (protocol.dataset_ids ?? [])
                  .map((id) => datasetById.get(id))
                  .filter((d): d is Dataset => d !== undefined);
                return (
                  <Card as="li" padding="md">
                    <header class="mb-2 flex flex-wrap items-baseline justify-between gap-3">
                      <div>
                        <h4 class="text-body-lg">
                          <a href={`/protocols/${slugForId(protocol.protocol_id)}`}>
                            {protocol.name}
                          </a>
                        </h4>
                        <p class="mt-0.5 text-mono-id text-fg-muted">
                          {protocol.species.join(", ")} ·
                          {" "}{protocol.evidence_type}
                          {" / "}{protocol.choice_type}
                          {" · "}{protocol.protocol_scope}
                        </p>
                      </div>
                      <span class="text-body-xs text-fg-muted">
                        {protocol.curation_status}
                      </span>
                    </header>

                    {datasets.length > 0 ? (
                      <div class="mt-2">
                        <p class="text-eyebrow uppercase text-fg-muted">
                          Datasets
                        </p>
                        <ul class="mt-1 flex flex-wrap gap-2">
                          {datasets.map((d) => (
                            <li class="min-w-0 max-w-full">
                              <RecordChip
                                type="dataset"
                                label={d.name}
                                href={`/datasets/${slugForId(d.dataset_id)}`}
                              />
                            </li>
                          ))}
                        </ul>
                      </div>
                    ) : null}

                    {slices.length > 0 ? (
                      <div class="mt-3">
                        <p class="text-eyebrow uppercase text-fg-muted">
                          Reproducible slices
                        </p>
                        <ul class="mt-1 flex flex-wrap gap-2">
                          {slices.map((slice) => (
                            <li class="min-w-0 max-w-full">
                              <a
                                class="inline-flex max-w-full min-w-0 items-baseline gap-1.5 rounded border border-rule bg-surface-raised px-2 py-0.5 text-body-xs no-underline text-fg-secondary hover:border-rule-emphasis hover:text-accent"
                                href={`/slices/${slugForId(slice.id)}`}
                              >
                                <span class="text-eyebrow uppercase text-fg-muted">
                                  slice
                                </span>
                                <span class="min-w-0 truncate">{slice.title}</span>
                                <StatusPill
                                  tone={slice.report_status === "available" ? "ok" : "neutral"}
                                  class="ml-1"
                                >
                                  {slice.report_status === "available"
                                    ? "report"
                                    : "no report"}
                                </StatusPill>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ) : null}
                  </Card>
                );
              })}
            </ul>
          )}
        </div>
      </Card>
    ))}
  </section>

  {orphanProtocols.length > 0 ? (
    <Section title="Unlinked protocols" spacing="lg" class="mt-12">
      <ul class="space-y-2">
        {orphanProtocols.map((p) => (
          <Card as="li" padding="sm">
            <a href={`/protocols/${slugForId(p.protocol_id)}`}>{p.name}</a>
            <span class="ml-2 text-mono-id text-fg-muted">{p.family_id}</span>
          </Card>
        ))}
      </ul>
    </Section>
  ) : null}

  <details class="mt-12 rounded-md border border-rule bg-surface-raised">
    <summary class="cursor-pointer px-4 py-3 text-body font-semibold text-fg-secondary hover:text-accent">
      Browse all records as flat tables
      <span class="ml-2 text-body-xs font-normal text-fg-muted">
        ({catalog.protocols.length} protocols · {catalog.datasets.length} datasets · {catalog.vertical_slices.length} slices)
      </span>
    </summary>
    <div class="border-t border-rule p-4">
      <h3 class="mb-2 text-eyebrow uppercase text-fg-muted">Protocols</h3>
      <DataTable
        class="mb-6"
        columns={[
          { label: "Name" },
          { label: "Family" },
          { label: "Species" },
          { label: "Evidence" },
          { label: "Choice" },
          { label: "Status" },
        ]}
      >
        {catalog.protocols.map((protocol) => (
          <tr>
            <td class="px-3 py-2">
              <a href={`/protocols/${slugForId(protocol.protocol_id)}`}>
                {protocol.name}
              </a>
            </td>
            <td class="px-3 py-2 text-fg-secondary">
              {protocol.family_name ?? protocol.family_id}
            </td>
            <td class="px-3 py-2">{protocol.species.join(", ")}</td>
            <td class="px-3 py-2">{protocol.evidence_type}</td>
            <td class="px-3 py-2">{protocol.choice_type}</td>
            <td class="px-3 py-2 text-body-xs text-fg-secondary">
              {protocol.curation_status}
            </td>
          </tr>
        ))}
      </DataTable>

      <h3 class="mb-2 text-eyebrow uppercase text-fg-muted">Datasets</h3>
      <DataTable
        class="mb-6"
        columns={[
          { label: "Name" },
          { label: "Source level" },
          { label: "Species" },
          { label: "License" },
          { label: "Status" },
        ]}
      >
        {catalog.datasets.map((dataset) => (
          <tr>
            <td class="px-3 py-2">
              <a href={`/datasets/${slugForId(dataset.dataset_id)}`}>
                {dataset.name}
              </a>
            </td>
            <td class="px-3 py-2">{dataset.source_data_level}</td>
            <td class="px-3 py-2">{dataset.species.join(", ")}</td>
            <td class="px-3 py-2 text-body-xs text-fg-secondary">
              {dataset.license ?? "—"}
            </td>
            <td class="px-3 py-2 text-body-xs text-fg-secondary">
              {dataset.curation_status}
            </td>
          </tr>
        ))}
      </DataTable>

      <h3 class="mb-2 text-eyebrow uppercase text-fg-muted">Vertical slices</h3>
      <ul class="grid grid-cols-1 gap-2 md:grid-cols-2">
        {catalog.vertical_slices.map((slice) => (
          <Card as="li" padding="sm">
            <div class="flex items-baseline justify-between gap-2">
              <span class="font-medium">{slice.title}</span>
              <StatusPill tone={slice.report_status === "available" ? "ok" : "neutral"}>
                {slice.report_status}
              </StatusPill>
            </div>
            <div class="mt-1 text-body-xs text-fg-secondary">{slice.slice_id}</div>
          </Card>
        ))}
      </ul>
    </div>
  </details>
</BaseLayout>
