---
import BaseLayout from "../layouts/BaseLayout.astro";
import RelationshipGraph from "../components/RelationshipGraph.svelte";
import { graph, hrefForNode } from "../lib/data";
import type { GraphNode, GraphEdge } from "../lib/data";

const counts = graph.counts as Record<string, number>;

const visualNodes = graph.nodes.map((n) => ({
  node_id: n.node_id,
  label: n.label,
  node_type: n.node_type,
  status: n.status ?? undefined,
  href: hrefForNode(n),
}));

const visualEdges = graph.edges.map((e) => ({
  source: e.source,
  target: e.target,
  label: e.label,
}));

const nodeTypeOrder = ["task_family", "protocol", "dataset", "vertical_slice"];
const nodeTypeLabels: Record<string, string> = {
  task_family: "Task families",
  protocol: "Protocols",
  dataset: "Datasets",
  vertical_slice: "Vertical slices",
};

const nodesByType = nodeTypeOrder.map((type) => ({
  type,
  label: nodeTypeLabels[type] ?? type,
  nodes: graph.nodes.filter((n) => n.node_type === type),
}));

const edgesBySource = new Map<string, GraphEdge[]>();
for (const edge of graph.edges) {
  if (!edgesBySource.has(edge.source)) {
    edgesBySource.set(edge.source, []);
  }
  edgesBySource.get(edge.source)!.push(edge);
}

const nodesById = new Map<string, GraphNode>();
for (const node of graph.nodes) {
  nodesById.set(node.node_id, node);
}

function targetLabel(targetId: string): string {
  return nodesById.get(targetId)?.label ?? targetId;
}

function targetHref(targetId: string): string | null {
  const target = nodesById.get(targetId);
  if (!target) return null;
  return hrefForNode(target);
}
---

<BaseLayout
  title="Relationship graph · behavtaskatlas"
  description="Force-layout visualization of how task families, protocols, datasets, and vertical slices reference each other across the atlas."
>
  <header class="mb-6">
    <h1 class="text-3xl">Relationship graph</h1>
    <p class="mt-2 max-w-3xl text-sm text-slate-600">
      How task families, protocols, datasets, and vertical slices reference
      each other. Force-layout view first; full text index below for
      Cmd-F-style searching.
    </p>
    <p class="mt-2 text-xs text-slate-500">
      {counts.nodes} nodes · {counts.edges} edges · {counts.qa_issues} QA issues
    </p>
  </header>

  <RelationshipGraph
    client:visible
    nodes={visualNodes}
    edges={visualEdges}
    height={620}
  />

  <section class="mt-12">
    <header class="mb-3">
      <h2 class="text-xl">Index</h2>
      <p class="mt-1 text-sm text-slate-600">
        Same nodes grouped by type, with each node's outgoing edges listed.
      </p>
    </header>
    {nodesByType.map((group) => (
      <section class="mb-8">
        <h3 class="mb-3 text-base font-semibold text-slate-800">
          {group.label}{" "}
          <span class="text-sm font-normal text-slate-500">
            ({group.nodes.length})
          </span>
        </h3>
        <ul class="space-y-3">
          {group.nodes.map((node) => {
            const href = hrefForNode(node);
            const outgoing = edgesBySource.get(node.node_id) ?? [];
            return (
              <li class="rounded-md border border-slate-200 bg-white p-3 text-sm">
                <header class="mb-1 flex items-baseline justify-between gap-2">
                  <span class="font-medium">
                    {href ? <a href={href}>{node.label}</a> : node.label}
                  </span>
                  <span class="text-xs text-slate-500">{node.status}</span>
                </header>
                <div class="font-mono text-xs text-slate-500">
                  {node.node_id}
                </div>
                {outgoing.length > 0 ? (
                  <ul class="mt-2 space-y-0.5 text-xs text-slate-700">
                    {outgoing.map((edge) => {
                      const tHref = targetHref(edge.target);
                      const label = targetLabel(edge.target);
                      return (
                        <li>
                          <span class="text-slate-500">{edge.label}:</span>{" "}
                          {tHref ? <a href={tHref}>{label}</a> : label}
                        </li>
                      );
                    })}
                  </ul>
                ) : null}
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>
