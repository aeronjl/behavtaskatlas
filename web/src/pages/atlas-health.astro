---
import BaseLayout from "../layouts/BaseLayout.astro";
import CoverageGapMatrix from "../components/CoverageGapMatrix.svelte";
import Card from "../components/ui/Card.astro";
import DataTable from "../components/ui/DataTable.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import Section from "../components/ui/Section.astro";
import SectionAnchorNav from "../components/ui/SectionAnchorNav.astro";
import Stat from "../components/ui/Stat.astro";
import StatGrid from "../components/ui/StatGrid.astro";
import StatusPill from "../components/ui/StatusPill.astro";
import {
  audit,
  catalog,
  curationQueue,
  dataRequests,
  hrefForFinding,
  linkIntegrity,
  models,
  papers,
  slugForId,
} from "../lib/data";
import { findings as findingsIndex } from "../lib/findings";

type AuditReportRow = (typeof audit)["reports"][number];
type AuditPerPoint = NonNullable<AuditReportRow["per_point"]>[number];
const auditReports = audit.reports as AuditReportRow[];

type LinkIssue = { source: string; href: string; message: string };
const linkIssues = linkIntegrity.issues as LinkIssue[];

type CurationItem = {
  item_id: string;
  action_type: string;
  priority: "low" | "normal" | "high";
  status: "open" | "blocked" | "done";
  source_issue_id: string;
  source_issue_type: string;
  source_severity: "info" | "warning" | "error";
  node_id?: string | null;
  node_label?: string | null;
  node_type?: string | null;
  related_node_id?: string | null;
  message: string;
  suggested_next_step: string;
  href?: string | null;
};
const curationItems = (curationQueue.items ?? []) as CurationItem[];
const curationCounts = (curationQueue.counts ?? {}) as Record<string, number>;
const actionCounts = (curationQueue.action_counts ?? {}) as Record<
  string,
  number
>;
const priorityCounts = (curationQueue.priority_counts ?? {}) as Record<
  string,
  number
>;
const priorityOrder: CurationItem["priority"][] = ["high", "normal", "low"];
const curationGrouped = priorityOrder
  .map((p) => ({ priority: p, items: curationItems.filter((i) => i.priority === p) }))
  .filter((g) => g.items.length > 0);
const priorityClasses: Record<CurationItem["priority"], string> = {
  high: "bg-warn-soft text-warn",
  normal: "bg-accent-soft text-accent",
  low: "bg-surface-sunken text-fg-muted",
};

type RoadmapItem = {
  rank: number;
  roadmap_id?: string;
  priority_label: string;
  issue_type: string;
  target_type: string;
  target_id: string;
  finding_id?: string;
  slice_id?: string;
  paper_id?: string;
  curve_type?: string;
  source_data_level?: string;
  comparison_scope?: string;
  caveat_tags?: string[];
  status?: string;
  blocker_type?: string;
  blocker_detail?: string;
  next_action?: string;
  recommended_action: string;
  impact: string;
  missing_requirements?: string[];
  related_variant_id?: string;
  rationale?: string;
};
const roadmap =
  ((models as unknown as {
    model_coverage_roadmap?: {
      counts?: {
        items?: number;
        by_priority?: Record<string, number>;
        by_status?: Record<string, number>;
      };
      issue_definitions?: Record<string, { label: string; description: string }>;
      items?: RoadmapItem[];
    };
  }).model_coverage_roadmap ?? { counts: {}, issue_definitions: {}, items: [] });
const roadmapItems = roadmap.items ?? [];
const topRoadmapItems = roadmapItems.slice(0, 20);
const roadmapIssueDefinitions = roadmap.issue_definitions ?? {};

type FindingEntry = {
  finding_id: string;
  dataset_id: string;
  paper_id: string;
  paper_citation: string;
  protocol_id: string;
  protocol_name: string;
  slice_id: string;
  species: string | null;
  curve_type: string;
  source_data_level: string;
  n_trials?: number | null;
  stratification?: { condition?: string | null; subject_id?: string | null };
};
type BlockerGroup = {
  key: string;
  blocker_type: string;
  blocker_detail: string;
  next_action: string;
  dataset_id: string;
  dataset_name: string;
  dataset_href: string;
  source_url: string | null;
  source_data_level: string;
  paper_id: string;
  paper_label: string;
  paper_href: string;
  slice_id: string;
  slice_href: string;
  protocol_name: string;
  species: string;
  items: RoadmapItem[];
  finding_ids: string[];
  curve_types: string[];
  comparison_scopes: string[];
  caveat_tags: string[];
  total_trials: number;
};
type DataRequestEntry = {
  request_id: string;
  title: string;
  status: string;
  priority: string;
  request_type: string;
  blocker_type?: string | null;
  blocker_detail?: string | null;
  curation_status?: string | null;
  dataset_ids: string[];
  dataset_names?: string[];
  paper_ids: string[];
  paper_labels?: string[];
  protocol_ids: string[];
  slice_ids: string[];
  finding_ids: string[];
  model_roadmap_issue_types?: string[];
  purpose: string;
  next_action: string;
  requested_files: Array<{ name: string; description: string; required: boolean }>;
  events?: Array<{
    event_type: string;
    event_date: string;
    actor: string;
    notes: string;
    evidence_url?: string | null;
    evidence_path?: string | null;
    next_follow_up_date?: string | null;
  }>;
  last_event_type?: string | null;
  last_event_date?: string | null;
  next_follow_up_date?: string | null;
  action_state?: string | null;
  action_summary?: string | null;
  suggested_command?: string | null;
  days_since_last_event?: number | null;
  days_until_follow_up?: number | null;
  request_export_path?: string | null;
  contact_instructions?: string | null;
  request_draft?: { subject: string; body: string } | null;
};
type MatrixCellKey =
  | "raw_data"
  | "trial_table"
  | "figure_source"
  | "findings"
  | "model_fits"
  | "reports"
  | "source_request";
type MatrixCellState =
  | "ok"
  | "partial"
  | "ready"
  | "missing"
  | "blocked"
  | "unknown"
  | "na";
type CoverageGapMatrixRow = {
  blocker: string;
  cells: Record<MatrixCellKey, MatrixCellState>;
  chips: string[];
  detail?: string | null;
  href: string;
  id: string;
  next_action: string;
  priority: string;
  request_href?: string | null;
  request_label?: string | null;
  source: string;
  status: string;
  target_id: string;
  target_label: string;
  target_type: string;
  view: "ready" | "blocked" | "extraction";
};
type SliceCoverageRow = {
  fittable_variant_ids?: string[];
  n_subjects?: number;
  n_trials?: number;
  slice_id: string;
  trials_path?: string | null;
};

const findings = (findingsIndex.findings ?? []) as unknown as FindingEntry[];
const findingsById = new Map(findings.map((f) => [f.finding_id, f]));
const findingsBySlice = new Map<string, FindingEntry[]>();
for (const finding of findings) {
  const rows = findingsBySlice.get(finding.slice_id) ?? [];
  rows.push(finding);
  findingsBySlice.set(finding.slice_id, rows);
}
const datasetsById = new Map(
  catalog.dataset_details.map((d) => [d.dataset_id, d]),
);
const papersById = new Map(papers.papers.map((paper) => [paper.id, paper]));
const slicesById = new Map(catalog.vertical_slices.map((slice) => [slice.slice_id, slice]));
const sliceCoverageById = new Map(
  (((models as unknown as { slice_coverage?: SliceCoverageRow[] }).slice_coverage ?? []) as SliceCoverageRow[])
    .map((row) => [row.slice_id, row]),
);
const fitsByFinding = ((models as unknown as {
  fits_by_finding?: Record<string, unknown[]>;
}).fits_by_finding ?? {}) as Record<string, unknown[]>;
const blockedItems = roadmapItems.filter(
  (item) => item.status === "blocked_external_data",
);
const groupsByKey = new Map<string, BlockerGroup>();
const requestRows = (dataRequests.requests ?? []) as unknown as DataRequestEntry[];

function compactId(id: string): string {
  return id.replace(/^[^.]+\./, "");
}
function label(value: string | undefined | null): string {
  return value && value.length > 0 ? value.replace(/_/g, " ") : "unknown";
}
function paperLabel(citation: string | undefined, paperId: string): string {
  return citation?.trim().split(".")[0] ?? compactId(paperId);
}
function addUnique(values: string[], value: string | undefined | null): void {
  if (!value || values.includes(value)) return;
  values.push(value);
}

for (const item of blockedItems) {
  const finding = item.finding_id ? findingsById.get(item.finding_id) : undefined;
  const datasetId = finding?.dataset_id ?? "unknown";
  const dataset = datasetsById.get(datasetId);
  const sliceId = item.slice_id || finding?.slice_id || "";
  const key = `${item.blocker_type ?? "external_data"}:${datasetId}:${sliceId}`;
  let group = groupsByKey.get(key);
  if (!group) {
    const paperId = item.paper_id ?? finding?.paper_id ?? "unknown";
    group = {
      key,
      blocker_type: item.blocker_type ?? "external_data",
      blocker_detail: item.blocker_detail ?? item.rationale ?? "",
      next_action: item.next_action ?? item.recommended_action,
      dataset_id: datasetId,
      dataset_name: dataset?.name ?? compactId(datasetId),
      dataset_href: dataset ? `/datasets/${slugForId(datasetId)}` : "#",
      source_url: dataset?.source_url ?? null,
      source_data_level:
        item.source_data_level ?? finding?.source_data_level ?? "unknown",
      paper_id: paperId,
      paper_label: paperLabel(finding?.paper_citation, paperId),
      paper_href: paperId !== "unknown" ? `/papers/${slugForId(paperId)}` : "#",
      slice_id: sliceId,
      slice_href: sliceId ? `/slices/${slugForId(sliceId)}` : "#",
      protocol_name: finding?.protocol_name ?? "unknown protocol",
      species: finding?.species ?? "unknown species",
      items: [],
      finding_ids: [],
      curve_types: [],
      comparison_scopes: [],
      caveat_tags: [],
      total_trials: 0,
    };
    groupsByKey.set(key, group);
  }
  group.items.push(item);
  addUnique(group.finding_ids, item.finding_id);
  addUnique(group.curve_types, item.curve_type ?? finding?.curve_type);
  addUnique(group.comparison_scopes, item.comparison_scope);
  for (const tag of item.caveat_tags ?? []) addUnique(group.caveat_tags, tag);
}
for (const group of groupsByKey.values()) {
  group.finding_ids.sort();
  group.curve_types.sort();
  group.comparison_scopes.sort();
  group.caveat_tags.sort();
  group.total_trials = group.finding_ids.reduce(
    (total, fid) => total + (findingsById.get(fid)?.n_trials ?? 0),
    0,
  );
}
const blockerGroups = Array.from(groupsByKey.values()).sort(
  (a, b) =>
    b.items.length - a.items.length || a.dataset_name.localeCompare(b.dataset_name),
);
const affectedFindingCount = new Set(
  blockedItems
    .map((i) => i.finding_id)
    .filter((id): id is string => Boolean(id)),
).size;
const blockedPriorityHigh = blockedItems.filter(
  (item) => item.priority_label === "high",
).length;
const readyRequestCount = requestRows.filter(
  (r) => r.status === "ready_to_send",
).length;
const actionOrder = [
  "overdue",
  "follow_up_due",
  "ready_to_send",
  "fulfilled_pending_intake",
  "waiting",
  "blocked",
  "draft",
  "closed",
];
const activeRequestCount = requestRows.filter(
  (r) => r.action_state && r.action_state !== "closed",
).length;
const followUpDueCount = requestRows.filter((r) =>
  ["overdue", "follow_up_due"].includes(r.action_state ?? ""),
).length;
const priorityRankOrder: Record<string, number> = { high: 0, medium: 1, low: 2 };
function priorityRank(value: string | undefined | null): number {
  return priorityRankOrder[value ?? ""] ?? 99;
}
const requestQueueGroups = actionOrder
  .map((actionState) => ({
    actionState,
    requests: requestRows
      .filter((r) => r.action_state === actionState)
      .sort(
        (a, b) =>
          priorityRank(a.priority) - priorityRank(b.priority) ||
          a.title.localeCompare(b.title),
      ),
  }))
  .filter((g) => g.requests.length > 0);

function requestForGroup(group: BlockerGroup): DataRequestEntry | undefined {
  return requestRows.find((r) => {
    if (r.blocker_type && r.blocker_type !== group.blocker_type) return false;
    const matchesDataset = r.dataset_ids.includes(group.dataset_id);
    const matchesSlice =
      group.slice_id.length > 0 && r.slice_ids.includes(group.slice_id);
    const matchesFinding = group.finding_ids.some((fid) =>
      r.finding_ids.includes(fid),
    );
    return matchesDataset || matchesSlice || matchesFinding;
  });
}

function statusClass(status: string): string {
  if (status === "ok") return "bg-ok-soft text-ok";
  if (status === "drift") return "bg-bad-soft text-bad";
  if (status === "ambiguous") return "bg-warn-soft text-warn";
  return "bg-surface-sunken text-fg-secondary";
}
function fmt(value: number | null | undefined, digits = 6): string {
  if (value === null || value === undefined) return "—";
  return value.toFixed(digits);
}
function priorityClass(priority: string): string {
  if (priority === "high") return "bg-warn-soft text-warn";
  if (priority === "medium") return "bg-accent-soft text-accent";
  return "bg-surface-sunken text-fg-muted";
}
function roadmapStatusClass(status: string | undefined): string {
  if (status === "blocked_external_data") return "bg-bad-soft text-bad";
  return "bg-ok-soft text-ok";
}
function roadmapStatusLabel(status: string | undefined): string {
  return status ? status.replace(/_/g, " ") : "ready";
}
function issueLabel(issueType: string): string {
  return roadmapIssueDefinitions[issueType]?.label ?? issueType.replace(/_/g, " ");
}
function roadmapHref(item: RoadmapItem): string {
  if (item.target_type === "slice" && item.slice_id) {
    return `/slices/${slugForId(item.slice_id)}`;
  }
  if (item.finding_id) return hrefForFinding(item.finding_id);
  return "#";
}
function formatDate(value: string | undefined | null): string {
  return value ? value : "none";
}
function hrefForNode(nodeId: string | undefined | null, nodeType?: string | null): string {
  if (!nodeId) return "#";
  if (nodeId.startsWith("paper.") || nodeType === "paper") return `/papers/${slugForId(nodeId)}`;
  if (nodeId.startsWith("finding.") || nodeType === "finding") return hrefForFinding(nodeId);
  if (nodeId.startsWith("slice.") || nodeType === "slice") return `/slices/${slugForId(nodeId)}`;
  if (nodeId.startsWith("dataset.") || nodeType === "dataset") return `/datasets/${slugForId(nodeId)}`;
  if (nodeId.startsWith("protocol.") || nodeType === "protocol") return `/protocols/${slugForId(nodeId)}`;
  return "#";
}
function requestCellState(actionState: string | null | undefined): MatrixCellState {
  if (actionState === "ready_to_send") return "ready";
  if (actionState === "blocked" || actionState === "overdue") return "blocked";
  if (actionState === "draft" || actionState === "waiting" || actionState === "follow_up_due") return "partial";
  if (actionState === "closed" || actionState === "fulfilled_pending_intake") return "ok";
  return "unknown";
}
function uniqueList(values: Array<string | undefined | null>): string[] {
  return Array.from(new Set(values.filter((value): value is string => Boolean(value))));
}

const coverageGapRows: CoverageGapMatrixRow[] = [];

for (const request of requestRows) {
  const paperId = request.paper_ids[0] ?? "";
  const paper = paperId ? papersById.get(paperId) : undefined;
  const findingCount =
    request.finding_ids.length ||
    request.paper_ids.reduce((total, id) => total + (papersById.get(id)?.finding_count ?? 0), 0);
  const sourceLevel = request.dataset_ids.length > 0 ? "figure-source-data" : "";
  coverageGapRows.push({
    blocker: request.blocker_type ?? request.request_type,
    cells: {
      raw_data: request.dataset_ids.length > 0 ? "partial" : "blocked",
      trial_table: "blocked",
      figure_source: request.dataset_ids.length > 0 ? "ok" : "unknown",
      findings: findingCount > 0 ? "partial" : "missing",
      model_fits: (request.model_roadmap_issue_types ?? []).includes("proxy_source_data")
        ? "partial"
        : "missing",
      reports: request.slice_ids.length > 0 ? "ok" : "missing",
      source_request: requestCellState(request.action_state ?? request.status),
    },
    chips: [
      request.paper_ids.length > 0 ? `${request.paper_ids.length} paper${request.paper_ids.length === 1 ? "" : "s"}` : "",
      findingCount > 0 ? `${findingCount} finding${findingCount === 1 ? "" : "s"}` : "",
      request.dataset_ids.length > 0 ? `${request.dataset_ids.length} dataset${request.dataset_ids.length === 1 ? "" : "s"}` : "",
      sourceLevel ? label(sourceLevel) : "",
    ].filter(Boolean),
    detail: request.blocker_detail,
    href: paperId ? `/papers/${slugForId(paperId)}` : request.request_export_path ?? "#",
    id: `request:${request.request_id}`,
    next_action: request.action_summary ?? request.next_action,
    priority: request.priority,
    request_href: request.request_export_path,
    request_label: label(request.status),
    source: "data request",
    status: request.action_state ?? request.status,
    target_id: paperId || request.request_id,
    target_label: request.title || paper?.citation?.split(".")[0] || compactId(request.request_id),
    target_type: request.paper_ids.length > 1 ? "paper group" : "paper",
    view: "blocked",
  });
}

const readyItemsBySlice = new Map<string, RoadmapItem[]>();
for (const item of roadmapItems.filter((entry) => entry.status === "ready")) {
  const sliceId = item.slice_id || item.target_id;
  const rows = readyItemsBySlice.get(sliceId) ?? [];
  rows.push(item);
  readyItemsBySlice.set(sliceId, rows);
}
for (const [sliceId, items] of readyItemsBySlice) {
  const slice = slicesById.get(sliceId);
  const sliceCoverage = sliceCoverageById.get(sliceId);
  const sliceFindings = findingsBySlice.get(sliceId) ?? [];
  const fitCount = sliceFindings.reduce(
    (total, finding) => total + (fitsByFinding[finding.finding_id]?.length ?? 0),
    0,
  );
  const missingRequirements = uniqueList(items.flatMap((item) => item.missing_requirements ?? []));
  coverageGapRows.push({
    blocker: missingRequirements.length > 0
      ? `missing ${missingRequirements.join(", ")}`
      : issueLabel(items[0]?.issue_type ?? "near_miss_slice"),
    cells: {
      raw_data: sliceCoverage?.trials_path ? "ok" : "missing",
      trial_table: sliceCoverage?.trials_path ? "ok" : "missing",
      figure_source: "na",
      findings: sliceFindings.length > 0 ? "ok" : "missing",
      model_fits: fitCount > 0 ? "partial" : "ready",
      reports: slice?.report_status === "available" ? "ok" : "missing",
      source_request: "na",
    },
    chips: [
      `${items.length} variant${items.length === 1 ? "" : "s"}`,
      sliceCoverage?.n_trials ? `${sliceCoverage.n_trials.toLocaleString()} trials` : "",
      missingRequirements.length > 0 ? missingRequirements.join(", ") : "",
    ].filter(Boolean),
    detail: items[0]?.rationale,
    href: `/slices/${slugForId(sliceId)}`,
    id: `roadmap-ready:${sliceId}`,
    next_action: items[0]?.recommended_action ?? "Add the missing harmonized capability or mark the variant intentionally inapplicable.",
    priority: items[0]?.priority_label ?? "low",
    source: "model roadmap",
    status: "ready",
    target_id: sliceId,
    target_label: slice?.title ?? compactId(sliceId),
    target_type: "slice",
    view: "ready",
  });
}

for (const item of curationItems.filter((entry) => entry.status === "open")) {
  const nodeId = item.node_id ?? item.source_issue_id ?? item.item_id;
  const relatedRequest = requestRows.find((request) =>
    Boolean(nodeId) &&
    (request.protocol_ids.includes(nodeId ?? "") ||
      request.paper_ids.includes(nodeId ?? "") ||
      request.slice_ids.includes(nodeId ?? "") ||
      request.finding_ids.includes(nodeId ?? "")),
  );
  const needsDataset = item.action_type.includes("dataset");
  const needsSlice = item.action_type.includes("vertical slice");
  coverageGapRows.push({
    blocker: item.action_type,
    cells: {
      raw_data: needsDataset ? "missing" : "unknown",
      trial_table: "missing",
      figure_source: "unknown",
      findings: "missing",
      model_fits: "missing",
      reports: needsSlice ? "missing" : "unknown",
      source_request: relatedRequest
        ? requestCellState(relatedRequest.action_state ?? relatedRequest.status)
        : "unknown",
    },
    chips: [item.source_issue_type, item.node_type ?? "", relatedRequest ? relatedRequest.status : ""].filter(Boolean),
    detail: item.message,
    href: hrefForNode(nodeId, item.node_type),
    id: `curation:${item.item_id}`,
    next_action: item.suggested_next_step,
    priority: item.priority,
    request_href: relatedRequest?.request_export_path,
    request_label: relatedRequest ? label(relatedRequest.status) : null,
    source: "curation queue",
    status: item.status,
    target_id: nodeId,
    target_label: item.node_label ?? compactId(nodeId),
    target_type: item.node_type ?? "record",
    view: "extraction",
  });
}

const sectionLinks = [
  { id: "gap-matrix", label: "Gap matrix" },
  { id: "audit", label: "Reproducibility audit" },
  { id: "curation", label: "Curation queue" },
  { id: "blockers", label: "External data blockers" },
  { id: "roadmap", label: "Coverage roadmap" },
  { id: "links", label: "Link integrity" },
];

const headlineCounts = {
  audit_status: audit.overall_status,
  curation_open: curationCounts.open ?? 0,
  blockers: blockerGroups.length,
  roadmap_total: roadmapItems.length,
  link_issues: linkIntegrity.counts.issues,
};
---

<BaseLayout
  title="Atlas health · behavtaskatlas"
  description="Reproducibility audit, curation queue, external data blockers, model coverage roadmap, and link integrity for the atlas."
  width="wide"
>
  <PageHeader
    title="Atlas health"
    lede="Operational status of the atlas: pooled-vs-by-subject reconciliation, open curation tasks, external data blockers, the model-coverage roadmap, and internal link integrity. CI runs each check on every commit; this page is the latest committed result."
  />

  <SectionAnchorNav items={sectionLinks} />

  <StatGrid cols={5} class="mb-10">
    <Card href="#audit" padding="sm">
      <p class="text-eyebrow uppercase text-fg-muted">Audit</p>
      <span class="mt-1 inline-block">
        <StatusPill
          tone={
            headlineCounts.audit_status === "ok"
              ? "ok"
              : headlineCounts.audit_status === "drift"
                ? "bad"
                : headlineCounts.audit_status === "ambiguous"
                  ? "warn"
                  : "neutral"
          }
        >
          {headlineCounts.audit_status}
        </StatusPill>
      </span>
    </Card>
    <Stat label="Curation open" value={headlineCounts.curation_open} href="#curation" />
    <Stat label="Blocker groups" value={headlineCounts.blockers} href="#blockers" />
    <Stat label="Roadmap items" value={headlineCounts.roadmap_total} href="#roadmap" />
    <Stat label="Link issues" value={headlineCounts.link_issues} href="#links" />
  </StatGrid>

  <Section
    id="gap-matrix"
    spacing="lg"
    title="Gap matrix"
    description="One board for local implementation targets, external data blockers, and extraction gaps. Rows are generated from the curation queue, data-request records, and model-coverage roadmap."
  >
    <CoverageGapMatrix client:load rows={coverageGapRows} />
  </Section>

  <Section
    id="audit"
    spacing="lg"
    title="Reproducibility audit"
    description="For each (paper × curve type × condition) group with both a pooled finding and ≥2 per-subject findings, the audit recomputes the n-weighted aggregate of the subject curves and compares to the pooled curve at every matching x."
  >
    <Card padding="md" class="mb-4">
      <div class="flex flex-wrap items-baseline gap-3">
        <span class={`rounded px-2 py-0.5 text-body-xs uppercase ${statusClass(audit.overall_status)}`}>
          {audit.overall_status}
        </span>
        <p class="text-body text-fg-secondary">
          {audit.n_groups_audited} group{audit.n_groups_audited === 1 ? "" : "s"} audited.
        </p>
        <p class="text-body-xs text-fg-muted">
          max |diff| = {fmt(audit.overall_max_abs_diff)} (tolerance {fmt(audit.tolerance, 4)})
        </p>
        <p class="ml-auto text-mono-id text-fg-muted">
          local: <code class="rounded bg-surface-sunken px-1">uv run behavtaskatlas audit-findings</code>
        </p>
      </div>
    </Card>
    {auditReports.length === 0 ? (
      <p class="rounded-md border border-rule bg-surface-raised p-4 text-sm text-fg-muted">
        No groups currently meet the audit criteria (≥1 pooled + ≥2 per-subject).
      </p>
    ) : (
      <DataTable
        columns={[
          { label: "Paper" },
          { label: "Curve" },
          { label: "Condition" },
          { label: "Subjects", align: "right" },
          { label: "x overlap", align: "right" },
          { label: "max |diff|", align: "right" },
          { label: "Status" },
        ]}
      >
        {auditReports.map((r) => (
          <tr>
            <td class="px-3 py-2">
              <a class="font-mono text-mono-id" href={`/papers/${slugForId(r.paper_id)}`}>
                {r.paper_id}
              </a>
            </td>
            <td class="px-3 py-2 text-body-xs">{r.curve_type}</td>
            <td class="px-3 py-2 text-body-xs text-fg-secondary">{r.condition || "—"}</td>
            <td class="px-3 py-2 text-right font-mono">{r.n_subjects ?? "—"}</td>
            <td class="px-3 py-2 text-right font-mono">{r.n_x_overlap ?? "—"}</td>
            <td class="px-3 py-2 text-right font-mono">{fmt(r.max_abs_diff)}</td>
            <td class="px-3 py-2">
              <span class={`rounded px-2 py-0.5 text-body-xs uppercase ${statusClass(r.status)}`}>
                {r.status}
              </span>
            </td>
          </tr>
        ))}
      </DataTable>
    )}
    <div class="mt-4 space-y-3">
      {auditReports
        .filter((r) => r.status !== "ok" && Array.isArray(r.per_point))
        .map((r) => (
          <details class="rounded-md border border-rule bg-surface-raised p-4">
            <summary class="cursor-pointer text-sm font-semibold text-fg-secondary">
              {r.paper_id} · {r.curve_type}
              {r.condition ? ` · ${r.condition}` : ""} — per-point detail
            </summary>
            <div class="mt-3 overflow-x-auto">
              <table class="w-full text-xs">
                <thead class="text-left text-[11px] uppercase tracking-wide text-fg-muted">
                  <tr>
                    <th class="px-2 py-1 text-right">x</th>
                    <th class="px-2 py-1 text-right">pooled y</th>
                    <th class="px-2 py-1 text-right">aggregated y</th>
                    <th class="px-2 py-1 text-right">|diff|</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-rule">
                  {(r.per_point as AuditPerPoint[]).map((p) => (
                    <tr>
                      <td class="px-2 py-1 text-right font-mono">{p.x}</td>
                      <td class="px-2 py-1 text-right font-mono">{fmt(p.pooled_y, 4)}</td>
                      <td class="px-2 py-1 text-right font-mono">{fmt(p.agg_y, 4)}</td>
                      <td class="px-2 py-1 text-right font-mono">{fmt(p.abs_diff, 4)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        ))}
    </div>
  </Section>

  <Section
    id="curation"
    spacing="lg"
    title="Curation queue"
    description={`${curationCounts.open ?? 0} open of ${curationCounts.items ?? 0} total · generated ${curationQueue.generated_at}. Items come from the relationship-graph QA pass: orphan records, missing reciprocal links, coverage gaps.`}
  >
    {curationItems.length === 0 ? (
      <p class="rounded-md border border-ok bg-ok-soft p-4 text-sm text-ok">
        Curation queue is empty in the current commit.
      </p>
    ) : (
      <>
        <div class="mb-4 grid grid-cols-1 gap-3 md:grid-cols-2">
          <Card padding="md">
            <h3 class="mb-2 text-h3 text-fg-secondary">By priority</h3>
            <ul class="space-y-1 text-body">
              {Object.entries(priorityCounts).map(([k, v]) => (
                <li class="flex justify-between">
                  <span class="text-fg-secondary">{k}</span>
                  <span class="font-mono text-fg">{v}</span>
                </li>
              ))}
            </ul>
          </Card>
          <Card padding="md">
            <h3 class="mb-2 text-h3 text-fg-secondary">By action type</h3>
            <ul class="space-y-1 text-body">
              {Object.entries(actionCounts).map(([k, v]) => (
                <li class="flex justify-between">
                  <span class="text-fg-secondary">{k}</span>
                  <span class="font-mono text-fg">{v}</span>
                </li>
              ))}
            </ul>
          </Card>
        </div>
        {curationGrouped.map((group) => (
          <div class="mb-6">
            <h3 class="mb-2 text-base font-semibold capitalize text-fg">
              {group.priority} priority{" "}
              <span class="text-sm font-normal text-fg-muted">
                ({group.items.length})
              </span>
            </h3>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li class="rounded-md border border-rule bg-surface-raised p-3 text-sm">
                  <header class="mb-1 flex items-baseline justify-between gap-2">
                    <span class="font-medium">{item.action_type}</span>
                    <span
                      class:list={[
                        "rounded px-2 py-0.5 text-xs",
                        priorityClasses[item.priority],
                      ]}
                    >
                      {item.priority}
                    </span>
                  </header>
                  <p class="mb-1 text-fg-secondary">{item.message}</p>
                  <p class="text-xs text-fg-muted">Next: {item.suggested_next_step}</p>
                  {item.node_id ? (
                    <p class="mt-1 font-mono text-xs text-fg-muted">{item.node_id}</p>
                  ) : null}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </>
    )}
  </Section>

  <Section
    id="blockers"
    spacing="lg"
    title="External data blockers"
  >
    <Fragment slot="action">
      <a class="text-body-xs text-accent" href="/data_requests.csv">data_requests.csv</a>
    </Fragment>
    <p class="mb-4 max-w-prose text-body text-fg-secondary">
      Roadmap rows that cannot be closed by another local fit or adapter
      pass — the missing source files have to be requested or located.
      Tracked separately so proxy-backed model wins remain visible.
    </p>

    <StatGrid cols={5} class="mb-6">
      <Stat label="Blocker groups" value={blockerGroups.length} />
      <Stat
        label="Roadmap rows"
        value={blockedItems.length}
        hint={`high priority ${blockedPriorityHigh}`}
      />
      <Stat label="Findings affected" value={affectedFindingCount} />
      <Stat
        label="Active requests"
        value={activeRequestCount}
        hint={`ready ${readyRequestCount}`}
      />
      <Stat label="Follow-up due" value={followUpDueCount} />
    </StatGrid>

    {requestQueueGroups.length > 0 ? (
      <div class="mb-6">
        <h3 class="mb-3 text-base font-semibold text-fg">Request queue</h3>
        <div class="grid grid-cols-1 gap-3 lg:grid-cols-2">
          {requestQueueGroups.map((group) => (
            <section class="rounded-md border border-rule bg-surface-raised p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs uppercase tracking-wide text-fg-muted">Queue state</p>
                  <h4 class="mt-1 text-sm font-semibold text-fg">
                    {label(group.actionState)}
                  </h4>
                </div>
                <span class="rounded bg-surface-sunken px-2 py-1 font-mono text-xs text-fg-secondary">
                  {group.requests.length}
                </span>
              </div>
              <ul class="mt-3 divide-y divide-rule text-sm">
                {group.requests.map((request) => (
                  <li class="py-3 first:pt-0 last:pb-0">
                    <div class="flex flex-wrap items-start justify-between gap-2">
                      <div>
                        {request.request_export_path ? (
                          <a class="font-semibold text-fg" href={request.request_export_path}>
                            {request.title}
                          </a>
                        ) : (
                          <span class="font-semibold text-fg">{request.title}</span>
                        )}
                        <p class="mt-0.5 font-mono text-[11px] text-fg-muted">
                          {compactId(request.request_id)}
                        </p>
                      </div>
                      <span class="rounded bg-accent-soft px-2 py-1 text-[10px] uppercase text-accent">
                        {label(request.priority)}
                      </span>
                    </div>
                    {request.action_summary ? (
                      <p class="mt-2 text-xs text-fg-secondary">{request.action_summary}</p>
                    ) : null}
                    <dl class="mt-2 grid grid-cols-1 gap-2 text-xs sm:grid-cols-2">
                      <div>
                        <dt class="uppercase text-fg-muted">Last event</dt>
                        <dd class="mt-0.5 text-fg-secondary">
                          {label(request.last_event_type)}
                          {request.days_since_last_event !== null && request.days_since_last_event !== undefined
                            ? ` · ${request.days_since_last_event} day(s)`
                            : ""}
                        </dd>
                      </div>
                      <div>
                        <dt class="uppercase text-fg-muted">Follow-up</dt>
                        <dd class="mt-0.5 text-fg-secondary">
                          {formatDate(request.next_follow_up_date)}
                          {request.days_until_follow_up !== null && request.days_until_follow_up !== undefined
                            ? ` · ${request.days_until_follow_up} day(s)`
                            : ""}
                        </dd>
                      </div>
                    </dl>
                    {request.suggested_command ? (
                      <pre class="mt-2 whitespace-pre-wrap break-words rounded bg-surface p-2 font-mono text-[11px] text-fg-secondary">{request.suggested_command}</pre>
                    ) : null}
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>
    ) : null}

    {blockerGroups.length === 0 ? (
      <Card padding="md" surface="ok" border="tinted" class="text-body text-ok">
        No external data blockers in the current roadmap.
      </Card>
    ) : (
      <div class="space-y-4">
        {blockerGroups.map((group) => {
          const request = requestForGroup(group);
          return (
            <Card padding="none">
              <header class="border-b border-rule p-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="text-xs uppercase tracking-wide text-fg-muted">
                      {label(group.blocker_type)}
                    </p>
                    <h3 class="mt-1 text-base font-semibold">
                      <a href={group.dataset_href}>{group.dataset_name}</a>
                    </h3>
                    <p class="mt-1 text-xs text-fg-muted">
                      {group.species} · {group.protocol_name} · {group.source_data_level}
                    </p>
                  </div>
                  <span class="rounded bg-bad-soft px-2 py-1 text-xs uppercase text-bad">
                    blocked external data
                  </span>
                </div>
              </header>
              <div class="grid grid-cols-1 gap-4 p-4 lg:grid-cols-[1fr_0.75fr]">
                <div>
                  <h4 class="text-sm font-semibold text-fg-secondary">Blocker</h4>
                  <p class="mt-1 text-sm text-fg-secondary">{group.blocker_detail}</p>
                  <h4 class="mt-4 text-sm font-semibold text-fg-secondary">Next action</h4>
                  <p class="mt-1 text-sm text-fg-secondary">{group.next_action}</p>
                  <div class="mt-4 flex flex-wrap gap-2 text-xs">
                    <a class="rounded bg-surface-sunken px-2 py-1" href={group.paper_href}>
                      {group.paper_label}
                    </a>
                    <a class="rounded bg-surface-sunken px-2 py-1" href={group.slice_href}>
                      {compactId(group.slice_id)}
                    </a>
                    {group.source_url ? (
                      <a class="rounded bg-surface-sunken px-2 py-1" href={group.source_url}>
                        source package
                      </a>
                    ) : null}
                  </div>
                  {request ? (
                    <section class="mt-5 rounded border border-rule p-3">
                      <div class="flex flex-wrap items-baseline justify-between gap-3">
                        <div>
                          <p class="text-xs uppercase tracking-wide text-fg-muted">Tracked request</p>
                          <h4 class="mt-1 text-sm font-semibold text-fg">{request.title}</h4>
                        </div>
                        <div class="flex flex-wrap items-center gap-2">
                          {request.request_export_path ? (
                            <a
                              class="rounded border border-accent px-2 py-1 text-[10px] uppercase text-accent"
                              href={request.request_export_path}
                            >
                              request .md
                            </a>
                          ) : null}
                          <span class="rounded bg-accent-soft px-2 py-1 text-[10px] uppercase text-accent">
                            {label(request.status)}
                          </span>
                        </div>
                      </div>
                      <p class="mt-2 text-sm text-fg-secondary">{request.purpose}</p>
                      {request.action_summary ? (
                        <p class="mt-2 text-xs text-accent">{request.action_summary}</p>
                      ) : null}
                      {request.suggested_command ? (
                        <pre class="mt-2 whitespace-pre-wrap break-words rounded bg-surface p-2 font-mono text-[11px] text-fg-secondary">{request.suggested_command}</pre>
                      ) : null}
                      {(request.events ?? []).length > 0 ? (
                        <details class="mt-3">
                          <summary class="cursor-pointer text-xs font-semibold text-fg-secondary">
                            Timeline ({(request.events ?? []).length})
                          </summary>
                          <ol class="mt-2 space-y-2 border-l border-rule pl-3 text-xs">
                            {(request.events ?? []).map((event) => (
                              <li>
                                <div class="flex flex-wrap items-baseline gap-2">
                                  <span class="font-semibold text-fg-secondary">
                                    {label(event.event_type)}
                                  </span>
                                  <span class="font-mono text-[11px] text-fg-muted">
                                    {event.event_date}
                                  </span>
                                  <span class="text-[11px] text-fg-muted">
                                    {event.actor}
                                  </span>
                                </div>
                                <p class="mt-0.5 text-fg-muted">{event.notes}</p>
                                {event.next_follow_up_date ? (
                                  <p class="mt-0.5 text-[11px] text-accent">
                                    Follow up {event.next_follow_up_date}
                                  </p>
                                ) : null}
                                {event.evidence_url ? (
                                  <a class="text-[11px] text-accent" href={event.evidence_url}>
                                    evidence
                                  </a>
                                ) : event.evidence_path ? (
                                  <p class="font-mono text-[11px] text-fg-muted">
                                    {event.evidence_path}
                                  </p>
                                ) : null}
                              </li>
                            ))}
                          </ol>
                        </details>
                      ) : null}
                      {request.request_draft ? (
                        <details class="mt-3 rounded border border-rule p-3">
                          <summary class="cursor-pointer text-xs font-semibold text-fg-secondary">
                            Ready-to-send request draft
                          </summary>
                          <p class="mt-3 text-xs font-semibold text-fg-secondary">
                            {request.request_draft.subject}
                          </p>
                          <pre class="mt-2 whitespace-pre-wrap rounded bg-surface p-3 text-xs text-fg-secondary">{request.request_draft.body}</pre>
                        </details>
                      ) : null}
                    </section>
                  ) : null}
                </div>
                <aside class="rounded border border-rule p-3">
                  <dl class="grid grid-cols-2 gap-x-3 gap-y-2 text-xs">
                    <dt class="text-fg-muted">Roadmap rows</dt>
                    <dd class="font-mono text-fg">{group.items.length}</dd>
                    <dt class="text-fg-muted">Findings</dt>
                    <dd class="font-mono text-fg">{group.finding_ids.length}</dd>
                    <dt class="text-fg-muted">Σ trials</dt>
                    <dd class="font-mono text-fg">
                      {group.total_trials.toLocaleString()}
                    </dd>
                    <dt class="text-fg-muted">Dataset</dt>
                    <dd class="font-mono text-[11px] text-fg-secondary">
                      {compactId(group.dataset_id)}
                    </dd>
                  </dl>
                  {group.comparison_scopes.length > 0 ? (
                    <>
                      <h4 class="mt-4 text-xs font-semibold uppercase text-fg-muted">Scopes</h4>
                      <ul class="mt-2 flex flex-wrap gap-1">
                        {group.comparison_scopes.map((scope) => (
                          <li class="rounded bg-accent-soft px-1.5 py-0.5 text-[10px] text-accent">
                            {label(scope)}
                          </li>
                        ))}
                      </ul>
                    </>
                  ) : null}
                  {group.caveat_tags.length > 0 ? (
                    <>
                      <h4 class="mt-4 text-xs font-semibold uppercase text-fg-muted">Caveats</h4>
                      <ul class="mt-2 flex flex-wrap gap-1">
                        {group.caveat_tags.map((tag) => (
                          <li class="rounded bg-warn-soft px-1.5 py-0.5 text-[10px] text-warn">
                            {label(tag)}
                          </li>
                        ))}
                      </ul>
                    </>
                  ) : null}
                </aside>
              </div>
              <div class="border-t border-rule">
                <div class="max-h-72 overflow-auto">
                  <table class="w-full text-body">
                    <thead class="bg-surface text-left text-body-xs uppercase text-fg-muted">
                      <tr>
                        <th class="px-3 py-2">Rank</th>
                        <th class="px-3 py-2">Finding</th>
                        <th class="px-3 py-2">Curve</th>
                        <th class="px-3 py-2">Scope</th>
                        <th class="px-3 py-2">Impact</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-rule">
                      {group.items.map((item) => (
                        <tr>
                          <td class="px-3 py-2 font-mono text-body-xs">{item.rank}</td>
                          <td class="px-3 py-2 font-mono text-mono-id">
                            {item.finding_id ? (
                              <a href={hrefForFinding(item.finding_id)}>
                                {compactId(item.finding_id)}
                              </a>
                            ) : (
                              compactId(item.target_id)
                            )}
                          </td>
                          <td class="px-3 py-2 text-body-xs text-fg-secondary">
                            {label(item.curve_type)}
                          </td>
                          <td class="px-3 py-2 text-body-xs text-fg-secondary">
                            {label(item.comparison_scope)}
                          </td>
                          <td class="px-3 py-2 text-body-xs text-fg-secondary">{item.impact}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </Card>
          );
        })}
      </div>
    )}
  </Section>

  <Section
    id="roadmap"
    spacing="lg"
    title="Coverage roadmap"
    description={`Ranked from coverage gaps, comparison-scope warnings, caveats, and near-miss slice capabilities. Top ${topRoadmapItems.length} shown; full export: model_roadmap.csv.`}
  >
    <Fragment slot="action">
      <div class="flex flex-wrap gap-2">
        <StatusPill tone="warn">high {roadmap.counts?.by_priority?.high ?? 0}</StatusPill>
        <StatusPill tone="accent">medium {roadmap.counts?.by_priority?.medium ?? 0}</StatusPill>
        <StatusPill tone="neutral">low {roadmap.counts?.by_priority?.low ?? 0}</StatusPill>
        <StatusPill tone="bad">
          blocked {roadmap.counts?.by_status?.blocked_external_data ?? 0}
        </StatusPill>
      </div>
    </Fragment>
    <div class="overflow-x-auto rounded-md border border-rule bg-surface-raised">
      <table class="w-full text-sm">
        <thead class="bg-surface text-left text-xs uppercase tracking-wide text-fg-muted">
          <tr>
            <th class="px-3 py-2">Rank</th>
            <th class="px-3 py-2">Target</th>
            <th class="px-3 py-2">Issue</th>
            <th class="px-3 py-2">Action</th>
            <th class="px-3 py-2">Impact</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-rule">
          {topRoadmapItems.map((item) => (
            <tr>
              <td class="px-3 py-2 align-top">
                <p class="font-mono text-xs">{item.rank}</p>
                <span class={`mt-1 inline-block rounded px-1.5 py-0.5 text-[10px] uppercase ${priorityClass(item.priority_label)}`}>
                  {item.priority_label}
                </span>
                <span class={`mt-1 block w-fit rounded px-1.5 py-0.5 text-[10px] uppercase ${roadmapStatusClass(item.status)}`}>
                  {roadmapStatusLabel(item.status)}
                </span>
              </td>
              <td class="px-3 py-2 align-top">
                <a class="font-mono text-[11px]" href={roadmapHref(item)}>
                  {item.target_id.replace(/^(finding|slice)\./, "")}
                </a>
                <p class="mt-1 text-[11px] text-fg-muted">{item.target_type}</p>
              </td>
              <td class="px-3 py-2 align-top">
                <span class="rounded bg-surface-sunken px-1.5 py-0.5 text-[10px] uppercase text-fg-muted">
                  {issueLabel(item.issue_type)}
                </span>
              </td>
              <td class="px-3 py-2 align-top text-xs text-fg-secondary">
                {item.recommended_action}
                {item.blocker_type ? (
                  <p class="mt-1 text-[11px] uppercase text-bad">
                    {item.blocker_type.replace(/_/g, " ")}
                  </p>
                ) : null}
              </td>
              <td class="px-3 py-2 align-top text-xs text-fg-muted">{item.impact}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <Section
    id="links"
    spacing="md"
    title="Link integrity"
    description="Internal links checked against the set of generated routes (search, graph, curation queue, finding provenance, model selection)."
  >
    <div class="mb-4 rounded-md border border-rule bg-surface-raised p-4">
      <div class="flex flex-wrap items-baseline gap-3">
        <span class={`rounded px-2 py-0.5 text-xs uppercase ${statusClass(linkIntegrity.overall_status)}`}>
          {linkIntegrity.overall_status}
        </span>
        <p class="text-sm text-fg-secondary">
          {linkIntegrity.counts.checked_links} link{linkIntegrity.counts.checked_links === 1 ? "" : "s"} checked against {linkIntegrity.counts.known_routes} routes.
        </p>
        <p class="text-xs text-fg-muted">
          {linkIntegrity.counts.issues} issue{linkIntegrity.counts.issues === 1 ? "" : "s"}.
        </p>
      </div>
    </div>
    {linkIssues.length === 0 ? (
      <Card padding="md" class="text-body text-fg-secondary">
        No missing internal routes detected.
      </Card>
    ) : (
      <DataTable
        columns={[
          { label: "Source" },
          { label: "Href" },
          { label: "Issue" },
        ]}
      >
        {linkIssues.map((issue) => (
          <tr>
            <td class="px-3 py-2 font-mono text-mono-id">{issue.source}</td>
            <td class="px-3 py-2 font-mono text-mono-id">{issue.href}</td>
            <td class="px-3 py-2 text-body-xs text-fg-secondary">{issue.message}</td>
          </tr>
        ))}
      </DataTable>
    )}
  </Section>
</BaseLayout>
