---
import BaseLayout from "../layouts/BaseLayout.astro";
import AtlasOverview from "../components/AtlasOverview.astro";
import LiveFitHero from "../components/LiveFitHero.svelte";
import MiniFindingsChart from "../components/MiniFindingsChart.svelte";
import ThresholdDistribution from "../components/ThresholdDistribution.svelte";
import AggregateBySpecies from "../components/AggregateBySpecies.svelte";
import Card from "../components/ui/Card.astro";
import ObjectModelStrip from "../components/ui/ObjectModelStrip.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import QueryLanes from "../components/QueryLanes.astro";
import Section from "../components/ui/Section.astro";
import Stat from "../components/ui/Stat.astro";
import StatGrid from "../components/ui/StatGrid.astro";
import {
  audit,
  catalog,
  curationQueue,
  hrefForFinding,
  linkIntegrity,
  manifest,
  models,
  papers,
  recent,
} from "../lib/data";
import StatusPill from "../components/ui/StatusPill.astro";
import {
  comparisons,
  findings,
  type FindingsEntry,
} from "../lib/findings";
import { featuredStory as pickFeaturedStory } from "../lib/stories";

const featured = pickFeaturedStory(
  (recent.family_last_added ?? {}) as Record<string, string>,
);
const featuredStory = featured.story;

// Pick a hero finding for the live-fit demo. We want a clean,
// reasonably-many-x psychometric with high trial counts so the Wilson
// CI bars come out tight and the 4-param fit is well-determined. The
// selection is deterministic — same finding on every visit — so the
// demo doubles as an honest preview of "this is what the atlas does".
function pickHeroFinding(): FindingsEntry | null {
  const candidates = (findings.findings as FindingsEntry[])
    .filter(
      (entry) =>
        entry.curve_type === "psychometric" &&
        !entry.stratification?.subject_id &&
        entry.points.length >= 8 &&
        (entry.n_trials ?? 0) > 1000,
    )
    .sort(
      (a, b) =>
        b.points.length * 100 + Math.floor((b.n_trials ?? 0) / 100) -
        (a.points.length * 100 + Math.floor((a.n_trials ?? 0) / 100)),
    );
  return candidates[0] ?? null;
}

const heroFinding = pickHeroFinding();

const objectModelCounts = {
  families: catalog.counts.task_families ?? catalog.task_families.length,
  protocols: catalog.counts.protocols ?? catalog.protocols.length,
  datasets: catalog.counts.datasets ?? catalog.datasets.length,
  slices: catalog.counts.vertical_slices ?? catalog.vertical_slices.length,
  findings: findings.counts.findings ?? findings.findings.length,
};

type FitFields = {
  mu: number;
  sigma: number;
  gamma: number;
  lapse: number;
  threshold?: number;
  threshold_target_y: number;
};

function median(values: number[]): number | null {
  const finite = values.filter((v) => Number.isFinite(v));
  if (finite.length === 0) return null;
  const sorted = [...finite].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 === 1
    ? sorted[mid]
    : (sorted[mid - 1] + sorted[mid]) / 2;
}

const psychometricFits = (findings.findings as FindingsEntry[]).filter(
  (f) =>
    f.curve_type === "psychometric" &&
    (f as FindingsEntry & { fit?: FitFields | null }).fit?.threshold !== undefined,
);

const allSigma = psychometricFits.map(
  (f) => (f as FindingsEntry & { fit: FitFields }).fit.sigma,
);
const allThreshold = psychometricFits.map(
  (f) => (f as FindingsEntry & { fit: FitFields }).fit.threshold!,
);
const allBias = psychometricFits.map(
  (f) => (f as FindingsEntry & { fit: FitFields }).fit.mu,
);

type SpeciesRow = {
  species: string;
  n_findings: number;
  median_sigma: number | null;
  median_threshold: number | null;
  total_trials: number;
  sigmas: number[];
  href: string;
};

const speciesGroups = new Map<string, FindingsEntry[]>();
for (const f of findings.findings as FindingsEntry[]) {
  if (f.curve_type !== "psychometric") continue;
  const fit = (f as FindingsEntry & { fit?: FitFields | null }).fit;
  if (!fit || fit.threshold === undefined) continue;
  const sp = f.species ?? "unknown";
  if (!speciesGroups.has(sp)) speciesGroups.set(sp, []);
  speciesGroups.get(sp)!.push(f);
}

const speciesRows: SpeciesRow[] = Array.from(speciesGroups.entries())
  .map(([species, fs]) => ({
    species,
    n_findings: fs.length,
    median_sigma: median(
      fs.map((f) => (f as FindingsEntry & { fit: FitFields }).fit.sigma),
    ),
    median_threshold: median(
      fs.map((f) => (f as FindingsEntry & { fit: FitFields }).fit.threshold!),
    ),
    total_trials: fs.reduce(
      (sum, f) => sum + (typeof f.n_trials === "number" ? f.n_trials : 0),
      0,
    ),
    sigmas: fs
      .map((f) => (f as FindingsEntry & { fit: FitFields }).fit.sigma)
      .filter((s) => Number.isFinite(s)),
    href: `/findings?q=${encodeURIComponent(species)}`,
  }))
  .sort((a, b) => b.n_findings - a.n_findings);

const aggregateStats = {
  n_psychometric_findings: psychometricFits.length,
  median_sigma: median(allSigma),
  median_threshold: median(allThreshold),
  median_bias: median(allBias),
  total_trials_psychometric: psychometricFits.reduce(
    (sum, f) => sum + (typeof f.n_trials === "number" ? f.n_trials : 0),
    0,
  ),
};

// Implication line for the aggregate panel. Computes the σ ratio
// between the steepest- and shallowest-slope species so we can replace
// "median σ = 0.42" with something that actually means something to a
// scientist. Uses the species rows already computed above.
const sigmasWithMedian = speciesRows
  .filter((r) => r.median_sigma !== null && Number.isFinite(r.median_sigma))
  .map((r) => ({ species: r.species, sigma: r.median_sigma! }))
  .sort((a, b) => a.sigma - b.sigma);
const steepest = sigmasWithMedian[0] ?? null;
const shallowest = sigmasWithMedian[sigmasWithMedian.length - 1] ?? null;
const slopeFold =
  steepest && shallowest && steepest.sigma > 0
    ? shallowest.sigma / steepest.sigma
    : null;

// Threshold distribution chart — pool on the dominant stimulus axis so
// the points are actually comparable. Different axes (signed coherence,
// signed contrast, signed click difference) have incommensurate units
// and would mislead if mixed. Group by (x_label, x_units), pick the
// largest group, plot the rest as a strip.
type ThresholdRow = {
  finding_id: string;
  href: string;
  paper_label: string;
  species: string;
  threshold: number;
};

const axisCounts = new Map<
  string,
  { label: string; units: string; rows: ThresholdRow[] }
>();
for (const f of psychometricFits) {
  if (f.stratification?.subject_id) continue; // only pooled / per-condition
  const fit = (f as FindingsEntry & { fit: FitFields }).fit;
  if (!Number.isFinite(fit.threshold ?? NaN)) continue;
  const label = f.x_label ?? "x";
  const units = f.x_units ?? "";
  const key = `${label}|${units}`;
  const bucket =
    axisCounts.get(key) ?? { label, units, rows: [] as ThresholdRow[] };
  bucket.rows.push({
    finding_id: f.finding_id,
    href: `/findings/${f.finding_id.replace("finding.", "")}`,
    paper_label: f.paper_citation.split(".")[0] ?? f.paper_id,
    species: f.species ?? "unknown",
    threshold: fit.threshold as number,
  });
  axisCounts.set(key, bucket);
}
const dominantAxisEntry = Array.from(axisCounts.values()).sort(
  (a, b) => b.rows.length - a.rows.length,
)[0];
const thresholdRows = dominantAxisEntry?.rows ?? [];
const thresholdAxisLabel = dominantAxisEntry
  ? dominantAxisEntry.units
    ? `x at 75% (${dominantAxisEntry.label}, ${dominantAxisEntry.units})`
    : `x at 75% (${dominantAxisEntry.label})`
  : "x at 75%";
const thresholdMedian = median(thresholdRows.map((r) => r.threshold));

const featuredComparison = comparisons.comparisons[0] ?? null;
const featuredFindingIds = ((featuredComparison?.finding_ids ?? []) as string[]);
const featuredFindings = featuredComparison
  ? (findings.findings as FindingsEntry[]).filter((f) =>
      featuredFindingIds.includes(f.finding_id),
    )
  : [];

// Compute real Δμ / Δσ / Δthreshold across the comparison's findings
// so the headline reads as a numeric claim instead of a question. We
// take the spread (max − min) on each axis when the comparison has 2+
// findings with fits; for two-finding comparisons this is just the
// difference between them.
type DeltaSummary = {
  mu_min: number; mu_max: number; mu_delta: number;
  sigma_min: number; sigma_max: number; sigma_delta: number; sigma_fold: number | null;
  threshold_min: number; threshold_max: number; threshold_delta: number;
  primary: "mu" | "sigma" | "threshold";
};

function axisFromHint(hint: string | null | undefined): "mu" | "sigma" | "threshold" | null {
  if (!hint) return null;
  const h = hint.toLowerCase();
  // Order matters: a hint can mention multiple axes (e.g. "μ moves and σ
  // stays put"). The first one wins, since that's the curator's framing.
  for (const [needle, axis] of [
    ["σ", "sigma"],
    ["sigma", "sigma"],
    ["slope", "sigma"],
    ["μ", "mu"],
    ["mu", "mu"],
    ["bias", "mu"],
    ["threshold", "threshold"],
  ] as const) {
    if (h.includes(needle)) return axis;
  }
  return null;
}

function comparisonDeltas(
  rows: FindingsEntry[],
  hint: string | null | undefined,
): DeltaSummary | null {
  const fits = rows
    .map((r) => (r as FindingsEntry & { fit?: FitFields | null }).fit)
    .filter((fit): fit is FitFields => Boolean(fit) && fit!.threshold !== undefined);
  if (fits.length < 2) return null;
  const mus = fits.map((f) => f.mu);
  const sigmas = fits.map((f) => f.sigma);
  const thresholds = fits.map((f) => f.threshold!);
  const mu_min = Math.min(...mus);
  const mu_max = Math.max(...mus);
  const sigma_min = Math.min(...sigmas);
  const sigma_max = Math.max(...sigmas);
  const threshold_min = Math.min(...thresholds);
  const threshold_max = Math.max(...thresholds);
  const sigma_delta = sigma_max - sigma_min;
  const mu_delta = mu_max - mu_min;
  const threshold_delta = threshold_max - threshold_min;
  // The comparison record's hint is the curator's framing — if it
  // names an axis ("Compare Δσ", "μ moves and σ stays put"), feature
  // that axis. Otherwise fall back to the largest normalized spread,
  // which still does the right thing on uncurated comparisons.
  const hinted = axisFromHint(hint);
  const score = (delta: number, scale: number) =>
    scale > 0 ? delta / scale : 0;
  const muScore = score(mu_delta, Math.max(Math.abs(mu_max), Math.abs(mu_min)));
  const sigmaScore = score(sigma_delta, Math.max(Math.abs(sigma_max), Math.abs(sigma_min)));
  const thresholdScore = score(threshold_delta, Math.max(Math.abs(threshold_max), Math.abs(threshold_min)));
  const primary: "mu" | "sigma" | "threshold" =
    hinted ??
    (sigmaScore >= muScore && sigmaScore >= thresholdScore
      ? "sigma"
      : muScore >= thresholdScore
        ? "mu"
        : "threshold");
  return {
    mu_min, mu_max, mu_delta,
    sigma_min, sigma_max, sigma_delta,
    sigma_fold: sigma_min > 0 ? sigma_max / sigma_min : null,
    threshold_min, threshold_max, threshold_delta,
    primary,
  };
}

const featuredDeltas = featuredComparison
  ? comparisonDeltas(
      featuredFindings,
      (featuredComparison as { hint?: string | null }).hint ?? null,
    )
  : null;

function fmt(value: number | null, digits = 2): string {
  if (value === null || !Number.isFinite(value)) return "—";
  return value.toFixed(digits);
}

const generated = manifest.generated_at?.slice(0, 10) ?? "";
const paperCount = papers.counts.papers ?? papers.papers.length;

// Atlas-health status strip — pulled into the home footer so a
// scientist sees operational state at a glance without leaving the
// page. Mirrors the headline counts on /project-health.
const auditStatus = audit.overall_status;
const auditTone =
  auditStatus === "ok"
    ? "ok"
    : auditStatus === "drift"
      ? "bad"
      : auditStatus === "ambiguous"
        ? "warn"
        : "neutral";
const curationOpen = (curationQueue.counts ?? {}).open ?? 0;
const linkIssues = linkIntegrity.counts.issues ?? 0;
const roadmapItems =
  ((models as unknown as {
    model_coverage_roadmap?: { items?: unknown[] };
  }).model_coverage_roadmap?.items ?? []).length;
const blockerHighCount = (
  (models as unknown as {
    model_coverage_roadmap?: { items?: Array<{ status?: string; priority_label?: string }> };
  }).model_coverage_roadmap?.items ?? []
).filter(
  (item) =>
    item.status === "blocked_external_data" &&
    (item.priority_label ?? "").toLowerCase().includes("high"),
).length;

// ───────────────────────────────────────────────────────────────────────
// Query lanes — three entry routes, shaped as queries.
// ───────────────────────────────────────────────────────────────────────

type Pair = { species: string; count: number };
const speciesByCount = new Map<string, number>();
for (const f of findings.findings as FindingsEntry[]) {
  const sp = f.species;
  if (!sp) continue;
  speciesByCount.set(sp, (speciesByCount.get(sp) ?? 0) + 1);
}
const topSpecies: Pair[] = Array.from(speciesByCount.entries())
  .map(([species, count]) => ({ species, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);

const SOURCE_LEVELS: Array<{
  level: "raw-trial" | "processed-trial" | "figure-source-data";
  glyph: "R" | "P" | "F";
  label: string;
}> = [
  { level: "raw-trial", glyph: "R", label: "Raw trials" },
  { level: "processed-trial", glyph: "P", label: "Processed" },
  { level: "figure-source-data", glyph: "F", label: "Figure-traced" },
];

const sourceCounts: Record<string, number> = {};
for (const ds of catalog.datasets) {
  const lvl = ds.source_data_level;
  if (!lvl) continue;
  sourceCounts[lvl] = (sourceCounts[lvl] ?? 0) + 1;
}

const totalComparisons = comparisons.comparisons.length;
const totalSlices = manifest.slices.length;
const totalFindings = findings.counts.findings ?? findings.findings.length;

const lanes: [
  Parameters<typeof QueryLanes>[0]["lanes"][0],
  Parameters<typeof QueryLanes>[0]["lanes"][1],
  Parameters<typeof QueryLanes>[0]["lanes"][2],
] = [
  {
    eyebrow: "Ask a question",
    headline: `${totalComparisons} cross-paper comparisons`,
    subline: featuredComparison
      ? "Hand-curated questions with quantitative parameter deltas across papers."
      : "Cross-paper questions with quantitative parameter deltas.",
    chips: comparisons.comparisons.slice(0, 4).map((c) => ({
      label: c.title ?? c.question.split("?")[0],
      href: `/compare#${c.id}`,
    })),
    footerHref: "/compare",
    footerLabel: "All comparisons",
  },
  {
    eyebrow: "Browse by species",
    headline: `${totalFindings} findings across ${topSpecies.length}+ species`,
    subline:
      "Curves filtered by organism, on shared signed-evidence axes.",
    chips: topSpecies.map((s) => ({
      label: s.species,
      count: s.count,
      href: `/findings?q=${encodeURIComponent(s.species)}`,
    })),
    footerHref: "/findings",
    footerLabel: "All findings",
  },
  {
    eyebrow: "Browse by source depth",
    headline: `${totalSlices} reproducible slices`,
    subline:
      "Filter datasets by source-data depth: raw trials, processed trials, figure-traced.",
    chips: SOURCE_LEVELS.map((s) => ({
      label: s.label,
      count: sourceCounts[s.level] ?? 0,
      glyph: s.glyph,
      href: `/catalog?source=${s.level}`,
    })),
    footerHref: "/catalog",
    footerLabel: "Open catalog",
  },
];
---

<BaseLayout
  title={manifest.title}
  description="A file-first atlas of sensory-guided decision-making tasks in behavioral neuroscience. Browse curated task families, protocols, datasets, vertical slices, and cross-paper findings on shared signed-evidence axes."
  width="wide"
>
  <PageHeader
    title="A file-first atlas of behavioral neuroscience tasks."
  >
    <Fragment slot="lede">
      Curated task records, harmonised data, and cross-paper findings on shared
      axes — every record is YAML in git, every analysis is reproducible, every
      number links back to the dataset that produced it.
    </Fragment>
  </PageHeader>

  <ObjectModelStrip
    counts={objectModelCounts}
    title="The shape of the atlas"
    class="mb-10"
  />

  {heroFinding ? (
    <Section spacing="lg">
      <LiveFitHero
        client:visible
        findingId={heroFinding.finding_id}
        paperCitation={heroFinding.paper_citation}
        species={heroFinding.species ?? null}
        nTrials={heroFinding.n_trials ?? null}
        xLabel={heroFinding.x_label}
        xUnits={heroFinding.x_units ?? null}
        yLabel={heroFinding.y_label}
        points={heroFinding.points.map((p) => ({
          x: p.x,
          y: p.y,
          n: p.n,
          y_lower: (p as { y_lower?: number | null }).y_lower ?? null,
          y_upper: (p as { y_upper?: number | null }).y_upper ?? null,
        }))}
        findingHref={hrefForFinding(heroFinding.finding_id)}
      />
    </Section>
  ) : null}

  <Section eyebrow="Where to start" spacing="lg">
    <QueryLanes lanes={lanes} />
  </Section>

  <AtlasOverview />

  {featuredComparison && featuredFindings.length > 0 ? (
    <Section spacing="lg">
      <Card padding="lg">
        <header class="mb-3 flex flex-wrap items-baseline justify-between gap-3">
          <div class="min-w-0">
            <p class="text-eyebrow uppercase text-accent">Featured comparison</p>
            {featuredDeltas ? (
              <h2 class="mt-1 text-h2 text-fg">
                {featuredDeltas.primary === "sigma" ? (
                  <>
                    σ spans <span class="font-mono">{fmt(featuredDeltas.sigma_min, 2)}</span>
                    {" "}to <span class="font-mono">{fmt(featuredDeltas.sigma_max, 2)}</span>
                    {featuredDeltas.sigma_fold !== null
                      ? <> ({fmt(featuredDeltas.sigma_fold, 1)}× steeper at the steep end)</>
                      : null}
                  </>
                ) : featuredDeltas.primary === "mu" ? (
                  <>
                    μ spans <span class="font-mono">{fmt(featuredDeltas.mu_min, 2)}</span>
                    {" "}to <span class="font-mono">{fmt(featuredDeltas.mu_max, 2)}</span>
                    {" "}(Δμ = <span class="font-mono">{fmt(featuredDeltas.mu_delta, 2)}</span>)
                  </>
                ) : (
                  <>
                    75% threshold spans <span class="font-mono">{fmt(featuredDeltas.threshold_min, 2)}</span>
                    {" "}to <span class="font-mono">{fmt(featuredDeltas.threshold_max, 2)}</span>
                  </>
                )}
              </h2>
            ) : (
              <h2 class="mt-1 text-h2 text-fg">{featuredComparison.question}</h2>
            )}
            <p class="mt-1 text-body text-fg-secondary">
              {featuredComparison.question}
            </p>
          </div>
          <a
            class="text-body-xs no-underline text-accent hover:underline"
            href={`/compare#${featuredComparison.id}`}
          >
            See parameter deltas →
          </a>
        </header>
        <p class="mb-4 max-w-prose text-body text-fg-secondary">
          {featuredComparison.framing}
        </p>
        <MiniFindingsChart
          client:visible
          findings={featuredFindings}
          colorBy={
            featuredComparison.color_by as
              | "paper"
              | "condition"
              | "curve_type"
          }
          height={320}
        />
      </Card>
    </Section>
  ) : null}

  {recent.items.length > 0 ? (
    <section class="mb-10 -mx-4 border-y border-rule bg-surface-sunken px-4 py-5">
      <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
        <p class="text-eyebrow uppercase text-fg-muted">Recently added</p>
        <p class="text-body-xs text-fg-muted">
          As of {recent.as_of} ·
          <span class="ml-1 font-mono text-fg">{recent.counts.findings}</span> findings,
          <span class="ml-1 font-mono text-fg">{recent.counts.papers}</span> papers,
          <span class="ml-1 font-mono text-fg">{recent.counts.slices}</span> slices in the atlas.
        </p>
      </div>
      <ul class="mt-3 -mx-1 flex gap-2 overflow-x-auto px-1 pb-1 sm:grid sm:grid-cols-2 sm:overflow-visible lg:grid-cols-4">
        {recent.items.slice(0, 4).map((item) => (
          <li class="min-w-[15rem] flex-shrink-0 sm:min-w-0">
            <a
              href={item.href}
              class="block h-full rounded-md border border-rule bg-surface-raised p-3 no-underline transition-colors hover:border-rule-emphasis"
            >
              <p class="flex items-baseline justify-between gap-2 text-mono-id text-fg-muted">
                <span class:list={[
                  "rounded px-1.5 py-0.5 font-semibold uppercase",
                  item.kind === "finding"
                    ? "bg-encoding-coverage-findings/10 text-encoding-coverage-findings"
                    : item.kind === "paper"
                      ? "bg-surface-accent text-accent"
                      : "bg-encoding-source-figure-soft text-encoding-source-figure-strong",
                ]}>{item.kind}</span>
                <span>{item.added_at}</span>
              </p>
              <p class="mt-1.5 line-clamp-2 text-body text-fg">{item.title}</p>
              {item.secondary ? (
                <p class="mt-0.5 text-body-xs text-fg-secondary">{item.secondary}</p>
              ) : null}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null}

  <Section spacing="lg">
    <Card href={featuredStory.href} padding="none" class="overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)]">
        <div class="aspect-[1200/630] w-full bg-surface-sunken md:aspect-auto md:h-full">
          <img
            src={`/og/stories/${featuredStory.slug}.svg`}
            alt=""
            loading="lazy"
            decoding="async"
            class="block h-full w-full object-cover"
          />
        </div>
        <div class="flex flex-col gap-2 p-5">
          <p class="text-eyebrow uppercase text-accent">
            {featured.triggeredByFamily
              ? `Recently active · ${featuredStory.readMinutes} min read`
              : `Story of the week · ${featuredStory.readMinutes} min read`}
          </p>
          <h2 class="text-h3 text-fg">{featuredStory.title}</h2>
          <p class="text-body text-fg-secondary">{featuredStory.lead}</p>
          {featured.triggeredByFamily ? (
            <p class="text-body-xs text-fg-muted">
              Featured because{" "}
              <span class="font-mono text-fg">
                {featured.triggeredByFamily.id
                  .replace("family.", "")
                  .replace(/-/g, " ")}
              </span>
              {" "}was extended on {featured.triggeredByFamily.lastAdded}.
            </p>
          ) : null}
          <p class="mt-auto pt-2 text-body-xs text-fg-muted">
            {featuredStory.surface}
            {" "}
            <span class="ml-2 text-fg-subtle transition-colors group-hover:text-accent" aria-hidden="true">→</span>
          </p>
        </div>
      </div>
    </Card>
    <p class="mt-2 text-body-xs text-fg-muted">
      All stories at <a class="text-accent" href="/stories">/stories</a>.
    </p>
  </Section>

  <Section spacing="lg">
    <Card padding="lg">
      <header class="mb-3 flex items-baseline justify-between gap-3">
        <div>
          <p class="text-eyebrow uppercase text-fg-muted">Across the literature</p>
          <h2 class="mt-1 text-h3 text-fg">
            {aggregateStats.n_psychometric_findings} psychometric fits, {paperCount} papers
          </h2>
        </div>
        <a class="text-body-xs text-accent" href="/findings">/findings →</a>
      </header>
      {steepest && shallowest && slopeFold !== null && steepest.species !== shallowest.species ? (
        <p class="mb-4 max-w-prose text-body text-fg-secondary">
          Slope σ varies <span class="font-mono text-fg">{fmt(slopeFold, 1)}×</span> across species —
          {" "}<span class="font-mono text-fg">{steepest.species}</span> fit steepest
          (<span class="font-mono text-fg">{fmt(steepest.sigma)}</span>),
          {" "}<span class="font-mono text-fg">{shallowest.species}</span> shallowest
          (<span class="font-mono text-fg">{fmt(shallowest.sigma)}</span>).
        </p>
      ) : (
        <p class="mb-4 max-w-prose text-body text-fg-secondary">
          Aggregate stats over every psychometric finding currently in the
          index, computed from build-time 4-parameter logistic fits.
        </p>
      )}
      <StatGrid cols={4} class="mb-5">
        <Stat label="Median bias (μ)" value={fmt(aggregateStats.median_bias)} />
        <Stat label="Median slope (σ)" value={fmt(aggregateStats.median_sigma)} />
        <Stat label="Median 75% threshold" value={fmt(aggregateStats.median_threshold)} />
        <Stat label="Σ trials" value={aggregateStats.total_trials_psychometric} />
      </StatGrid>
      {thresholdRows.length > 1 ? (
        <div class="mb-6">
          <h3 class="mb-1 flex items-baseline justify-between gap-3 text-eyebrow uppercase text-fg-muted">
            <span>
              Threshold distribution · {thresholdRows.length} fits
            </span>
            <span class="text-mono-id text-fg-muted">
              dominant axis only
            </span>
          </h3>
          <ThresholdDistribution
            client:visible
            rows={thresholdRows}
            median={thresholdMedian}
            xLabel={thresholdAxisLabel}
            height={200}
          />
        </div>
      ) : null}
      <h3 class="mb-2 text-eyebrow uppercase text-fg-muted">Median σ by species</h3>
      <AggregateBySpecies client:visible rows={speciesRows} height={Math.max(160, 32 * speciesRows.length + 60)} />
    </Card>
  </Section>

  <section class="mt-8 -mx-4 border-y border-rule bg-surface-raised px-4 py-4 text-body-xs">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1.5">
      <span class="text-eyebrow uppercase text-fg-muted">Atlas health</span>
      <StatusPill tone={auditTone}>audit {auditStatus}</StatusPill>
      <span class="inline-flex items-baseline gap-1 rounded bg-surface-sunken px-1.5 py-0.5">
        <span class="font-mono text-fg">{curationOpen}</span>
        <span class="text-fg-muted">curation</span>
      </span>
      <span class:list={[
        "inline-flex items-baseline gap-1 rounded px-1.5 py-0.5",
        blockerHighCount > 0 ? "bg-bad-soft text-bad" : "bg-surface-sunken text-fg-muted",
      ]}>
        <span class="font-mono">{blockerHighCount}</span>
        <span>blocker{blockerHighCount === 1 ? "" : "s"}</span>
      </span>
      <span class="inline-flex items-baseline gap-1 rounded bg-surface-sunken px-1.5 py-0.5">
        <span class="font-mono text-fg">{roadmapItems}</span>
        <span class="text-fg-muted">roadmap</span>
      </span>
      <span class:list={[
        "inline-flex items-baseline gap-1 rounded px-1.5 py-0.5",
        linkIssues > 0 ? "bg-warn-soft text-warn" : "bg-surface-sunken text-fg-muted",
      ]}>
        <span class="font-mono">{linkIssues}</span>
        <span>link issue{linkIssues === 1 ? "" : "s"}</span>
      </span>
      <a class="ml-auto text-accent" href="/project-health">/project-health →</a>
    </div>
    <p class="mt-2 text-mono-id text-fg-muted">
      Built {generated}{manifest.behavtaskatlas_commit ? (
        <>
          {" · "}
          <code class="rounded bg-surface-sunken px-1 py-0.5">
            {manifest.behavtaskatlas_commit}
          </code>
        </>
      ) : null}{manifest.behavtaskatlas_git_dirty ? " (dirty tree)" : null}
    </p>
  </section>
</BaseLayout>
