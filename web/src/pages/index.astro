---
import BaseLayout from "../layouts/BaseLayout.astro";
import AtlasOverview from "../components/AtlasOverview.astro";
import MiniFindingsChart from "../components/MiniFindingsChart.svelte";
import { manifest } from "../lib/data";
import {
  comparisons,
  findings,
  type FindingsEntry,
} from "../lib/findings";

const sliceCount = manifest.slices.length;

const entryPoints = [
  {
    href: "/findings",
    title: "Findings",
    description:
      "Cross-paper psychometric, chronometric, and accuracy curves on shared signed-evidence axes with build-time fits and an in-browser refit.",
  },
  {
    href: "/compare",
    title: "Compare",
    description:
      "Hand-curated cross-paper questions — prior-block shifts, species differences, cueing effects — with quantitative parameter deltas.",
  },
  {
    href: "/slices",
    title: "Slices",
    description: `${sliceCount} reproducible local pipelines bound to pinned datasets, each with an in-browser Pyodide cell for live exploration.`,
  },
  {
    href: "/papers",
    title: "Papers",
    description:
      "Generated bibliography with per-paper citation exports, linked protocols, source coverage, and finding tables where standardized curves exist.",
  },
];

type FitFields = {
  mu: number;
  sigma: number;
  gamma: number;
  lapse: number;
  threshold?: number;
  threshold_target_y: number;
};

function median(values: number[]): number | null {
  const finite = values.filter((v) => Number.isFinite(v));
  if (finite.length === 0) return null;
  const sorted = [...finite].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 === 1
    ? sorted[mid]
    : (sorted[mid - 1] + sorted[mid]) / 2;
}

const psychometricFits = (findings.findings as FindingsEntry[]).filter(
  (f) =>
    f.curve_type === "psychometric" &&
    (f as FindingsEntry & { fit?: FitFields | null }).fit?.threshold !== undefined,
);

const allSigma = psychometricFits.map(
  (f) => (f as FindingsEntry & { fit: FitFields }).fit.sigma,
);
const allThreshold = psychometricFits.map(
  (f) => (f as FindingsEntry & { fit: FitFields }).fit.threshold!,
);
const allBias = psychometricFits.map(
  (f) => (f as FindingsEntry & { fit: FitFields }).fit.mu,
);

type SpeciesRow = {
  species: string;
  count: number;
  median_sigma: number | null;
  median_threshold: number | null;
  total_trials: number;
};

const speciesGroups = new Map<string, FindingsEntry[]>();
for (const f of findings.findings as FindingsEntry[]) {
  if (f.curve_type !== "psychometric") continue;
  const fit = (f as FindingsEntry & { fit?: FitFields | null }).fit;
  if (!fit || fit.threshold === undefined) continue;
  const sp = f.species ?? "unknown";
  if (!speciesGroups.has(sp)) speciesGroups.set(sp, []);
  speciesGroups.get(sp)!.push(f);
}

const speciesRows: SpeciesRow[] = Array.from(speciesGroups.entries())
  .map(([species, fs]) => ({
    species,
    count: fs.length,
    median_sigma: median(
      fs.map((f) => (f as FindingsEntry & { fit: FitFields }).fit.sigma),
    ),
    median_threshold: median(
      fs.map((f) => (f as FindingsEntry & { fit: FitFields }).fit.threshold!),
    ),
    total_trials: fs.reduce(
      (sum, f) => sum + (typeof f.n_trials === "number" ? f.n_trials : 0),
      0,
    ),
  }))
  .sort((a, b) => b.count - a.count);

const aggregateStats = {
  n_psychometric_findings: psychometricFits.length,
  median_sigma: median(allSigma),
  median_threshold: median(allThreshold),
  median_bias: median(allBias),
  total_trials_psychometric: psychometricFits.reduce(
    (sum, f) => sum + (typeof f.n_trials === "number" ? f.n_trials : 0),
    0,
  ),
};

const featuredComparison = comparisons.comparisons[0] ?? null;
const featuredFindingIds = ((featuredComparison?.finding_ids ?? []) as string[]);
const featuredFindings = featuredComparison
  ? (findings.findings as FindingsEntry[]).filter((f) =>
      featuredFindingIds.includes(f.finding_id),
    )
  : [];

function fmt(value: number | null, digits = 2): string {
  if (value === null || !Number.isFinite(value)) return "—";
  return value.toFixed(digits);
}

const generated = manifest.generated_at?.slice(0, 10) ?? "";

---

<BaseLayout
  title={manifest.title}
  description="A file-first atlas of sensory-guided decision-making tasks in behavioral neuroscience. Browse curated task families, protocols, datasets, vertical slices, and cross-paper findings on shared axes."
>
  <header class="mb-8">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
      A file-first atlas of behavioral neuroscience tasks.
    </h1>
    <p class="mt-3 max-w-3xl text-base text-slate-700">
      Curated task families, protocols, datasets, and reproducible analyses,
      paired with a meta-analysis layer of cross-paper findings on shared
      signed-evidence axes. Every record is YAML in git, validated by
      Pydantic, and rebuilt on every commit.
    </p>
  </header>

  <AtlasOverview />

  {featuredComparison && featuredFindings.length > 0 ? (
    <section class="mb-12">
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <header class="mb-3 flex flex-wrap items-baseline justify-between gap-3">
          <div>
            <p class="text-xs uppercase tracking-wide text-accent">
              Featured comparison
            </p>
            <h2 class="mt-1 text-xl font-semibold text-slate-900">
              {featuredComparison.question}
            </h2>
          </div>
          <a
            class="text-xs no-underline text-accent hover:underline"
            href={`/compare#${featuredComparison.id}`}
          >
            See parameter deltas →
          </a>
        </header>
        <p class="mb-4 max-w-3xl text-sm text-slate-700">
          {featuredComparison.framing}
        </p>
        <MiniFindingsChart
          client:visible
          findings={featuredFindings}
          colorBy={
            featuredComparison.color_by as
              | "paper"
              | "condition"
              | "curve_type"
          }
          height={300}
        />
      </article>
    </section>
  ) : null}

  <section class="mb-12">
    <h2 class="mb-3 text-xs uppercase tracking-wide text-slate-500">
      Where to start
    </h2>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      {entryPoints.map((card) => (
        <a
          href={card.href}
          class="group rounded-md border border-slate-200 bg-white p-4 no-underline transition-colors hover:border-accent"
        >
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="text-base font-semibold text-slate-900">
              {card.title}
            </h3>
            <span
              class="text-sm text-slate-400 transition-colors group-hover:text-accent"
              aria-hidden="true"
            >→</span>
          </div>
          <p class="mt-1 text-sm text-slate-600">{card.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mb-12">
    <a
      href="/stories/visual-contrast"
      class="group flex flex-col gap-2 rounded-md border border-slate-200 bg-white p-5 no-underline transition-colors hover:border-accent sm:flex-row sm:items-baseline sm:justify-between sm:gap-6"
    >
      <div class="max-w-2xl">
        <p class="text-xs uppercase tracking-wide text-accent">
          Latest story
        </p>
        <h2 class="mt-1 text-xl text-slate-900">
          Visual contrast discrimination now has a family map
        </h2>
        <p class="mt-2 text-sm text-slate-600">
          Timeline, coverage matrix, curve scan, small multiples, source
          depth, and model ambiguity are now visible in one scannable view.
        </p>
      </div>
      <span
        class="shrink-0 self-start text-sm text-slate-400 transition-colors group-hover:text-accent sm:self-baseline"
        aria-hidden="true"
      >→</span>
    </a>
    <p class="mt-2 text-xs text-slate-500">
      All stories at <a class="text-accent" href="/stories">/stories</a>.
    </p>
  </section>

  <section class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[2fr_1fr]">
    <article class="rounded-md border border-slate-200 bg-white p-5">
      <header class="mb-3 flex items-baseline justify-between">
        <h2 class="text-base font-semibold text-slate-900">
          Across the literature
        </h2>
        <a class="text-xs text-accent" href="/findings">/findings →</a>
      </header>
      <p class="mb-4 text-sm text-slate-600">
        Aggregate stats over the {aggregateStats.n_psychometric_findings}{" "}
        psychometric findings currently in the index, computed from build-time
        4-parameter logistic fits.
      </p>
      <dl class="mb-5 grid grid-cols-2 gap-x-4 gap-y-1 text-sm sm:grid-cols-4">
        <div>
          <dt class="text-xs uppercase text-slate-500">Median bias (μ)</dt>
          <dd class="mt-0.5 font-mono text-base">{fmt(aggregateStats.median_bias)}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase text-slate-500">Median slope (σ)</dt>
          <dd class="mt-0.5 font-mono text-base">{fmt(aggregateStats.median_sigma)}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase text-slate-500">Median 75% threshold</dt>
          <dd class="mt-0.5 font-mono text-base">
            {fmt(aggregateStats.median_threshold)}
          </dd>
        </div>
        <div>
          <dt class="text-xs uppercase text-slate-500">Σ trials</dt>
          <dd class="mt-0.5 font-mono text-base">
            {aggregateStats.total_trials_psychometric.toLocaleString()}
          </dd>
        </div>
      </dl>
      <h3 class="mb-1 text-xs font-semibold uppercase text-slate-500">By species</h3>
      <div class="overflow-x-auto rounded border border-slate-200">
        <table class="w-full text-xs">
          <thead class="bg-slate-50 text-left uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-2 py-1.5">Species</th>
              <th class="px-2 py-1.5 text-right">Findings</th>
              <th class="px-2 py-1.5 text-right">Median σ</th>
              <th class="px-2 py-1.5 text-right">Median 75%</th>
              <th class="px-2 py-1.5 text-right">Σ trials</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            {speciesRows.map((row) => (
              <tr>
                <td class="px-2 py-1.5">{row.species}</td>
                <td class="px-2 py-1.5 text-right font-mono">{row.count}</td>
                <td class="px-2 py-1.5 text-right font-mono">{fmt(row.median_sigma)}</td>
                <td class="px-2 py-1.5 text-right font-mono">
                  {fmt(row.median_threshold)}
                </td>
                <td class="px-2 py-1.5 text-right font-mono">
                  {row.total_trials.toLocaleString()}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>

    <aside class="space-y-3">
      <div class="rounded-md border border-slate-200 bg-white p-4 text-xs text-slate-500">
        <h2 class="mb-2 text-xs uppercase tracking-wide text-slate-500">
          Build state
        </h2>
        <p>
          Generated {generated}
          {manifest.behavtaskatlas_commit ? (
            <>
              {" · "}
              <code class="rounded bg-slate-100 px-1 py-0.5 text-[11px]">
                {manifest.behavtaskatlas_commit}
              </code>
            </>
          ) : null}
          {manifest.behavtaskatlas_git_dirty ? " (dirty)" : null}
        </p>
        <p class="mt-2">
          Operational status on{" "}
          <a class="text-accent" href="/atlas-health">/atlas-health</a>.
        </p>
      </div>
    </aside>
  </section>
</BaseLayout>
