---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import MiniFindingsChart from "../../components/MiniFindingsChart.svelte";
import RecordChip from "../../components/RecordChip.astro";
import Card from "../../components/ui/Card.astro";
import DetailLayout from "../../components/ui/DetailLayout.astro";
import DetailToc from "../../components/ui/DetailToc.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Section from "../../components/ui/Section.astro";
import StatusPill from "../../components/ui/StatusPill.astro";
import { catalog, slugForId } from "../../lib/data";
import type { CatalogProtocolDetail } from "../../lib/data";
import { findings as findingsIndex } from "../../lib/findings";

export function getStaticPaths() {
  return catalog.protocol_details.map((protocol) => ({
    params: { id: slugForId(protocol.protocol_id) },
    props: { protocol },
  }));
}

interface Props {
  protocol: CatalogProtocolDetail;
}

type Mapping = Record<string, unknown>;

const { protocol } = Astro.props as Props;
const stimulus: Mapping = protocol.stimulus as Mapping;
const choice: Mapping = protocol.choice as Mapping;
const feedback: Mapping = protocol.feedback as Mapping;
const training: Mapping = protocol.training as Mapping;

const timingRows = (protocol.timing as Mapping[]).map((phase) => ({
  name: String(phase.name ?? ""),
  duration: String(phase.duration ?? ""),
  description: phase.description ? String(phase.description) : null,
}));

const interpretiveClaims = (protocol.interpretive_claims as Mapping[]).map(
  (claim) => ({
    label: String(claim.label ?? ""),
    confidence: String(claim.confidence ?? ""),
    source: String(claim.source ?? ""),
    caveat: claim.caveat ? String(claim.caveat) : null,
  }),
);

function renderValue(value: unknown): string {
  if (value === null || value === undefined) return "—";
  if (Array.isArray(value)) return value.join(", ");
  return String(value);
}

const protocolFindings = findingsIndex.findings.filter(
  (entry) => entry.protocol_id === protocol.protocol_id,
);
const protocolPapers = Array.from(
  new Map(
    protocolFindings.map((entry) => [
      entry.paper_id,
      {
        paper_id: entry.paper_id,
        paper_citation: entry.paper_citation,
        paper_year: entry.paper_year,
      },
    ]),
  ).values(),
).sort((a, b) => b.paper_year - a.paper_year);

type TocItem = { id: string; label: string; count?: number };
const tocItems: TocItem[] = [
  { id: "structure", label: "Task structure" } as TocItem,
  timingRows.length > 0
    ? { id: "timing", label: "Trial timing", count: timingRows.length }
    : null,
  protocol.vertical_slices.length > 0
    ? {
        id: "slices",
        label: "Vertical slices",
        count: protocol.vertical_slices.length,
      }
    : null,
  protocol.expected_analyses.length > 0
    ? { id: "analyses", label: "Expected analyses" }
    : null,
  interpretiveClaims.length > 0
    ? {
        id: "claims",
        label: "Interpretive claims",
        count: interpretiveClaims.length,
      }
    : null,
  protocol.open_questions.length > 0
    ? { id: "questions", label: "Open questions" }
    : null,
  protocolPapers.length > 0
    ? { id: "papers", label: "Papers", count: protocolPapers.length }
    : null,
  protocolFindings.length > 0
    ? { id: "findings", label: "Findings", count: protocolFindings.length }
    : null,
].filter((item): item is TocItem => item !== null);

const isCurated =
  protocol.curation_status === "data-linked" ||
  protocol.curation_status === "literature-curated";
---

<BaseLayout title={`${protocol.name} · Protocol`} width="wide">
  <Breadcrumbs
    crumbs={[
      { label: "Catalog", href: "/catalog" },
      { label: "Protocols", href: "/catalog#protocols" },
      { label: protocol.name },
    ]}
  />

  <DetailLayout>
    <Fragment slot="rail">
      <DetailToc items={tocItems} />
      <Card padding="md" class="text-body-xs">
        <h3 class="mb-3 text-eyebrow uppercase text-fg-muted">Protocol</h3>
        <dl class="space-y-3">
          <div>
            <dt class="text-fg-muted">Family</dt>
            <dd class="mt-0.5 text-fg">{protocol.family_name ?? protocol.family_id}</dd>
          </div>
          <div>
            <dt class="text-fg-muted">Scope</dt>
            <dd class="mt-0.5 text-fg">{protocol.protocol_scope}</dd>
          </div>
          <div>
            <dt class="text-fg-muted">Species</dt>
            <dd class="mt-0.5 text-fg">{protocol.species.join(", ")}</dd>
          </div>
          <div>
            <dt class="text-fg-muted">Status</dt>
            <dd class="mt-1">
              <StatusPill tone={isCurated ? "ok" : "neutral"}>
                {protocol.curation_status}
              </StatusPill>
            </dd>
          </div>
          {protocol.aliases.length > 0 ? (
            <div>
              <dt class="text-fg-muted">Aliases</dt>
              <dd class="mt-0.5 text-fg-secondary">{protocol.aliases.join(", ")}</dd>
            </div>
          ) : null}
        </dl>
      </Card>
      {protocol.datasets.length > 0 ? (
        <Card padding="md" class="mt-3 text-body-xs">
          <h3 class="mb-2 text-eyebrow uppercase text-fg-muted">Datasets</h3>
          <ul class="flex flex-wrap gap-1.5">
            {protocol.datasets.map((d) => (
              <li>
                <RecordChip
                  type="dataset"
                  label={d.name}
                  href={`/datasets/${slugForId(d.dataset_id)}`}
                />
              </li>
            ))}
          </ul>
        </Card>
      ) : null}
    </Fragment>

    <PageHeader
      eyebrow="Protocol"
      title={protocol.name}
      lede={protocol.description}
    />

    <Section
      id="structure"
      spacing="md"
      title="Task structure"
      description="Stimulus, choice, feedback, and training as declared in the protocol record."
    >
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <Card padding="md">
          <h3 class="mb-2 text-h3 text-fg-secondary">Stimulus</h3>
          <dl class="space-y-1 text-body">
            {Object.entries(stimulus).map(([key, value]) => (
              <div class="grid grid-cols-3 gap-2">
                <dt class="text-fg-muted">{key}</dt>
                <dd class="col-span-2 break-words">{renderValue(value)}</dd>
              </div>
            ))}
          </dl>
        </Card>
        <Card padding="md">
          <h3 class="mb-2 text-h3 text-fg-secondary">Choice</h3>
          <dl class="space-y-1 text-body">
            {Object.entries(choice).map(([key, value]) => (
              <div class="grid grid-cols-3 gap-2">
                <dt class="text-fg-muted">{key}</dt>
                <dd class="col-span-2 break-words">{renderValue(value)}</dd>
              </div>
            ))}
          </dl>
        </Card>
        <Card padding="md">
          <h3 class="mb-2 text-h3 text-fg-secondary">Feedback</h3>
          <dl class="space-y-1 text-body">
            {Object.entries(feedback).map(([key, value]) => (
              <div class="grid grid-cols-3 gap-2">
                <dt class="text-fg-muted">{key}</dt>
                <dd class="col-span-2 break-words">{renderValue(value)}</dd>
              </div>
            ))}
          </dl>
        </Card>
        <Card padding="md">
          <h3 class="mb-2 text-h3 text-fg-secondary">Training</h3>
          <dl class="space-y-1 text-body">
            {Object.entries(training).map(([key, value]) => (
              <div class="grid grid-cols-3 gap-2">
                <dt class="text-fg-muted">{key}</dt>
                <dd class="col-span-2 break-words">{renderValue(value)}</dd>
              </div>
            ))}
          </dl>
        </Card>
      </div>
    </Section>

    {timingRows.length > 0 ? (
      <Section id="timing" spacing="md" title="Trial timing">
        <ol class="space-y-2 text-body">
          {timingRows.map((phase) => (
            <Card as="li" padding="sm">
              <div class="font-medium">{phase.name}</div>
              <div class="text-body-xs text-fg-muted">{phase.duration}</div>
              {phase.description ? (
                <p class="mt-1 text-fg-secondary">{phase.description}</p>
              ) : null}
            </Card>
          ))}
        </ol>
      </Section>
    ) : null}

    {protocol.vertical_slices.length > 0 ? (
      <Section id="slices" spacing="md" title="Vertical slices">
        <ul class="space-y-1 text-body">
          {protocol.vertical_slices.map((slice) => (
            <li class="flex items-baseline justify-between">
              <a class="text-fg" href={`/slices/${slugForId(slice.slice_id)}`}>{slice.title}</a>
              <StatusPill tone={slice.report_status === "available" ? "ok" : "neutral"}>
                {slice.report_status}
              </StatusPill>
            </li>
          ))}
        </ul>
      </Section>
    ) : null}

    {protocol.expected_analyses.length > 0 ? (
      <Section id="analyses" spacing="md" title="Expected analyses">
        <ul class="list-disc space-y-1 pl-5 text-body">
          {protocol.expected_analyses.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </Section>
    ) : null}

    {interpretiveClaims.length > 0 ? (
      <Section id="claims" spacing="md" title="Interpretive claims">
        <ul class="space-y-2 text-body">
          {interpretiveClaims.map((claim) => (
            <Card as="li" padding="sm">
              <div class="font-medium">{claim.label}</div>
              <div class="text-body-xs text-fg-muted">
                Confidence: {claim.confidence} · {claim.source}
              </div>
              {claim.caveat ? (
                <p class="mt-1 text-fg-secondary">{claim.caveat}</p>
              ) : null}
            </Card>
          ))}
        </ul>
      </Section>
    ) : null}

    {protocol.open_questions.length > 0 ? (
      <Section id="questions" spacing="md" title="Open questions">
        <ul class="list-disc space-y-1 pl-5 text-body text-fg-secondary">
          {protocol.open_questions.map((q) => (
            <li>{q}</li>
          ))}
        </ul>
      </Section>
    ) : null}

    {protocolPapers.length > 0 ? (
      <Section id="papers" spacing="md" title="Papers">
        <ul class="space-y-1 text-body">
          {protocolPapers.map((p) => (
            <li>
              <a href={`/papers/${slugForId(p.paper_id)}`}>{p.paper_citation}</a>
              <span class="ml-2 text-body-xs text-fg-muted">({p.paper_year})</span>
            </li>
          ))}
        </ul>
      </Section>
    ) : null}

    {protocolFindings.length > 0 ? (
      <Section
        id="findings"
        spacing="md"
        title="Findings"
        description="Curves attached to this protocol on shared signed-evidence axes."
      >
        <MiniFindingsChart
          client:visible
          findings={protocolFindings}
          colorBy="paper"
          height={280}
        />
        <ul class="mt-3 space-y-1 text-body">
          {protocolFindings.map((entry) => (
            <li class="flex items-baseline justify-between gap-3">
              <span>
                <a href={`/papers/${slugForId(entry.paper_id)}`}>
                  {entry.paper_citation}
                </a>
                <span class="ml-2 text-body-xs text-fg-muted">
                  · {entry.curve_type}
                  {entry.stratification.condition
                    ? ` · ${entry.stratification.condition}`
                    : ""}
                </span>
              </span>
              <span class="text-body-xs text-fg-muted">{entry.source_data_level}</span>
            </li>
          ))}
        </ul>
        <p class="mt-2 text-body-xs text-fg-muted">
          See all <a href="/findings">findings overlaid on shared axes</a>.
        </p>
      </Section>
    ) : null}
  </DetailLayout>
</BaseLayout>
