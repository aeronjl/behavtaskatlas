---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchPanel from "../components/SearchPanel.svelte";
import { searchIndex } from "../lib/search";

const total = searchIndex.counts.total;
---

<BaseLayout
  title="Search · behavtaskatlas"
  description="Cross-record search over papers, protocols, datasets, slices, findings, models, stories, data requests, and comparisons."
>
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Search</h1>
    <p class="mt-2 text-sm text-slate-600">
      Search across {total} records — papers, task families, protocols,
      datasets, vertical slices, findings, models, stories, data requests, and
      curated comparisons.
    </p>
  </header>

  <SearchPanel client:load />
</BaseLayout>
