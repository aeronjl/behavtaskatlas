---
import BaseLayout from "../layouts/BaseLayout.astro";
import { models, slugForId } from "../lib/data";

type Variant = {
  id: string;
  family_id: string;
  name: string;
  free_parameters: string[];
};
type Fit = {
  id: string;
  variant_id: string;
  finding_ids: string[];
  quality?: { log_likelihood?: number; aic?: number; n_trials?: number };
};

const { families, slice_coverage, counts, known_requirements } = models;
const variants = (models.variants ?? []) as unknown as Variant[];
const fits = (models.fits ?? []) as unknown as Fit[];

const variantsByFamily = new Map<string, Variant[]>();
for (const v of variants) {
  if (!variantsByFamily.has(v.family_id)) variantsByFamily.set(v.family_id, []);
  variantsByFamily.get(v.family_id)!.push(v);
}

function capabilityRow(s: (typeof slice_coverage)[number]): string[] {
  if (!s.capabilities) return [];
  return Object.entries(s.capabilities)
    .filter(([, v]) => v)
    .map(([k]) => k);
}
---

<BaseLayout
  title="Models · behavtaskatlas"
  description="Computational model families, variants, and fits curated alongside findings."
>
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Models</h1>
    <p class="mt-2 text-sm text-slate-600">
      {counts.families} families, {counts.variants} variants,
      {counts.fits} fit{counts.fits === 1 ? "" : "s"}. Each fit is curated
      as a YAML record with parameters, quality metrics, and provenance.
      Heavy fits run locally; the
      <a class="text-accent" href="/audit">audit</a>
      gate forward-evaluates each committed fit on every CI run to catch
      drift if data changes underneath. Cross-paper view of DDM
      parameters: <a class="text-accent" href="/models/ddm">/models/ddm</a>.
    </p>
  </header>

  {
    counts.fits === 0 ? (
      <section class="mb-6 rounded-md border border-dashed border-slate-300 bg-white p-4 text-sm text-slate-600">
        Model layer scaffolding is in. No fits committed yet — the
        first batch (logistic + SDT for all pooled psychometric findings,
        then DDM on Roitman / Palmer / Walsh) lands in the next pass.
      </section>
    ) : null
  }

  <section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold">Families &amp; variants</h2>
    <div class="space-y-4">
      {
        families.map((family) => (
          <article class="rounded-md border border-slate-200 bg-white p-4">
            <header class="mb-2 flex items-baseline justify-between gap-3">
              <h3 class="text-base font-semibold">{family.name}</h3>
              <span class="rounded bg-slate-100 px-2 py-0.5 text-[10px] uppercase tracking-wide text-slate-500">
                {family.applicable_curve_types.join(", ")}
              </span>
            </header>
            <p class="text-xs font-mono text-slate-500">{family.id}</p>
            <p class="mt-2 text-sm text-slate-700">{family.description}</p>
            <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2">
              <div>
                <h4 class="mb-1 text-xs font-semibold text-slate-700">Parameters</h4>
                <ul class="space-y-1 text-xs text-slate-700">
                  {family.parameter_definitions.map((p) => (
                    <li>
                      <span class="font-mono">
                        {p.symbol ?? p.name}
                      </span>
                      <span class="ml-1 text-slate-500">{p.name}</span>
                      {p.units ? (
                        <span class="ml-1 text-slate-500">[{p.units}]</span>
                      ) : null}
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <h4 class="mb-1 text-xs font-semibold text-slate-700">Requires</h4>
                <ul class="flex flex-wrap gap-1">
                  {family.requires.map((r) => (
                    <li class="rounded bg-slate-100 px-2 py-0.5 text-xs font-mono">
                      {r}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="mt-3">
              <h4 class="mb-1 text-xs font-semibold text-slate-700">
                Variants ({(variantsByFamily.get(family.id) ?? []).length})
              </h4>
              <ul class="space-y-1 text-xs">
                {(variantsByFamily.get(family.id) ?? []).map((v) => (
                  <li>
                    <span class="font-mono text-slate-700">{v.id}</span>
                    <span class="ml-2 text-slate-600">— {v.name}</span>
                    <span class="ml-2 text-slate-500">
                      free=[{v.free_parameters.join(", ")}]
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold">Per-slice fittability</h2>
    <p class="mb-3 text-xs text-slate-600">
      Mapping from canonical-trial coverage in each slice's harmonized
      trials.csv to the variants whose data requirements it satisfies.
      Slices with empty fittability either lack the right canonical
      fields (RT, signed choice, click times) or need adapter fixes.
    </p>
    <div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-3 py-2">Slice</th>
            <th class="px-3 py-2 text-right">Trials</th>
            <th class="px-3 py-2 text-right">Subjects</th>
            <th class="px-3 py-2">Capabilities</th>
            <th class="px-3 py-2">Fittable variants</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          {
            slice_coverage.map((s) => (
              <tr>
                <td class="px-3 py-2">
                  <a class="font-mono text-xs" href={`/slices/${slugForId(s.slice_id)}`}>
                    {s.slice_id}
                  </a>
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {s.n_trials.toLocaleString()}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {s.n_subjects}
                </td>
                <td class="px-3 py-2">
                  <ul class="flex flex-wrap gap-1">
                    {capabilityRow(s).map((c) => (
                      <li class="rounded bg-ok-soft px-2 py-0.5 text-[11px] font-mono text-ok">
                        {c}
                      </li>
                    ))}
                  </ul>
                </td>
                <td class="px-3 py-2">
                  {(() => {
                    const ids = (s.fittable_variant_ids ?? []) as string[];
                    return ids.length === 0 ? (
                      <span class="text-xs text-slate-500">—</span>
                    ) : (
                      <ul class="flex flex-wrap gap-1">
                        {ids.map((vid) => (
                          <li class="rounded bg-slate-100 px-2 py-0.5 text-[11px] font-mono">
                            {vid.replace("model_variant.", "")}
                          </li>
                        ))}
                      </ul>
                    );
                  })()}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-[11px] text-slate-500">
      Known requirements: {known_requirements.join(", ")}
    </p>
  </section>

  {
    fits.length > 0 ? (
      <section class="mb-8">
        <h2 class="mb-3 text-lg font-semibold">Fits</h2>
        <div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
              <tr>
                <th class="px-3 py-2">Fit</th>
                <th class="px-3 py-2">Variant</th>
                <th class="px-3 py-2">Findings</th>
                <th class="px-3 py-2 text-right">logL</th>
                <th class="px-3 py-2 text-right">AIC</th>
                <th class="px-3 py-2 text-right">n_trials</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {fits.map((f) => (
                <tr>
                  <td class="px-3 py-2 font-mono text-xs">{f.id}</td>
                  <td class="px-3 py-2 font-mono text-xs">{f.variant_id}</td>
                  <td class="px-3 py-2 font-mono text-[11px]">
                    {f.finding_ids.join(", ")}
                  </td>
                  <td class="px-3 py-2 text-right font-mono">
                    {f.quality?.log_likelihood ?? "—"}
                  </td>
                  <td class="px-3 py-2 text-right font-mono">
                    {f.quality?.aic ?? "—"}
                  </td>
                  <td class="px-3 py-2 text-right font-mono">
                    {f.quality?.n_trials ?? "—"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ) : null
  }
</BaseLayout>
