---
import BaseLayout from "../layouts/BaseLayout.astro";
import { curationQueue } from "../lib/data";

type CurationItem = {
  item_id: string;
  action_type: string;
  priority: "low" | "normal" | "high";
  status: "open" | "blocked" | "done";
  source_issue_id: string;
  source_issue_type: string;
  source_severity: "info" | "warning" | "error";
  node_id?: string | null;
  node_label?: string | null;
  node_type?: string | null;
  related_node_id?: string | null;
  message: string;
  suggested_next_step: string;
  href?: string | null;
};

const items = (curationQueue.items ?? []) as CurationItem[];
const counts = (curationQueue.counts ?? {}) as Record<string, number>;
const actionCounts = (curationQueue.action_counts ?? {}) as Record<
  string,
  number
>;
const priorityCounts = (curationQueue.priority_counts ?? {}) as Record<
  string,
  number
>;

const priorityOrder: CurationItem["priority"][] = ["high", "normal", "low"];
const grouped = priorityOrder
  .map((p) => ({ priority: p, items: items.filter((i) => i.priority === p) }))
  .filter((g) => g.items.length > 0);

const priorityClasses: Record<CurationItem["priority"], string> = {
  high: "bg-warn-soft text-warn",
  normal: "bg-accent-soft text-accent",
  low: "bg-slate-100 text-slate-600",
};
---

<BaseLayout title="Curation queue · behavtaskatlas">
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Curation queue</h1>
    <p class="mt-2 text-sm text-slate-600">
      {counts.open ?? 0} open of {counts.items ?? 0} total ·
      generated {curationQueue.generated_at}
    </p>
  </header>

  {
    items.length === 0 ? (
      <section class="rounded-md border border-ok bg-ok-soft p-4 text-sm text-ok">
        Curation queue is empty. The relationship-graph QA pass found no orphan
        records, missing reciprocal links, or coverage gaps in the current
        commit.
      </section>
    ) : (
      <>
        <section class="mb-8 grid grid-cols-1 gap-3 md:grid-cols-2">
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <h2 class="mb-2 text-sm font-semibold text-slate-700">
              By priority
            </h2>
            <ul class="space-y-1 text-sm">
              {Object.entries(priorityCounts).map(([k, v]) => (
                <li class="flex justify-between">
                  <span class="text-slate-700">{k}</span>
                  <span class="font-mono text-slate-900">{v}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <h2 class="mb-2 text-sm font-semibold text-slate-700">
              By action type
            </h2>
            <ul class="space-y-1 text-sm">
              {Object.entries(actionCounts).map(([k, v]) => (
                <li class="flex justify-between">
                  <span class="text-slate-700">{k}</span>
                  <span class="font-mono text-slate-900">{v}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>

        {grouped.map((group) => (
          <section class="mb-8">
            <h2 class="mb-3 text-lg font-semibold capitalize">
              {group.priority} priority{" "}
              <span class="text-sm font-normal text-slate-500">
                ({group.items.length})
              </span>
            </h2>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li class="rounded-md border border-slate-200 bg-white p-3 text-sm">
                  <header class="mb-1 flex items-baseline justify-between gap-2">
                    <span class="font-medium">{item.action_type}</span>
                    <span
                      class:list={[
                        "rounded px-2 py-0.5 text-xs",
                        priorityClasses[item.priority],
                      ]}
                    >
                      {item.priority}
                    </span>
                  </header>
                  <p class="mb-1 text-slate-700">{item.message}</p>
                  <p class="text-xs text-slate-500">
                    Next: {item.suggested_next_step}
                  </p>
                  {item.node_id ? (
                    <p class="mt-1 text-xs font-mono text-slate-500">
                      {item.node_id}
                    </p>
                  ) : null}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </>
    )
  }
</BaseLayout>
