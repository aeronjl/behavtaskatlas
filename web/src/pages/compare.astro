---
import BaseLayout from "../layouts/BaseLayout.astro";
import MiniFindingsChart from "../components/MiniFindingsChart.svelte";
import DdmParamScatter from "../components/DdmParamScatter.svelte";
import Card from "../components/ui/Card.astro";
import DataTable from "../components/ui/DataTable.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import {
  comparisons as comparisonsIndex,
  findings,
  type ComparisonEntry,
  type FindingsEntry,
} from "../lib/findings";
import { models, slugForId } from "../lib/data";

type FitFields = {
  mu: number;
  sigma: number;
  gamma: number;
  lapse: number;
  threshold: number;
  threshold_target_y: number;
};

type ModelFit = {
  id: string;
  variant_id: string;
  finding_ids: string[];
  parameters: Record<string, number>;
  quality: Record<string, number>;
};
const modelFits = (models.fits ?? []) as unknown as ModelFit[];
const modelFitsById = new Map<string, ModelFit>();
for (const f of modelFits) modelFitsById.set(f.id, f);

const findingsById = new Map<string, FindingsEntry>();
for (const entry of findings.findings as FindingsEntry[]) {
  findingsById.set(entry.finding_id, entry);
}

function pickEntries(ids: string[]): FindingsEntry[] {
  return ids
    .map((id) => findingsById.get(id))
    .filter((e): e is FindingsEntry => e !== undefined);
}

function entryLabel(entry: FindingsEntry): string {
  const condition = entry.stratification?.condition ?? entry.stratification?.subject_id;
  if (condition) return `${entry.paper_citation.split(".")[0]} · ${condition}`;
  return entry.paper_citation;
}

function fmt(value: number | null | undefined, digits = 2): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "—";
  return value.toFixed(digits);
}

const COMPARISONS: ComparisonEntry[] = comparisonsIndex.comparisons;

type ModelFitRow = {
  fit: ModelFit;
  group: string;
  variant: string;
  aic: number | null;
  bic: number | null;
  log_likelihood: number | null;
  params: Record<string, number>;
  paper_id: string | null;
  finding_id: string | null;
};

function fitsForComparison(spec: ComparisonEntry): ModelFitRow[] {
  const ids = ((spec as unknown as { model_fit_ids?: string[] }).model_fit_ids ?? []) as string[];
  if (ids.length === 0) return [];
  const rows: ModelFitRow[] = [];
  for (const id of ids) {
    const fit = modelFitsById.get(id);
    if (!fit) continue;
    const psyId = fit.finding_ids.find((fid) => {
      const e = findingsById.get(fid);
      return e?.curve_type === "psychometric";
    }) ?? fit.finding_ids[0];
    const psyEntry = psyId ? findingsById.get(psyId) ?? null : null;
    const condition = psyEntry?.stratification?.condition ?? null;
    const subject = psyEntry?.stratification?.subject_id ?? null;
    let group = "all";
    if (condition && subject) group = `${condition} · ${subject}`;
    else if (condition) group = condition;
    else if (subject) group = subject;
    else if (psyEntry) group = psyEntry.paper_citation.split(".")[0];
    rows.push({
      fit,
      group,
      variant: fit.variant_id.replace("model_variant.", ""),
      aic: fit.quality?.aic ?? null,
      bic: fit.quality?.bic ?? null,
      log_likelihood: fit.quality?.log_likelihood ?? null,
      params: fit.parameters,
      paper_id: psyEntry?.paper_id ?? null,
      finding_id: psyEntry?.finding_id ?? null,
    });
  }
  return rows;
}

function bestVariantPerGroup(rows: ModelFitRow[]): Map<string, string> {
  const winners = new Map<string, string>();
  const groups = new Map<string, ModelFitRow[]>();
  for (const r of rows) {
    if (!groups.has(r.group)) groups.set(r.group, []);
    groups.get(r.group)!.push(r);
  }
  for (const [group, list] of groups) {
    let best: ModelFitRow | null = null;
    for (const r of list) {
      if (r.aic === null) continue;
      if (best === null || (best.aic !== null && r.aic < best.aic)) best = r;
    }
    if (best) winners.set(group, best.variant);
  }
  return winners;
}

function uniqueVariants(rows: ModelFitRow[]): string[] {
  const seen: string[] = [];
  for (const r of rows) if (!seen.includes(r.variant)) seen.push(r.variant);
  return seen;
}

function paramSummary(params: Record<string, number>): string {
  return Object.entries(params)
    .map(([k, v]) => {
      const abs = Math.abs(v);
      const fmtv = abs !== 0 && (abs < 0.01 || abs > 1000) ? v.toExponential(2) : v.toFixed(3);
      return `${k}=${fmtv}`;
    })
    .join(" · ");
}

const sections = COMPARISONS.map((spec) => {
  const entries = pickEntries(spec.finding_ids);
  const fits = entries
    .map((entry) => {
      const fit = (entry as FindingsEntry & { fit?: FitFields | null }).fit;
      return fit ? { entry, fit } : null;
    })
    .filter((row): row is { entry: FindingsEntry; fit: FitFields } => row !== null);
  // Pairwise deltas relative to the first row (when present).
  const reference = fits[0] ?? null;
  const deltas = fits.map((row) => ({
    label: entryLabel(row.entry),
    finding_id: row.entry.finding_id,
    paper_id: row.entry.paper_id,
    mu: row.fit.mu,
    sigma: row.fit.sigma,
    threshold: Number.isFinite(row.fit.threshold) ? row.fit.threshold : null,
    delta_mu: reference ? row.fit.mu - reference.fit.mu : 0,
    delta_sigma: reference ? row.fit.sigma - reference.fit.sigma : 0,
    delta_threshold:
      reference &&
      Number.isFinite(row.fit.threshold) &&
      Number.isFinite(reference.fit.threshold)
        ? row.fit.threshold - reference.fit.threshold
        : null,
    is_reference: row === reference,
  }));
  const modelFitRows = fitsForComparison(spec);
  const variants = uniqueVariants(modelFitRows);
  const winners = bestVariantPerGroup(modelFitRows);
  const groups = Array.from(new Set(modelFitRows.map((r) => r.group))).sort();
  const isHomogeneous = modelFitRows.length > 0 && variants.length === 1;
  // Detect DDM family for the strip-plot view.
  const isDdmHomogeneous =
    isHomogeneous &&
    (variants[0]?.startsWith("ddm-") ?? false);
  const ddmRows = isDdmHomogeneous
    ? modelFitRows.map((r) => {
        const psyId = r.fit.finding_ids.find((fid) => {
          const e = findingsById.get(fid);
          return e?.curve_type === "psychometric";
        }) ?? r.fit.finding_ids[0];
        const psyEntry = psyId ? findingsById.get(psyId) ?? null : null;
        return {
          fit_id: r.fit.id,
          variant: r.variant,
          paper_id: psyEntry?.paper_id ?? "",
          paper_label: psyEntry?.paper_citation.split(".")[0] ?? r.fit.id,
          species: psyEntry?.species ?? "unknown",
          subject_id: psyEntry?.stratification?.subject_id ?? null,
          condition: psyEntry?.stratification?.condition ?? null,
          drift_per_unit_evidence: r.fit.parameters.drift_per_unit_evidence ?? NaN,
          boundary: r.fit.parameters.boundary ?? NaN,
          non_decision_time: r.fit.parameters.non_decision_time ?? NaN,
          starting_point: r.fit.parameters.starting_point ?? null,
          drift_bias: r.fit.parameters.drift_bias ?? null,
          aic: r.fit.quality?.aic ?? null,
        };
      })
    : [];
  return {
    spec,
    entries,
    deltas,
    has_fits: fits.length > 0,
    target_y_label:
      fits[0] && fits[0].fit.threshold_target_y === 0.84 ? "x at 84%" : "x at 75%",
    modelFitRows,
    variants,
    winners,
    groups,
    isHomogeneous,
    isDdmHomogeneous,
    ddmRows,
  };
});
---

<BaseLayout
  title="Compare · behavtaskatlas"
  description="Pre-baked cross-paper comparisons that answer specific questions: prior-block shifts, species differences, cueing effects, all on shared signed-evidence axes with fitted parameter deltas."
  width="wide"
>
  <PageHeader title="Compare">
    <Fragment slot="lede">
      Curated cross-paper comparisons that answer one question each. Each
      panel embeds the relevant findings overlaid on shared signed-evidence
      axes and reports fitted parameter deltas computed at build time from a
      4-parameter logistic fit to each finding. For an arbitrary
      paper-pair view, see{" "}
      <a class="text-accent" href="/compare/papers">/compare/papers</a>.
    </Fragment>
    <Fragment slot="meta">
      <p class="text-body-xs text-fg-muted">
        Comparisons are hand-curated; the underlying findings live in{" "}
        <code class="rounded bg-surface-sunken px-1 text-mono-id">findings/</code>
        and the complete catalog is on
        <a class="text-accent" href="/findings">/findings</a>.
      </p>
    </Fragment>
  </PageHeader>

  <Card
    as="aside"
    padding="md"
    class="mb-10 text-body"
    aria-label="Reading the parameter columns"
  >
    <h2 class="mb-2 text-eyebrow uppercase text-fg-muted">Reading the deltas</h2>
    <dl class="grid grid-cols-1 gap-x-6 gap-y-2 text-body-xs sm:grid-cols-3">
      <div>
        <dt class="font-mono text-fg">Δμ</dt>
        <dd class="text-fg-secondary">
          Bias shift along the x-axis (in stimulus units). Positive Δμ means
          the curve moved rightward relative to the reference.
        </dd>
      </div>
      <div>
        <dt class="font-mono text-fg">Δσ</dt>
        <dd class="text-fg-secondary">
          Slope change. Larger σ = shallower psychometric (lower
          discriminability). |Δσ|≈0 means sensitivity is preserved.
        </dd>
      </div>
      <div>
        <dt class="font-mono text-fg">Δ threshold</dt>
        <dd class="text-fg-secondary">
          Difference in the x at which P(right)=75% (or 84% for accuracy
          curves). Same direction as Δμ but reads in stimulus units.
        </dd>
      </div>
    </dl>
  </Card>

  <div class="space-y-12">
    {sections.map((section) => (
      <Card
        as="section"
        padding="lg"
        id={section.spec.id}
        class="scroll-mt-20"
      >
        <header class="group/header mb-4 flex items-baseline justify-between gap-3">
          <h2 class="text-h3 text-fg">{section.spec.question}</h2>
          <a
            class="shrink-0 rounded border border-rule bg-surface px-2 py-0.5 font-mono text-mono-id text-fg-muted no-underline transition-colors hover:border-accent hover:text-accent focus:border-accent focus:text-accent group-hover/header:text-fg-secondary"
            href={`#${section.spec.id}`}
            aria-label={`Permalink to ${section.spec.question}`}
            title="Copy permalink"
          >
            <span aria-hidden="true">#</span> link
          </a>
        </header>
        <p class="mb-4 text-body text-fg-secondary">{section.spec.framing}</p>
        {section.entries.length > 0 ? (
          <MiniFindingsChart
            client:visible
            findings={section.entries}
            colorBy={section.spec.color_by as "paper" | "condition" | "curve_type"}
            height={320}
          />
        ) : section.modelFitRows.length === 0 ? (
          <Card padding="sm" surface="warn" border="tinted" class="text-body-xs text-warn">
            None of the referenced findings or fits are present in the
            index. Edit the comparison's
            <code class="ml-1 rounded bg-surface-sunken px-1">
              comparisons/*.yaml
            </code>
            record or fix its
            <code class="ml-1 rounded bg-surface-sunken px-1">finding_ids</code>
            /
            <code class="rounded bg-surface-sunken px-1">model_fit_ids</code>.
          </Card>
        ) : null}

        {section.isDdmHomogeneous && section.ddmRows.length > 0 ? (
          <div class="mt-4">
            <h3 class="mb-1 text-eyebrow uppercase text-fg-muted">
              Parameter strip plot · {section.variants[0]}
            </h3>
            <p class="mb-2 text-mono-id text-fg-muted">
              {section.ddmRows.length} fits, all sharing variant{" "}
              <code class="font-mono">{section.variants[0]}</code>. Hover a
              point for fit id, paper, and stratification.
            </p>
            <DdmParamScatter client:visible fits={section.ddmRows} height={240} />
          </div>
        ) : null}

        {section.modelFitRows.length > 0 ? (
          <details class="mt-4 rounded-md border border-rule bg-surface-raised">
            <summary class="cursor-pointer px-4 py-3 text-body font-semibold text-fg-secondary hover:text-accent">
              Model-fit comparison
              <span class="ml-2 text-body-xs font-normal text-fg-muted">
                ({section.modelFitRows.length} fits across {section.variants.length}
                variant{section.variants.length === 1 ? "" : "s"})
              </span>
            </summary>
            <div class="border-t border-rule p-4">
              <p class="mb-2 text-mono-id text-fg-muted">
                Lower AIC wins (★). <span class="text-fg-secondary">{section.spec.hint}</span>
              </p>
              <DataTable
                density="compact"
                headerRows={[
                  [
                    { label: "Group", rowspan: 2 },
                    ...section.variants.map((v) => ({
                      label: v,
                      align: "right" as const,
                      colspan: 2,
                    })),
                  ],
                  [
                    ...section.variants.flatMap(() => [
                      { label: "AIC", align: "right" as const },
                      { label: "params" },
                    ]),
                  ],
                ]}
              >
                {section.groups.map((group) => (
                  <tr>
                    <td class="px-3 py-2 font-mono text-mono-id text-fg-secondary">
                      {group}
                    </td>
                    {section.variants.map((v) => {
                      const row = section.modelFitRows.find(
                        (r) => r.group === group && r.variant === v,
                      );
                      if (!row) {
                        return (
                          <>
                            <td class="px-3 py-2 text-right text-fg-subtle">—</td>
                            <td class="px-3 py-2 text-fg-subtle">—</td>
                          </>
                        );
                      }
                      const isWinner = section.winners.get(group) === v;
                      return (
                        <>
                          <td class="px-3 py-2 text-right font-mono">
                            {isWinner ? "★ " : ""}
                            {fmt(row.aic, 1)}
                          </td>
                          <td class="px-3 py-2 font-mono text-mono-id text-fg-secondary">
                            {paramSummary(row.params)}
                          </td>
                        </>
                      );
                    })}
                  </tr>
                ))}
              </DataTable>
            </div>
          </details>
        ) : null}

        {section.has_fits ? (
          <details class="mt-3 rounded-md border border-rule bg-surface-raised">
            <summary class="cursor-pointer px-4 py-3 text-body font-semibold text-fg-secondary hover:text-accent">
              Fitted parameters
              <span class="ml-2 text-body-xs font-normal text-fg-muted">
                ({section.deltas.length} row{section.deltas.length === 1 ? "" : "s"} · Δ relative to reference)
              </span>
            </summary>
            <div class="border-t border-rule p-4">
              <p class="mb-2 text-mono-id text-fg-muted">
                Deltas relative to the first row.
                <span class="text-fg-secondary">{section.spec.hint}</span>
              </p>
              <DataTable
                density="compact"
                columns={[
                  { label: "Finding" },
                  { label: "μ (bias)", align: "right", title: "Mid-asymptote crossing (psychometric bias)" },
                  { label: "σ (slope)", align: "right", title: "Slope width; larger σ = shallower psychometric" },
                  { label: section.target_y_label, align: "right", title: "x-value where the fitted curve crosses the threshold target" },
                  { label: "Δμ", align: "right", title: "Bias shift relative to reference row" },
                  { label: "Δσ", align: "right", title: "Slope change relative to reference row" },
                  { label: "Δ threshold", align: "right", title: "Threshold-crossing change relative to reference row" },
                ]}
              >
                {section.deltas.map((row) => (
                  <tr class={row.is_reference ? "bg-surface" : ""}>
                    <td class="px-3 py-2">
                      <a href={`/papers/${slugForId(row.paper_id)}`}>
                        {row.label}
                      </a>
                      {row.is_reference ? (
                        <span class="ml-2 text-mono-id text-fg-muted">
                          (reference)
                        </span>
                      ) : null}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">{fmt(row.mu)}</td>
                    <td class="px-3 py-2 text-right font-mono">{fmt(row.sigma)}</td>
                    <td class="px-3 py-2 text-right font-mono">
                      {fmt(row.threshold)}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {row.is_reference ? "—" : fmt(row.delta_mu)}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {row.is_reference ? "—" : fmt(row.delta_sigma)}
                    </td>
                    <td class="px-3 py-2 text-right font-mono">
                      {row.is_reference ? "—" : fmt(row.delta_threshold)}
                    </td>
                  </tr>
                ))}
              </DataTable>
            </div>
          </details>
        ) : (
          <p class="mt-3 text-mono-id text-fg-muted">
            No 4-parameter logistic fit applies (curve type does not support
            it, or fits failed). Visual comparison only.
          </p>
        )}
      </Card>
    ))}
  </div>

  <p class="mt-8 text-body-xs text-fg-muted">
    These comparisons are pre-baked at build time; the underlying logistic
    fits are computed by{" "}
    <code class="rounded bg-surface-sunken px-1">behavtaskatlas site-index</code>
    using the same model as the interactive fitter on{" "}
    <a class="text-accent" href="/findings">/findings</a>, so values agree.
    Curate new comparisons by adding a YAML file under
    <code class="ml-1 rounded bg-surface-sunken px-1">comparisons/</code>
    in the repository.
  </p>
</BaseLayout>
