---
const items = [
  { href: "/", label: "Overview" },
  { href: "/catalog", label: "Catalog" },
  { href: "/slices", label: "Slices" },
  { href: "/graph", label: "Graph" },
  { href: "/curation-queue", label: "Curation queue" },
  { href: "/about", label: "About" },
];
---

<nav class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="font-semibold tracking-tight text-slate-900 no-underline">
      behavtaskatlas
    </a>
    <ul class="flex gap-5 text-sm">
      {
        items.map((item) => (
          <li>
            <a href={item.href} class="text-slate-700 no-underline hover:text-accent">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
