---
const items = [
  { href: "/", label: "Overview" },
  { href: "/catalog", label: "Catalog" },
  { href: "/slices", label: "Slices" },
  { href: "/papers", label: "Papers" },
  { href: "/findings", label: "Findings" },
  { href: "/models", label: "Models" },
  { href: "/compare", label: "Compare" },
  { href: "/graph", label: "Graph" },
  { href: "/curation-queue", label: "Curation queue" },
  { href: "/audit", label: "Audit" },
  { href: "/about", label: "About" },
];
---

<nav class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 py-3">
    <a href="/" class="font-semibold tracking-tight text-slate-900 no-underline">
      behavtaskatlas
    </a>
    <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
      {
        items.map((item) => (
          <li>
            <a href={item.href} class="text-slate-700 no-underline hover:text-accent">
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <form action="/search" method="get" class="flex items-center">
          <input
            type="search"
            name="q"
            placeholder="Search…"
            aria-label="Search the atlas"
            class="w-44 rounded-md border border-slate-300 bg-white px-2 py-1 text-xs focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            autocomplete="off"
          />
        </form>
      </li>
    </ul>
  </div>
</nav>
