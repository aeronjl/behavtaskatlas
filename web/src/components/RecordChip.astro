---
type RecordType =
  | "paper"
  | "protocol"
  | "dataset"
  | "slice"
  | "finding"
  | "family"
  | "comparison"
  | "fit"
  | "variant";

interface Props {
  type: RecordType;
  label: string;
  href?: string | null;
  id?: string | null;
  size?: "sm" | "md";
}

const { type, label, href, id, size = "sm" } = Astro.props as Props;

const TYPE_LABELS: Record<RecordType, string> = {
  paper: "paper",
  protocol: "protocol",
  dataset: "dataset",
  slice: "slice",
  finding: "finding",
  family: "family",
  comparison: "comparison",
  fit: "fit",
  variant: "variant",
};

const padding = size === "md" ? "px-2.5 py-1" : "px-2 py-0.5";
const textSize = size === "md" ? "text-sm" : "text-xs";
const baseClasses = `inline-flex max-w-full min-w-0 items-baseline gap-1.5 rounded border border-rule bg-surface-raised ${padding} ${textSize} font-normal text-fg-secondary`;
---

{href ? (
  <a
    href={href}
    class={`${baseClasses} no-underline transition-colors hover:border-accent hover:text-accent`}
  >
    <span class="text-[10px] uppercase tracking-wide text-fg-muted">
      {TYPE_LABELS[type]}
    </span>
    <span class="min-w-0 truncate">{label}</span>
    {id ? <span class="font-mono text-[10px] text-fg-subtle">{id}</span> : null}
  </a>
) : (
  <span class={baseClasses}>
    <span class="text-[10px] uppercase tracking-wide text-fg-muted">
      {TYPE_LABELS[type]}
    </span>
    <span class="min-w-0 truncate">{label}</span>
    {id ? <span class="font-mono text-[10px] text-fg-subtle">{id}</span> : null}
  </span>
)}
