---
import { catalog, models, papers, slugForId } from "../lib/data";
import { findings } from "../lib/findings";

type Protocol = (typeof catalog.protocols)[number];
type Dataset = (typeof catalog.datasets)[number];
type Slice = (typeof catalog.vertical_slices)[number];
type Paper = (typeof papers.papers)[number];
type Finding = (typeof findings.findings)[number];
type ModelFit = (typeof models.fits)[number];

type FamilyRow = {
  family: (typeof catalog.task_families)[number];
  protocols: Protocol[];
  datasets: Dataset[];
  slices: Slice[];
  papers: Paper[];
  findings: Finding[];
  modelFits: ModelFit[];
  species: string[];
  modalities: string[];
  sourceLevels: string[];
  reportCount: number;
  links: {
    catalog: string;
    papers: string;
    findings: string;
    reports: string;
    slices: string;
    models: string;
  };
};

const datasetById = new Map(catalog.datasets.map((dataset) => [dataset.dataset_id, dataset]));
const findingRows = findings.findings as Finding[];
const modelFitRows = models.fits as ModelFit[];

function unique(values: Iterable<string | null | undefined>): string[] {
  return Array.from(new Set(Array.from(values).filter((value): value is string => Boolean(value)))).sort();
}

function href(path: string, params: Record<string, string | undefined>): string {
  const search = new URLSearchParams();
  for (const [key, value] of Object.entries(params)) {
    if (value) search.set(key, value);
  }
  const query = search.toString();
  return `${path}${query ? `?${query}` : ""}`;
}

function readable(value: string): string {
  if (value === "non-human-primate") return "NHP";
  if (value === "processed-trial") return "processed trials";
  if (value === "raw-trial") return "raw trials";
  if (value === "figure-source-data") return "figure source data";
  return value.replace(/[_-]/g, " ");
}

function familyHash(familyId: string): string {
  return slugForId(familyId);
}

function rowDepthLabel(row: FamilyRow): string {
  if (row.findings.length >= 20 && row.modelFits.length > 0) return "deep";
  if (row.findings.length > 0 && row.modelFits.length > 0) return "modeled";
  if (row.slices.length > 0) return "source-backed";
  return "bibliography";
}

function nextAction(row: FamilyRow): { label: string; href: string; tone: string } {
  if (row.findings.length === 0 && row.slices.length > 0) {
    return {
      label: "extract findings",
      href: row.links.slices,
      tone: "bg-warn-soft text-warn",
    };
  }
  if (row.modelFits.length === 0 && row.findings.length > 0) {
    return {
      label: "fit models",
      href: row.links.findings,
      tone: "bg-encoding-model-ddm-soft text-encoding-model-ddm-strong",
    };
  }
  if (row.reportCount < row.slices.length) {
    return {
      label: "finish reports",
      href: href("/slices", { family: row.family.name, report: "missing" }),
      tone: "bg-bad-soft text-bad",
    };
  }
  return {
    label: row.findings.length >= 20 ? "inspect depth" : "inspect coverage",
    href: row.findings.length > 0 ? row.links.findings : row.links.catalog,
    tone: "bg-ok-soft text-ok",
  };
}

// Heat-map cell style. Mixes a CSS encoding token with white via
// color-mix() so a single token swap propagates everywhere. Alpha floors
// at 20% for non-empty cells (keeps cells visually distinguishable from
// white at the lowest count) and 4% for empty (effectively no fill).
function heatStyle(value: number, max: number, varName: string): string {
  const ratio = max > 0 ? value / max : 0;
  const fillPct = value > 0 ? Math.round(20 + 50 * ratio) : 4;
  const borderPct = value > 0 ? Math.round(28 + 40 * ratio) : 12;
  return `background-color: color-mix(in srgb, var(${varName}) ${fillPct}%, white); border-color: color-mix(in srgb, var(${varName}) ${borderPct}%, white);`;
}

function barWidth(value: number, max: number): string {
  if (max <= 0) return "0%";
  return `${Math.max(4, Math.round((value / max) * 100))}%`;
}

function sourceRank(levels: string[]): number {
  if (levels.includes("raw-trial")) return 3;
  if (levels.includes("processed-trial")) return 2;
  if (levels.includes("figure-source-data")) return 1;
  return 0;
}

const familyRows: FamilyRow[] = catalog.task_families
  .map((family) => {
    const protocols = catalog.protocols.filter((protocol) => protocol.family_id === family.family_id);
    const protocolIds = new Set(protocols.map((protocol) => protocol.protocol_id));
    const datasetIds = new Set(protocols.flatMap((protocol) => protocol.dataset_ids ?? []));
    const datasets = Array.from(datasetIds)
      .map((id) => datasetById.get(id))
      .filter((dataset): dataset is Dataset => Boolean(dataset));
    const slices = catalog.vertical_slices.filter((slice) => slice.family_id === family.family_id);
    const familyFindings = findingRows.filter((finding) => finding.family_id === family.family_id);
    const familyFindingIds = new Set(familyFindings.map((finding) => finding.finding_id));
    const paperIdsFromFindings = new Set(familyFindings.map((finding) => finding.paper_id));
    const familyPapers = papers.papers.filter(
      (paper) =>
        (paper.protocol_ids ?? []).some((protocolId) => protocolIds.has(protocolId)) ||
        paperIdsFromFindings.has(paper.id),
    );
    const familyModelFits = modelFitRows.filter((fit) =>
      (fit.finding_ids ?? []).some((findingId) => familyFindingIds.has(findingId)),
    );
    const protocolNames = protocols.map((protocol) => protocol.name).join(",");
    const sourceLevels = unique([
      ...datasets.map((dataset) => dataset.source_data_level),
      ...slices.map((slice) => slice.source_data_level),
      ...familyFindings.map((finding) => finding.source_data_level),
    ]);

    return {
      family,
      protocols,
      datasets,
      slices,
      papers: familyPapers,
      findings: familyFindings,
      modelFits: familyModelFits,
      species: unique(protocols.flatMap((protocol) => protocol.species ?? [])),
      modalities: unique(protocols.flatMap((protocol) => protocol.modalities ?? [])),
      sourceLevels,
      reportCount: slices.filter((slice) => slice.report_status === "available").length,
      links: {
        catalog: `${href("/catalog", { q: family.name })}#${familyHash(family.family_id)}`,
        papers: protocolNames ? href("/papers", { protocol: protocolNames }) : href("/papers", { q: family.name }),
        findings: href("/findings", { q: family.name }),
        reports: href("/slices", { family: family.name, report: "available" }),
        slices: href("/slices", { family: family.name }),
        models: href("/models", { model_family: family.name }),
      },
    };
  })
  .sort(
    (a, b) =>
      b.findings.length - a.findings.length ||
      b.modelFits.length - a.modelFits.length ||
      a.family.name.localeCompare(b.family.name),
  );

const maxFindings = Math.max(1, ...familyRows.map((row) => row.findings.length));
const maxModels = Math.max(1, ...familyRows.map((row) => row.modelFits.length));

const sourceOrder = ["raw-trial", "processed-trial", "figure-source-data"];
const deepestRows = familyRows.filter((row) => row.findings.length > 0).slice(0, 3);
const gapRows = familyRows.filter((row) => row.findings.length === 0 && row.slices.length > 0);
---

<section data-testid="atlas-overview" class="mb-12 min-w-0">
  <header class="mb-4 flex flex-wrap items-end justify-between gap-3">
    <div>
      <p class="text-eyebrow uppercase text-fg-muted">Family coverage</p>
      <h2 class="mt-1 text-h2 text-fg">
        Where the atlas runs deep, where it doesn't
      </h2>
    </div>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-body-xs text-fg-muted">
      <span class="inline-flex items-center gap-1">
        <span class="h-2 w-2 rounded-full bg-encoding-source-raw"></span> raw
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="h-2 w-2 rounded-full bg-encoding-source-processed"></span> processed
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="h-2 w-2 rounded-full bg-encoding-source-figure"></span> figure
      </span>
    </div>
  </header>

  <div class="grid min-w-0 grid-cols-1 gap-4">
    <article class="min-w-0 overflow-hidden rounded-md border border-rule bg-surface-raised">
      <div class="-mx-px max-w-full overflow-x-auto">
        <table class="min-w-[44rem] w-full border-separate border-spacing-y-1 text-body-xs">
          <thead>
            <tr class="text-left text-eyebrow uppercase text-fg-muted">
              <th class="w-[18rem] px-3 py-2 font-medium">Family</th>
              <th class="px-2 py-2 text-right font-medium">Findings</th>
              <th class="px-2 py-2 text-right font-medium">Models</th>
              <th class="px-3 py-2 font-medium">Source</th>
              <th class="px-3 py-2 font-medium">Next</th>
            </tr>
          </thead>
          <tbody>
            {familyRows.map((row) => {
              const action = nextAction(row);
              const tags = [...row.species, ...row.modalities];
              return (
                <tr data-testid="atlas-overview-row" class="align-middle">
                  <th class="rounded-l-md border-y border-l border-rule bg-surface px-3 py-2 text-left">
                    <a href={row.links.catalog} class="font-semibold text-fg">
                      {row.family.name}
                    </a>
                    <p class="mt-1 text-mono-id text-fg-muted">
                      <span class="rounded bg-surface-raised px-1.5 py-0.5 ring-1 ring-rule">
                        {rowDepthLabel(row)}
                      </span>
                      {tags.length > 0 ? (
                        <span class="ml-2">
                          {tags.map(readable).join(" · ")}
                        </span>
                      ) : null}
                    </p>
                  </th>
                  <td class="border-y border-rule bg-surface-raised px-2 py-2 text-right">
                    <a
                      href={row.links.findings}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-fg no-underline"
                      style={heatStyle(row.findings.length, maxFindings, "--color-encoding-coverage-findings")}
                      aria-label={`${row.family.name}: ${row.findings.length} findings`}
                    >
                      {row.findings.length}
                    </a>
                  </td>
                  <td class="border-y border-rule bg-surface-raised px-2 py-2 text-right">
                    <a
                      href={row.links.models}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-fg no-underline"
                      style={heatStyle(row.modelFits.length, maxModels, "--color-encoding-model-ddm")}
                      aria-label={`${row.family.name}: ${row.modelFits.length} model fits`}
                    >
                      {row.modelFits.length}
                    </a>
                  </td>
                  <td class="border-y border-rule bg-surface-raised px-3 py-2">
                    <div class="flex min-w-24 overflow-hidden rounded-full border border-rule bg-surface-sunken" title={row.sourceLevels.map(readable).join(", ") || "no source level"}>
                      {sourceOrder.map((level) => (
                        <a
                          href={href("/catalog", { q: row.family.name, source: level })}
                          class:list={[
                            "h-2 flex-1",
                            row.sourceLevels.includes(level)
                              ? level === "raw-trial"
                                ? "bg-encoding-source-raw"
                                : level === "processed-trial"
                                  ? "bg-encoding-source-processed"
                                  : "bg-encoding-source-figure"
                              : "bg-transparent",
                          ]}
                          aria-label={`${row.family.name}: ${readable(level)} ${row.sourceLevels.includes(level) ? "available" : "missing"}`}
                        />
                      ))}
                    </div>
                    <span class="sr-only">source rank {sourceRank(row.sourceLevels)}</span>
                  </td>
                  <td class="rounded-r-md border-y border-r border-rule bg-surface-raised px-3 py-2">
                    <a
                      href={action.href}
                      class:list={[
                        "inline-flex whitespace-nowrap rounded px-2 py-1 text-body-xs no-underline",
                        action.tone,
                      ]}
                    >
                      {action.label}
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </article>

    <aside class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <section class="rounded-md border border-rule bg-surface-raised p-4">
        <h3 class="text-h3 text-fg">Deepest Families</h3>
        <ul class="mt-3 space-y-3">
          {deepestRows.map((row) => (
            <li>
              <a href={row.links.findings} class="block no-underline">
                <span class="flex items-baseline justify-between gap-3 text-body-xs">
                  <span class="font-medium text-fg">{row.family.name}</span>
                  <span class="font-mono text-fg-secondary">{row.findings.length} findings</span>
                </span>
                <span class="mt-1 block h-1.5 rounded-full bg-surface-sunken">
                  <span
                    class="block h-1.5 rounded-full bg-encoding-coverage-findings"
                    style={`width: ${barWidth(row.findings.length, maxFindings)}`}
                  />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="rounded-md border border-rule bg-surface-raised p-4">
        <h3 class="text-h3 text-fg">Source-Backed Gaps</h3>
        {gapRows.length > 0 ? (
          <ul class="mt-3 space-y-2 text-body-xs">
            {gapRows.map((row) => (
              <li class="flex items-start justify-between gap-3">
                <a href={row.links.slices} class="text-fg">
                  {row.family.name}
                </a>
                <span class="shrink-0 rounded bg-warn-soft px-1.5 py-0.5 font-mono text-warn">
                  {row.slices.length}s / 0f
                </span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-2 text-body-xs text-fg-secondary">
            Every source-backed family has at least one extracted finding.
          </p>
        )}
      </section>
    </aside>
  </div>
</section>
