---
import { catalog, models, papers, slugForId } from "../lib/data";
import { findings } from "../lib/findings";

type Protocol = (typeof catalog.protocols)[number];
type Dataset = (typeof catalog.datasets)[number];
type Slice = (typeof catalog.vertical_slices)[number];
type Paper = (typeof papers.papers)[number];
type Finding = (typeof findings.findings)[number];
type ModelFit = (typeof models.fits)[number];

type FamilyRow = {
  family: (typeof catalog.task_families)[number];
  protocols: Protocol[];
  datasets: Dataset[];
  slices: Slice[];
  papers: Paper[];
  findings: Finding[];
  modelFits: ModelFit[];
  species: string[];
  modalities: string[];
  sourceLevels: string[];
  reportCount: number;
  links: {
    catalog: string;
    papers: string;
    findings: string;
    reports: string;
    slices: string;
    models: string;
  };
};

const datasetById = new Map(catalog.datasets.map((dataset) => [dataset.dataset_id, dataset]));
const findingRows = findings.findings as Finding[];
const modelFitRows = models.fits as ModelFit[];

function unique(values: Iterable<string | null | undefined>): string[] {
  return Array.from(new Set(Array.from(values).filter((value): value is string => Boolean(value)))).sort();
}

function href(path: string, params: Record<string, string | undefined>): string {
  const search = new URLSearchParams();
  for (const [key, value] of Object.entries(params)) {
    if (value) search.set(key, value);
  }
  const query = search.toString();
  return `${path}${query ? `?${query}` : ""}`;
}

function readable(value: string): string {
  if (value === "non-human-primate") return "NHP";
  if (value === "processed-trial") return "processed trials";
  if (value === "raw-trial") return "raw trials";
  if (value === "figure-source-data") return "figure source data";
  return value.replace(/[_-]/g, " ");
}

function familyHash(familyId: string): string {
  return slugForId(familyId);
}

function rowDepthLabel(row: FamilyRow): string {
  if (row.findings.length >= 20 && row.modelFits.length > 0) return "deep";
  if (row.findings.length > 0 && row.modelFits.length > 0) return "modeled";
  if (row.slices.length > 0) return "source-backed";
  return "bibliography";
}

function nextAction(row: FamilyRow): { label: string; href: string; tone: string } {
  if (row.findings.length === 0 && row.slices.length > 0) {
    return {
      label: "extract findings",
      href: row.links.slices,
      tone: "bg-amber-50 text-amber-800 ring-amber-200",
    };
  }
  if (row.modelFits.length === 0 && row.findings.length > 0) {
    return {
      label: "fit models",
      href: row.links.findings,
      tone: "bg-violet-50 text-violet-800 ring-violet-200",
    };
  }
  if (row.reportCount < row.slices.length) {
    return {
      label: "finish reports",
      href: href("/slices", { family: row.family.name, report: "missing" }),
      tone: "bg-rose-50 text-rose-800 ring-rose-200",
    };
  }
  return {
    label: row.findings.length >= 20 ? "inspect depth" : "inspect coverage",
    href: row.findings.length > 0 ? row.links.findings : row.links.catalog,
    tone: "bg-emerald-50 text-emerald-800 ring-emerald-200",
  };
}

function heatStyle(value: number, max: number, rgb: string): string {
  const ratio = max > 0 ? value / max : 0;
  const alpha = value > 0 ? 0.1 + 0.62 * ratio : 0.045;
  const border = value > 0 ? 0.2 + 0.5 * ratio : 0.12;
  return `background-color: rgba(${rgb}, ${alpha.toFixed(3)}); border-color: rgba(${rgb}, ${border.toFixed(3)});`;
}

function barWidth(value: number, max: number): string {
  if (max <= 0) return "0%";
  return `${Math.max(4, Math.round((value / max) * 100))}%`;
}

function sourceRank(levels: string[]): number {
  if (levels.includes("raw-trial")) return 3;
  if (levels.includes("processed-trial")) return 2;
  if (levels.includes("figure-source-data")) return 1;
  return 0;
}

const familyRows: FamilyRow[] = catalog.task_families
  .map((family) => {
    const protocols = catalog.protocols.filter((protocol) => protocol.family_id === family.family_id);
    const protocolIds = new Set(protocols.map((protocol) => protocol.protocol_id));
    const datasetIds = new Set(protocols.flatMap((protocol) => protocol.dataset_ids ?? []));
    const datasets = Array.from(datasetIds)
      .map((id) => datasetById.get(id))
      .filter((dataset): dataset is Dataset => Boolean(dataset));
    const slices = catalog.vertical_slices.filter((slice) => slice.family_id === family.family_id);
    const familyFindings = findingRows.filter((finding) => finding.family_id === family.family_id);
    const familyFindingIds = new Set(familyFindings.map((finding) => finding.finding_id));
    const paperIdsFromFindings = new Set(familyFindings.map((finding) => finding.paper_id));
    const familyPapers = papers.papers.filter(
      (paper) =>
        (paper.protocol_ids ?? []).some((protocolId) => protocolIds.has(protocolId)) ||
        paperIdsFromFindings.has(paper.id),
    );
    const familyModelFits = modelFitRows.filter((fit) =>
      (fit.finding_ids ?? []).some((findingId) => familyFindingIds.has(findingId)),
    );
    const protocolNames = protocols.map((protocol) => protocol.name).join(",");
    const sourceLevels = unique([
      ...datasets.map((dataset) => dataset.source_data_level),
      ...slices.map((slice) => slice.source_data_level),
      ...familyFindings.map((finding) => finding.source_data_level),
    ]);

    return {
      family,
      protocols,
      datasets,
      slices,
      papers: familyPapers,
      findings: familyFindings,
      modelFits: familyModelFits,
      species: unique(protocols.flatMap((protocol) => protocol.species ?? [])),
      modalities: unique(protocols.flatMap((protocol) => protocol.modalities ?? [])),
      sourceLevels,
      reportCount: slices.filter((slice) => slice.report_status === "available").length,
      links: {
        catalog: `${href("/catalog", { q: family.name })}#${familyHash(family.family_id)}`,
        papers: protocolNames ? href("/papers", { protocol: protocolNames }) : href("/papers", { q: family.name }),
        findings: href("/findings", { q: family.name }),
        reports: href("/slices", { family: family.name, report: "available" }),
        slices: href("/slices", { family: family.name }),
        models: href("/models", { model_family: family.name }),
      },
    };
  })
  .sort(
    (a, b) =>
      b.findings.length - a.findings.length ||
      b.modelFits.length - a.modelFits.length ||
      a.family.name.localeCompare(b.family.name),
  );

const maxProtocols = Math.max(1, ...familyRows.map((row) => row.protocols.length));
const maxDatasets = Math.max(1, ...familyRows.map((row) => row.datasets.length));
const maxReports = Math.max(1, ...familyRows.map((row) => row.reportCount));
const maxFindings = Math.max(1, ...familyRows.map((row) => row.findings.length));
const maxModels = Math.max(1, ...familyRows.map((row) => row.modelFits.length));
const maxPapers = Math.max(1, ...familyRows.map((row) => row.papers.length));

const sourceOrder = ["raw-trial", "processed-trial", "figure-source-data"];
const headlineStats = [
  { label: "families", value: catalog.counts.task_families ?? familyRows.length, href: "/catalog", color: "bg-teal-500" },
  { label: "protocols", value: catalog.counts.protocols ?? catalog.protocols.length, href: "/catalog?type=protocol", color: "bg-sky-500" },
  { label: "datasets", value: catalog.counts.datasets ?? catalog.datasets.length, href: "/catalog?type=dataset", color: "bg-emerald-500" },
  { label: "papers", value: papers.counts.papers ?? papers.papers.length, href: "/papers", color: "bg-indigo-500" },
  { label: "findings", value: findings.counts.findings ?? findingRows.length, href: "/findings", color: "bg-blue-600" },
  { label: "slices", value: catalog.counts.vertical_slices ?? catalog.vertical_slices.length, href: "/slices", color: "bg-amber-500" },
  { label: "model fits", value: models.counts.fits ?? modelFitRows.length, href: "/models", color: "bg-violet-500" },
];
const maxHeadline = Math.max(1, ...headlineStats.map((stat) => stat.value));
const deepestRows = familyRows.filter((row) => row.findings.length > 0).slice(0, 3);
const gapRows = familyRows.filter((row) => row.findings.length === 0 && row.slices.length > 0);
---

<section data-testid="atlas-overview" class="mb-12 min-w-0">
  <header class="mb-4">
    <p class="text-xs uppercase tracking-wide text-accent">Atlas overview</p>
    <h2 class="mt-1 text-2xl font-semibold tracking-tight text-slate-900">
      Coverage shape at a glance
    </h2>
    <p class="mt-2 max-w-3xl text-sm text-slate-700">
      Task families are arranged by finding depth. The matrix separates source
      depth, reports, extracted curves, and model fits so density and gaps are
      visible before opening individual records.
    </p>
  </header>

  <div class="mb-5 grid grid-cols-2 gap-2 md:grid-cols-4 lg:grid-cols-7">
    {headlineStats.map((stat) => (
      <a
        href={stat.href}
        class="rounded-md border border-slate-200 bg-white p-3 no-underline transition-colors hover:border-accent"
      >
        <span class="block text-[11px] uppercase tracking-wide text-slate-500">
          {stat.label}
        </span>
        <span class="mt-1 block font-mono text-xl font-semibold text-slate-950">
          {stat.value.toLocaleString()}
        </span>
        <span class="mt-2 block h-1.5 rounded-full bg-slate-100">
          <span
            class:list={["block h-1.5 rounded-full", stat.color]}
            style={`width: ${barWidth(stat.value, maxHeadline)}`}
          />
        </span>
      </a>
    ))}
  </div>

  <div class="grid min-w-0 grid-cols-1 gap-4">
    <article class="min-w-0 rounded-md border border-slate-200 bg-white p-4">
      <header class="mb-3 flex flex-wrap items-start justify-between gap-3">
        <div>
          <h3 class="text-base font-semibold text-slate-900">
            Family Coverage Matrix
          </h3>
          <p class="mt-1 text-xs text-slate-600">
            Darker cells mark deeper coverage; every count links to a filtered
            browse surface.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-slate-500">
          <span class="inline-flex items-center gap-1">
            <span class="h-2 w-2 rounded-full bg-emerald-500"></span> raw
          </span>
          <span class="inline-flex items-center gap-1">
            <span class="h-2 w-2 rounded-full bg-sky-500"></span> processed
          </span>
          <span class="inline-flex items-center gap-1">
            <span class="h-2 w-2 rounded-full bg-amber-500"></span> figure
          </span>
        </div>
      </header>

      <div class="-mx-4 max-w-full overflow-x-auto px-4">
        <table class="min-w-[56rem] w-full border-separate border-spacing-y-1 text-xs">
          <thead>
            <tr class="text-left text-[11px] uppercase tracking-wide text-slate-500">
              <th class="w-[16rem] px-2 py-1 font-medium">Family</th>
              <th class="px-2 py-1 font-medium">Species / modality</th>
              <th class="px-2 py-1 text-right font-medium">Papers</th>
              <th class="px-2 py-1 text-right font-medium">Protocols</th>
              <th class="px-2 py-1 text-right font-medium">Datasets</th>
              <th class="px-2 py-1 text-right font-medium">Reports</th>
              <th class="px-2 py-1 text-right font-medium">Findings</th>
              <th class="px-2 py-1 text-right font-medium">Models</th>
              <th class="px-2 py-1 font-medium">Source</th>
              <th class="px-2 py-1 font-medium">Next</th>
            </tr>
          </thead>
          <tbody>
            {familyRows.map((row) => {
              const action = nextAction(row);
              return (
                <tr data-testid="atlas-overview-row" class="align-middle">
                  <th class="rounded-l-md border-y border-l border-slate-200 bg-slate-50 px-2 py-2 text-left">
                    <a href={row.links.catalog} class="font-semibold text-slate-900">
                      {row.family.name}
                    </a>
                    <div class="mt-1 flex flex-wrap items-center gap-1">
                      <span class="rounded bg-white px-1.5 py-0.5 font-mono text-[10px] text-slate-500 ring-1 ring-slate-200">
                        {rowDepthLabel(row)}
                      </span>
                      <span class="font-mono text-[10px] text-slate-500">
                        {row.family.family_id.replace("family.", "")}
                      </span>
                    </div>
                  </th>
                  <td class="border-y border-slate-200 bg-white px-2 py-2">
                    <div class="flex max-w-[13rem] flex-wrap gap-1">
                      {[...row.species, ...row.modalities].map((value) => (
                        <span class="rounded bg-slate-100 px-1.5 py-0.5 text-[10px] text-slate-700">
                          {readable(value)}
                        </span>
                      ))}
                    </div>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-1 py-2 text-right">
                    <a
                      href={row.links.papers}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-slate-900 no-underline"
                      style={heatStyle(row.papers.length, maxPapers, "79, 70, 229")}
                      aria-label={`${row.family.name}: ${row.papers.length} papers`}
                    >
                      {row.papers.length}
                    </a>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-1 py-2 text-right">
                    <a
                      href={row.links.catalog}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-slate-900 no-underline"
                      style={heatStyle(row.protocols.length, maxProtocols, "14, 165, 233")}
                      aria-label={`${row.family.name}: ${row.protocols.length} protocols`}
                    >
                      {row.protocols.length}
                    </a>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-1 py-2 text-right">
                    <a
                      href={row.links.catalog}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-slate-900 no-underline"
                      style={heatStyle(row.datasets.length, maxDatasets, "16, 185, 129")}
                      aria-label={`${row.family.name}: ${row.datasets.length} datasets`}
                    >
                      {row.datasets.length}
                    </a>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-1 py-2 text-right">
                    <a
                      href={row.links.reports}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-slate-900 no-underline"
                      style={heatStyle(row.reportCount, maxReports, "20, 184, 166")}
                      aria-label={`${row.family.name}: ${row.reportCount} reports`}
                    >
                      {row.reportCount}/{row.slices.length}
                    </a>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-1 py-2 text-right">
                    <a
                      href={row.links.findings}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-slate-900 no-underline"
                      style={heatStyle(row.findings.length, maxFindings, "37, 99, 235")}
                      aria-label={`${row.family.name}: ${row.findings.length} findings`}
                    >
                      {row.findings.length}
                    </a>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-1 py-2 text-right">
                    <a
                      href={row.links.models}
                      class="inline-flex min-w-10 justify-end rounded border px-2 py-1 font-mono text-slate-900 no-underline"
                      style={heatStyle(row.modelFits.length, maxModels, "124, 58, 237")}
                      aria-label={`${row.family.name}: ${row.modelFits.length} model fits`}
                    >
                      {row.modelFits.length}
                    </a>
                  </td>
                  <td class="border-y border-slate-200 bg-white px-2 py-2">
                    <div class="flex min-w-24 overflow-hidden rounded-full border border-slate-200 bg-slate-100" title={row.sourceLevels.map(readable).join(", ") || "no source level"}>
                      {sourceOrder.map((level) => (
                        <a
                          href={href("/catalog", { q: row.family.name, source: level })}
                          class:list={[
                            "h-2 flex-1",
                            row.sourceLevels.includes(level)
                              ? level === "raw-trial"
                                ? "bg-emerald-500"
                                : level === "processed-trial"
                                  ? "bg-sky-500"
                                  : "bg-amber-500"
                              : "bg-transparent",
                          ]}
                          aria-label={`${row.family.name}: ${readable(level)} ${row.sourceLevels.includes(level) ? "available" : "missing"}`}
                        />
                      ))}
                    </div>
                    <span class="sr-only">source rank {sourceRank(row.sourceLevels)}</span>
                  </td>
                  <td class="rounded-r-md border-y border-r border-slate-200 bg-white px-2 py-2">
                    <a
                      href={action.href}
                      class:list={[
                        "inline-flex whitespace-nowrap rounded px-2 py-1 text-[11px] no-underline ring-1",
                        action.tone,
                      ]}
                    >
                      {action.label}
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </article>

    <aside class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <section class="rounded-md border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-semibold text-slate-900">Deepest Families</h3>
        <ul class="mt-3 space-y-3">
          {deepestRows.map((row) => (
            <li>
              <a href={row.links.findings} class="block no-underline">
                <span class="flex items-baseline justify-between gap-3 text-xs">
                  <span class="font-medium text-slate-800">{row.family.name}</span>
                  <span class="font-mono text-slate-600">{row.findings.length} findings</span>
                </span>
                <span class="mt-1 block h-1.5 rounded-full bg-slate-100">
                  <span
                    class="block h-1.5 rounded-full bg-blue-600"
                    style={`width: ${barWidth(row.findings.length, maxFindings)}`}
                  />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="rounded-md border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-semibold text-slate-900">Source-Backed Gaps</h3>
        {gapRows.length > 0 ? (
          <ul class="mt-3 space-y-2 text-xs">
            {gapRows.map((row) => (
              <li class="flex items-start justify-between gap-3">
                <a href={row.links.slices} class="text-slate-800">
                  {row.family.name}
                </a>
                <span class="shrink-0 rounded bg-amber-50 px-1.5 py-0.5 font-mono text-amber-800">
                  {row.slices.length}s / 0f
                </span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-2 text-xs text-slate-600">
            Every source-backed family has at least one extracted finding.
          </p>
        )}
      </section>
    </aside>
  </div>
</section>

<style>
  a.no-underline {
    text-decoration: none;
  }

  a.no-underline:hover {
    text-decoration: none;
  }
</style>
