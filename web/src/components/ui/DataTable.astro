---
/**
 * DataTable — bordered table shell with auto-generated header.
 *
 * Captures the chrome that's repeated 15+ times across the project:
 * overflow-x-auto + rounded border + surface + bg-surface head with
 * fg-muted uppercase labels + divide-rule body. Consumers pass the
 * column config and render `<tr>` rows in the default slot, keeping
 * full control over cell content (links, formatted values, conditional
 * status pills, etc.).
 *
 *   <DataTable
 *     columns={[
 *       { label: "Variant" },
 *       { label: "AIC", align: "right" },
 *       { label: "Caveats" },
 *     ]}
 *   >
 *     {rows.map((row) => (
 *       <tr>
 *         <td class="px-3 py-2 font-mono">{row.variant}</td>
 *         <td class="px-3 py-2 text-right font-mono">{row.aic}</td>
 *         <td class="px-3 py-2">...</td>
 *       </tr>
 *     ))}
 *   </DataTable>
 *
 * `density="compact"` tightens the head padding for inner/nested tables.
 */
interface Column {
  label: string;
  align?: "left" | "right" | "center";
  title?: string;
  colspan?: number;
  rowspan?: number;
  /** Extra Tailwind classes for this column's header cell (e.g. "w-48"). */
  class?: string;
}

interface Props {
  /** Single-row header. Use `headerRows` for multi-row / colspan headers. */
  columns?: Column[];
  /** Multi-row header. First row gets normal head padding, subsequent
   * rows get smaller padding + smaller font (the "sub-header" pattern
   * used for things like {variant} above {AIC, params} sub-columns). */
  headerRows?: Column[][];
  density?: "compact" | "md";
  /** Layout-mode override for the wrapping div. */
  class?: string;
}

const {
  columns,
  headerRows,
  density = "md",
  class: className,
} = Astro.props as Props;

const headPad = density === "compact" ? "px-2 py-1.5" : "px-3 py-2";
const subHeadPad = "px-3 py-1 text-mono-id";
const rows: Column[][] = headerRows ?? (columns ? [columns] : []);

function alignClass(align: Column["align"]): string {
  if (align === "right") return "text-right";
  if (align === "center") return "text-center";
  return "text-left";
}
---

<div
  class:list={[
    "overflow-x-auto rounded-md border border-rule bg-surface-raised",
    className,
  ]}
>
  <table class="w-full text-body">
    <thead class="bg-surface text-left text-body-xs uppercase tracking-wide text-fg-muted">
      {rows.map((row, rowIndex) => (
        <tr>
          {row.map((col) => (
            <th
              colspan={col.colspan}
              rowspan={col.rowspan}
              class:list={[
                rowIndex === 0 ? headPad : subHeadPad,
                alignClass(col.align),
                col.class,
              ]}
              title={col.title}
            >
              {col.label}
            </th>
          ))}
        </tr>
      ))}
    </thead>
    <tbody class="divide-y divide-rule">
      <slot />
    </tbody>
  </table>
</div>
