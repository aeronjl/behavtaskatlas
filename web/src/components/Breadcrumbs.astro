---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props as Props;
---

<nav aria-label="Breadcrumb" class="mb-3 text-xs text-fg-muted">
  <ol class="flex flex-wrap items-center gap-1">
    {crumbs.map((crumb, index) => (
      <li class="flex items-center gap-1">
        {crumb.href && index < crumbs.length - 1 ? (
          <a
            href={crumb.href}
            class="no-underline text-fg-muted hover:text-accent"
          >
            {crumb.label}
          </a>
        ) : (
          <span class="text-fg-secondary">{crumb.label}</span>
        )}
        {index < crumbs.length - 1 ? (
          <span class="text-fg-subtle" aria-hidden="true">/</span>
        ) : null}
      </li>
    ))}
  </ol>
</nav>
